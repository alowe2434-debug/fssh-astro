---
import Base from '../../../layouts/Base.astro';
const N8N_WEBHOOK = 'https://shiro770.app.n8n.cloud/webhook/fssh-reg4-lead';
const NEIGHBORHOOD = 'Westwood';
const SLUG = 'westwood';
const schema = {"@context":"https://schema.org","@graph":[{"@type":"WebPage","@id":`https://firesafetysupplyhouse.com/lafd-regulation-4/${SLUG}/`,"url":`https://firesafetysupplyhouse.com/lafd-regulation-4/${SLUG}/`,"name":`LAFD Regulation 4 Compliance — ${NEIGHBORHOOD}`,"breadcrumb":{"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://firesafetysupplyhouse.com/"},{"@type":"ListItem","position":2,"name":"LAFD Regulation 4","item":"https://firesafetysupplyhouse.com/lafd-regulation-4/"},{"@type":"ListItem","position":3,"name":NEIGHBORHOOD,"item":`https://firesafetysupplyhouse.com/lafd-regulation-4/${SLUG}/`}]}}]};
const buildingTypes = [
  { type: 'Luxury High-Rise Residential (Wilshire)', systems: 'Fire alarm, sprinkler, standpipe, smoke management, generator', nfpa: ['NFPA 72','NFPA 25','NFPA 14','NFPA 92','NFPA 110'], freq: 'Alarm: Annual · Smoke Mgmt: Annual · Generator: Annual · Standpipe: 5 Years' },
  { type: 'Medical Office / Ambulatory Care', systems: 'Fire alarm, sprinkler, medical gas suppression, emergency power', nfpa: ['NFPA 72','NFPA 25','NFPA 99','NFPA 110'], freq: 'Alarm: Annual · Sprinkler: 5 Years · Generator: Annual' },
  { type: 'Class A Office Tower', systems: 'Fire alarm, sprinkler, standpipe, smoke management', nfpa: ['NFPA 72','NFPA 25','NFPA 14','NFPA 92'], freq: 'Alarm: Annual · Smoke Mgmt: Annual · Sprinkler/Standpipe: 5 Years' },
  { type: 'Restaurant / Cafe (Westwood Village)', systems: 'Kitchen suppression, fire alarm, extinguishers', nfpa: ['NFPA 96','NFPA 10','NFPA 72'], freq: 'Suppression: Semi-annual · Alarm: Annual' },
  { type: 'Retail / Commercial (Westwood Village)', systems: 'Fire alarm, extinguishers, sprinkler', nfpa: ['NFPA 72','NFPA 10','NFPA 25'], freq: 'Alarm: Annual · Sprinkler: 5 Years' },
  { type: 'UCLA-Adjacent Research / Lab', systems: 'Fire alarm, sprinkler, special hazard suppression', nfpa: ['NFPA 72','NFPA 25','NFPA 2001'], freq: 'Alarm: Annual · Sprinkler: 5 Years · Clean Agent: Annual' },
];
const nearbyHoods = [
  { slug: 'century-city', name: 'Century City', type: 'Office towers · Medical' },
  { slug: 'mid-wilshire', name: 'Mid-Wilshire', type: 'Office · Retail · Cultural' },
  { slug: 'playa-vista', name: 'Playa Vista', type: 'Tech campus · Office' },
  { slug: 'hollywood', name: 'Hollywood', type: 'Entertainment · Commercial' },
];
const deficiencies = [
  'Smoke management system deferrals in Wilshire corridor residential towers — annual NFPA 92 testing required but frequently deferred by HOAs unfamiliar with the distinction from the fire alarm test',
  'Emergency generator testing gaps in Westwood medical buildings — annual load-bank testing under NFPA 110 required but skipped in multiple ambulatory care facilities along the medical corridor',
  'Medical gas suppression compliance gaps — NFPA 99 obligations in ambulatory surgery centers and dental offices with nitrous oxide systems often fall outside standard Reg 4 tester scope',
  'Standpipe hose valve pressure deficiencies in 1970s–1980s Wilshire towers — five-year NFPA 14 service cycle missed in older residential high-rises without proactive maintenance programs',
  'Restaurant kitchen suppression lapses in Westwood Village tenant turnover — student-heavy market with high F&B churn creates frequent compliance gaps between outgoing and incoming operators',
  'Sprinkler head age in pre-1990 high-rise residential buildings — original heads on Wilshire corridor construction from the 1970s boom are approaching or past manufacturer service life',
];
const faqs = [
  { q: 'Our Westwood high-rise has a smoke management system. Does Reg 4 require annual testing?', a: 'Yes. Smoke management and smoke control systems in high-rise buildings (75 feet and above) must be tested annually under NFPA 92 as required by LAFD Regulation 4. This is a separate inspection from the annual fire alarm test — it requires a different LAFD-certified tester category and must be filed independently through thecomplianceengine.com within 7 days.' },
  { q: 'We operate a medical office in Westwood with nitrous oxide. What does Reg 4 require?', a: 'Medical facilities with piped medical gases are subject to NFPA 99 health care facilities code. Standard Reg 4 fire protection obligations apply (alarm, sprinkler), plus NFPA 99 adds specific requirements for medical gas shutoff valves, zone valve boxes, and alarm panels. Confirm your specific obligations with a licensed fire protection engineer familiar with healthcare occupancies.' },
  { q: "We're an HOA board for a Wilshire corridor condominium tower. What are our Reg 4 responsibilities?", a: 'The HOA is responsible for Regulation 4 compliance of all common-area fire systems — fire alarm, sprinkler, standpipe, smoke management, and emergency generators serving life safety loads. Individual unit owners are not separately responsible if their in-unit devices are part of the building-wide addressable system. Engage a property management company or fire protection consultant to track your compliance calendar and ensure annual TCE filings are complete.' },
  { q: 'How far in advance should I book a Westwood Reg 4 tester?', a: 'LAFD-certified testers in Westwood typically book 4–6 weeks out during peak compliance periods (January–March and again in Q3). For buildings with multiple system categories — alarm, smoke management, generator, sprinkler — each requires a separately certified tester. Book all categories simultaneously to avoid staggered compliance gaps and missed TCE filing windows.' },
];
---
<Base title="LAFD Regulation 4 Compliance — Westwood | Fire Safety Supply House" description="LAFD Regulation 4 fire system compliance for Westwood buildings. Wilshire corridor high-rises, medical offices, luxury residential towers, and Westwood Village commercial — fire alarm and suppression testing, equipment supply, and LAFD-certified tester referrals." canonical={`https://firesafetysupplyhouse.com/lafd-regulation-4/${SLUG}/`} schema={schema}>
<style>
  .hood-hero { background: #1a2744; }
  .alert-strip { background: #fdf2f0; border-top: 3px solid #c0392b; border-bottom: 1px solid #fbd5d0; }
  .sform { background: #1a2744; border-radius: 12px; overflow: hidden; }
  .fi { width:100%; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.15); border-radius:6px; padding:10px 12px; font-size:13.5px; color:#fff; font-family:inherit; outline:none; margin-bottom:10px; }
  .fi::placeholder { color:rgba(255,255,255,0.3); }
  .qfr { display:flex; justify-content:space-between; padding:9px 0; border-bottom:1px solid #f0f0f0; font-size:13px; }
  .qfr:last-child { border-bottom:none; }
  .npill { display:inline-block; background:#1a2744; color:#fff; font-size:10.5px; font-weight:600; padding:2px 7px; border-radius:3px; margin:2px 2px 0 0; }
</style>
  <div class="bg-gray-50 border-b border-gray-200"><div class="section py-2.5"><nav class="flex items-center gap-1.5 text-xs text-gray-400"><a href="/" class="hover:text-gray-700 no-underline">Home</a><span>/</span><a href="/lafd-regulation-4/" class="hover:text-gray-700 no-underline">LAFD Regulation 4</a><span>/</span><span class="text-gray-700 font-medium">{NEIGHBORHOOD}</span></nav></div></div>
  <div class="hood-hero py-14"><div class="section"><div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-center"><div class="lg:col-span-2">
    <div class="inline-flex items-center gap-2 bg-red-brand/20 border border-red-brand/40 text-red-300 text-xs font-bold tracking-widest uppercase px-3 py-1.5 rounded mb-5"><span class="w-1.5 h-1.5 rounded-full bg-red-brand inline-block"></span>{NEIGHBORHOOD} — Los Angeles City Limits — LAFD Jurisdiction</div>
    <h1 class="text-4xl lg:text-5xl font-bold text-white tracking-tight leading-tight mb-4">LAFD Regulation 4 Compliance in {NEIGHBORHOOD}</h1>
    <p class="text-lg text-blue-200 max-w-2xl leading-relaxed mb-6">Westwood's Regulation 4 profile spans two distinct zones: the Wilshire Boulevard high-rise corridor — luxury residential towers and Class A medical office buildings — and Westwood Village commercial district adjacent to UCLA. Medical occupancies along the Westwood medical corridor carry some of the most layered Reg 4 obligations in West LA, combining NFPA 99, NFPA 110, and NFPA 92 on top of the standard annual fire alarm cycle.</p>
    <div class="flex flex-wrap gap-2"><span class="bg-white/10 border border-white/15 text-blue-100 text-xs font-medium px-3 py-1.5 rounded">High-Rise Smoke Management</span><span class="bg-white/10 border border-white/15 text-blue-100 text-xs font-medium px-3 py-1.5 rounded">Medical NFPA 99 Compliance</span><span class="bg-white/10 border border-white/15 text-blue-100 text-xs font-medium px-3 py-1.5 rounded">7-Day Compliance Engine Filing</span><span class="bg-white/10 border border-white/15 text-blue-100 text-xs font-medium px-3 py-1.5 rounded">48hr Equipment Fulfillment</span></div>
  </div><div class="flex flex-col gap-2">
    <div class="bg-white/10 border border-white/10 rounded-xl p-4 text-center"><div class="text-3xl font-bold text-white mb-1">Annual</div><div class="text-xs text-blue-300">Smoke management testing required for every Wilshire corridor high-rise under NFPA 92</div></div>
    <div class="bg-white/10 border border-white/10 rounded-xl p-4 text-center"><div class="text-3xl font-bold text-white mb-1">NFPA 99</div><div class="text-xs text-blue-300">Medical gas compliance required in Westwood medical corridor facilities — separate from standard Reg 4 alarm test</div></div>
    <div class="bg-white/10 border border-white/10 rounded-xl p-4 text-center"><div class="text-3xl font-bold text-white mb-1">7</div><div class="text-xs text-blue-300">Days to file inspection results through The Compliance Engine</div></div>
  </div></div></div></div>
  <div class="alert-strip px-6 py-4"><div class="section flex items-start gap-3"><span class="text-red-brand text-lg mt-0.5 flex-shrink-0">⚠</span><p class="text-sm text-red-900 leading-relaxed"><strong class="text-red-brand">Westwood Compliance Notice:</strong> Westwood is within Los Angeles City limits under LAFD jurisdiction. High-rise residential towers on Wilshire must test smoke management systems <strong>annually</strong> under NFPA 92. Medical buildings with backup power require annual emergency generator testing under NFPA 110. Westwood Village restaurants require <strong>semi-annual</strong> kitchen suppression inspection. All results filed within <strong>7 days</strong> via thecomplianceengine.com.</p></div></div>
  <div class="section py-14"><div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start"><div class="lg:col-span-2 space-y-14">
    <div><div class="tag text-red-brand mb-2">Context</div><h2 class="text-3xl font-bold tracking-tight mb-4">Regulation 4 in {NEIGHBORHOOD}</h2>
    <p class="text-gray-600 leading-relaxed mb-4">Westwood's compliance profile is defined by two distinct corridors: the Wilshire Boulevard high-rise corridor — a concentration of luxury residential towers and Class A medical office buildings — and the Westwood Village commercial district adjacent to UCLA. Both carry significant Regulation 4 obligations, with the Wilshire towers requiring smoke management and standpipe testing on top of the standard annual fire alarm cycle.</p>
    <p class="text-gray-600 leading-relaxed mb-6">Medical occupancies along Westwood's medical corridor combine NFPA 99 healthcare facility requirements with standard Reg 4 obligations — creating stacked compliance calendars that require testers certified in multiple categories. Emergency generator testing, medical gas systems, and standard fire alarm obligations each require separate certified testers and separate TCE filings.</p>
    <div class="grid grid-cols-2 gap-3">
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-4"><div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">AHJ</div><div class="text-sm font-semibold text-gray-800">Los Angeles Fire Department</div><div class="text-xs text-gray-500 mt-0.5">All of Westwood is LAFD jurisdiction</div></div>
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-4"><div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">Key Risk</div><div class="text-sm font-semibold text-gray-800">Medical + High-Rise Overlap</div><div class="text-xs text-gray-500 mt-0.5">NFPA 99 + NFPA 92 obligations stacked</div></div>
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-4"><div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">Filing Platform</div><div class="text-sm font-semibold text-gray-800">thecomplianceengine.com</div><div class="text-xs text-gray-500 mt-0.5">7-day electronic submission required</div></div>
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-4"><div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">Equipment Lead Time</div><div class="text-sm font-semibold text-red-brand">48 Hours</div><div class="text-xs text-gray-500 mt-0.5">FSSH fulfillment for Westwood addresses</div></div>
    </div></div>
    <div><div class="tag text-red-brand mb-2">By Building Type</div><h2 class="text-3xl font-bold tracking-tight mb-4">{NEIGHBORHOOD} Building Types &amp; Requirements</h2>
    <div class="overflow-x-auto rounded-xl border border-gray-200"><table class="w-full text-sm border-collapse"><thead><tr class="bg-[#1a2744] text-white"><th class="text-left px-4 py-3 text-xs font-semibold tracking-wider">Building Type</th><th class="text-left px-4 py-3 text-xs font-semibold tracking-wider hidden md:table-cell">NFPA Standards</th><th class="text-left px-4 py-3 text-xs font-semibold tracking-wider">Frequency</th></tr></thead><tbody>
      {buildingTypes.map((bt, i) => (<tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}><td class="px-4 py-3 border-b border-gray-100 font-semibold text-[#1a2744] align-top text-sm">{bt.type}</td><td class="px-4 py-3 border-b border-gray-100 align-top hidden md:table-cell">{bt.nfpa.map(n => <span class="npill">{n}</span>)}</td><td class="px-4 py-3 border-b border-gray-100 text-xs text-gray-600 align-top leading-relaxed">{bt.freq}</td></tr>))}
    </tbody></table></div></div>
    <div><div class="tag text-red-brand mb-2">What Gets Flagged</div><h2 class="text-3xl font-bold tracking-tight mb-4">Most Common Reg 4 Deficiencies in {NEIGHBORHOOD}</h2>
    <div class="flex flex-col gap-3">{deficiencies.map(d => (<div class="flex items-start gap-3 bg-red-light border border-red-200 border-l-4 border-l-red-brand rounded-r-lg px-4 py-3 text-sm text-red-900"><span class="text-red-brand flex-shrink-0 mt-0.5">⚠</span>{d}</div>))}</div></div>
    <div><div class="tag text-red-brand mb-2">FAQ</div><h2 class="text-3xl font-bold tracking-tight mb-6">{NEIGHBORHOOD} — Regulation 4 FAQs</h2>
    <div class="divide-y divide-gray-100">{faqs.map(faq => (<details class="group py-4"><summary class="flex items-center justify-between gap-4 cursor-pointer list-none"><span class="text-sm font-semibold text-gray-800 group-open:text-red-brand transition-colors">{faq.q}</span><span class="w-6 h-6 flex-shrink-0 bg-gray-100 group-open:bg-red-brand rounded-full flex items-center justify-center text-gray-600 group-open:text-white text-base leading-none transition-all">+</span></summary><p class="text-sm text-gray-600 leading-relaxed mt-3 pb-1">{faq.a}</p></details>))}</div></div>
    <div><div class="tag text-red-brand mb-2">Other Neighborhoods</div><h2 class="text-3xl font-bold tracking-tight mb-4">Other Los Angeles City Neighborhoods</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">{nearbyHoods.map(hood => (<a href={`/lafd-regulation-4/${hood.slug}/`} class="flex items-center justify-between border border-gray-200 rounded-xl p-4 hover:border-[#1a2744] hover:bg-gray-50 no-underline transition-all"><div><div class="text-sm font-semibold text-[#1a2744]">{hood.name}</div><div class="text-xs text-gray-400 mt-0.5">{hood.type}</div></div><span class="text-gray-300 ml-3">→</span></a>))}<a href="/lafd-regulation-4/" class="flex items-center border border-gray-200 rounded-xl p-4 hover:border-red-brand hover:bg-red-light no-underline transition-all"><span class="text-sm font-semibold text-red-brand">View All LA City Neighborhoods</span></a></div></div>
  </div>
  <div class="space-y-5 lg:sticky lg:top-20">
    <div class="sform"><div class="bg-white/10 border-b border-white/10 px-5 py-3.5"><span class="text-xs font-bold uppercase tracking-wider text-blue-300">Free {NEIGHBORHOOD} Compliance Assessment</span></div>
    <div class="p-5"><p class="text-xs text-blue-200 mb-4 leading-relaxed">Building in {NEIGHBORHOOD}? We'll review your Reg 4 status and connect you with an LAFD-certified tester.</p>
      <input id="ww-name" type="text" class="fi" placeholder="Your name" />
      <input id="ww-address" type="text" class="fi" placeholder="Building address" />
      <select id="ww-type" class="fi"><option value="">Building type...</option><option>Luxury High-Rise Residential</option><option>Medical Office / Ambulatory Care</option><option>Class A Office Tower</option><option>Restaurant / Cafe (Westwood Village)</option><option>Retail / Commercial</option><option>Research / Lab</option></select>
      <input id="ww-floors" type="text" class="fi" placeholder="Number of floors" />
      <select id="ww-inspection" class="fi"><option value="">Last inspection...</option><option>Within the last year</option><option>1-2 years ago</option><option>2+ years ago</option><option>Never / Unknown</option></select>
      <input id="ww-email" type="email" class="fi" placeholder="Email address" />
      <input id="ww-phone" type="tel" class="fi" placeholder="Phone number" />
      <button id="ww-submit" class="w-full bg-red-brand text-white py-3.5 rounded-lg text-sm font-bold hover:bg-red-dark transition-colors cursor-pointer border-0">Get Free Assessment</button>
      <div id="ww-success" style="display:none" class="text-center text-green-300 text-sm font-medium mt-3">✓ Received — we'll be in touch within one business day.</div>
      <p class="text-xs text-center mt-3" style="color:rgba(147,197,253,0.4)">Response within one business day.</p>
    </div></div>
    <div class="border border-gray-200 rounded-xl overflow-hidden"><div class="bg-gray-50 border-b border-gray-200 px-4 py-3"><span class="text-xs font-bold uppercase tracking-wider text-gray-400">{NEIGHBORHOOD} Quick Facts</span></div>
    <div class="p-4"><div class="qfr"><span class="text-gray-400 font-medium">Jurisdiction</span><span class="text-gray-800 font-semibold">LA City (LAFD)</span></div><div class="qfr"><span class="text-gray-400 font-medium">Fire Alarms</span><span class="text-gray-800 font-semibold">Annual</span></div><div class="qfr"><span class="text-gray-400 font-medium">Smoke Management</span><span class="font-bold text-red-brand">Annual</span></div><div class="qfr"><span class="text-gray-400 font-medium">Generator Testing</span><span class="font-bold text-red-brand">Annual</span></div><div class="qfr"><span class="text-gray-400 font-medium">Sprinklers / Standpipe</span><span class="font-bold text-red-brand">5 Years</span></div><div class="qfr"><span class="text-gray-400 font-medium">Repair/Retest</span><span class="font-bold text-red-brand">30 days</span></div><div class="qfr"><span class="text-gray-400 font-medium">Filing Deadline</span><span class="text-gray-800 font-semibold">7 days</span></div><div class="qfr"><span class="text-gray-400 font-medium">Equipment Lead Time</span><span class="text-gray-800 font-semibold">48 hours</span></div></div></div>
    <div class="border border-gray-200 rounded-xl overflow-hidden"><div class="bg-gray-50 border-b border-gray-200 px-4 py-3"><span class="text-xs font-bold uppercase tracking-wider text-gray-400">LAFD Reg 4 Unit</span></div>
    <div class="p-4 space-y-2"><p class="text-xs text-gray-600 leading-relaxed">Bureau of Fire Prevention and Public Safety<br/>200 North Main Street, Room 1750<br/>Los Angeles, CA 90012</p><a href="tel:+12139783560" class="block text-sm font-bold text-red-brand no-underline">(213) 978-3560</a><a href="mailto:LafdReg4@lacity.org" class="block text-xs text-red-brand no-underline">LafdReg4@lacity.org</a></div></div>
    <div class="border border-gray-200 rounded-xl overflow-hidden"><div class="bg-gray-50 border-b border-gray-200 px-4 py-3"><span class="text-xs font-bold uppercase tracking-wider text-gray-400">NFPA Standards</span></div><div class="p-4 flex flex-wrap gap-1.5">{['NFPA 10','NFPA 14','NFPA 25','NFPA 72','NFPA 92','NFPA 96','NFPA 99','NFPA 101','NFPA 110','NFPA 2001','Title 19 CCR'].map(tag => (<span class="npill">{tag}</span>))}</div></div>
  </div></div></div>
  <script define:vars={{ N8N_WEBHOOK, NEIGHBORHOOD }}>
    document.getElementById('ww-submit').addEventListener('click', async function() {
      const btn = this; btn.textContent = 'Submitting...'; btn.disabled = true;
      const payload = { neighborhood: NEIGHBORHOOD, name: document.getElementById('ww-name').value, address: document.getElementById('ww-address').value, buildingType: document.getElementById('ww-type').value, floors: document.getElementById('ww-floors').value, lastInspection: document.getElementById('ww-inspection').value, email: document.getElementById('ww-email').value, phone: document.getElementById('ww-phone').value, source: 'FSSH Reg 4 — Westwood' };
      try { await fetch(N8N_WEBHOOK, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) }); } catch(e) {}
      document.getElementById('ww-success').style.display = 'block'; btn.style.display = 'none';
    });
  </script>
</Base>

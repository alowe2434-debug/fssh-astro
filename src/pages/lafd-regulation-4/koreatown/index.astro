---
import Base from '../../../layouts/Base.astro';

const N8N_WEBHOOK = 'https://shiro770.app.n8n.cloud/webhook/fssh-reg4-lead';
const NEIGHBORHOOD = 'Koreatown';
const SLUG = 'koreatown';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `https://firesafetysupplyhouse.com/lafd-regulation-4/${SLUG}/`,
      "url": `https://firesafetysupplyhouse.com/lafd-regulation-4/${SLUG}/`,
      "name": `LAFD Regulation 4 Compliance — ${NEIGHBORHOOD}`,
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://firesafetysupplyhouse.com/"},
          {"@type": "ListItem", "position": 2, "name": "LAFD Regulation 4", "item": "https://firesafetysupplyhouse.com/lafd-regulation-4/"},
          {"@type": "ListItem", "position": 3, "name": NEIGHBORHOOD, "item": `https://firesafetysupplyhouse.com/lafd-regulation-4/${SLUG}/`}
        ]
      }
    }
  ]
};

const buildingTypes = [
  { type: 'Restaurant / Korean BBQ', systems: 'Kitchen suppression (table-top + overhead), fire alarm, extinguishers', nfpa: ['NFPA 96','NFPA 10','NFPA 72'], freq: 'Suppression: Semi-annual · Alarm: Annual' },
  { type: 'Mid-Rise Apartment / Mixed-Use', systems: 'Fire alarm, sprinkler systems, standpipe', nfpa: ['NFPA 72','NFPA 25','NFPA 14'], freq: 'Alarm: Annual · Sprinkler/Standpipe: 5 Years' },
  { type: 'Nightclub / Karaoke Bar', systems: 'Fire alarm, sprinkler, kitchen suppression, egress', nfpa: ['NFPA 72','NFPA 25','NFPA 96','NFPA 101'], freq: 'Alarm: Annual · Kitchen: Semi-annual' },
  { type: 'Retail Strip / Commercial', systems: 'Fire alarm, extinguishers', nfpa: ['NFPA 72','NFPA 10'], freq: 'Alarm: Annual · Extinguisher: Annual' },
  { type: 'Hotel / Motel', systems: 'Fire alarm, sprinkler, kitchen suppression', nfpa: ['NFPA 72','NFPA 25','NFPA 96'], freq: 'Alarm: Annual · Kitchen: Semi-annual' },
  { type: 'Medical / Dental Office', systems: 'Fire alarm, extinguishers, sprinkler', nfpa: ['NFPA 72','NFPA 25','NFPA 10'], freq: 'Alarm: Annual · Sprinkler: 5 Years' },
];

const nearbyHoods = [
  { slug: 'downtown-los-angeles', name: 'Downtown Los Angeles', type: 'High-rise · Hotel · Office' },
  { slug: 'hollywood', name: 'Hollywood', type: 'Entertainment · Commercial' },
  { slug: 'mid-wilshire', name: 'Mid-Wilshire', type: 'Office · Retail · Cultural' },
  { slug: 'westwood', name: 'Westwood', type: 'Medical · University' },
];

const deficiencies = [
  'Table-top Korean BBQ suppression systems — many KBBQ operators have overhead hood suppression but lack required table-level suppression for charcoal and gas grill setups, which LAFD now actively inspects',
  'Aging fire alarm panels in 1960s–1980s mid-rise residential buildings — system sensor compatibility issues when upgrading from conventional to addressable panels',
  'High-density restaurant clustering creating simultaneous Reg 4 filing backlogs — certified testers in Koreatown are booked 4–6 weeks in advance during peak compliance cycles',
  'Karaoke room egress deficiencies — enclosed karaoke suites often lack compliant emergency lighting and exit signage meeting NFPA 101 assembly occupancy standards',
  'Missing sprinkler coverage in commercial kitchen expansions — tenant buildouts that expanded kitchen footprints without updating sprinkler head placement',
  'Expired portable extinguisher tags in high-turnover retail spaces — Koreatown\'s rapid business churn frequently leaves compliance gaps between outgoing and incoming tenants',
];
---

<Base
  title={`LAFD Regulation 4 Compliance — Koreatown | Fire Safety Supply House`}
  description={`LAFD Regulation 4 fire system compliance for Koreatown buildings. Korean BBQ restaurants, mid-rise apartments, nightclubs,`}
  canonical={`https://firesafetysupplyhouse.com/lafd-regulation-4/${SLUG}/`}
  schema={schema}
>
<style>
  .hood-hero { background: #1a2744; }
  .alert-strip { background: #fdf2f0; border-top: 3px solid #c0392b; border-bottom: 1px solid #fbd5d0; }
  .sform { background: #1a2744; border-radius: 12px; overflow: hidden; }
  .fi { width:100%; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.15); border-radius:6px; padding:10px 12px; font-size:13.5px; color:#fff; font-family:inherit; outline:none; margin-bottom:10px; }
  .fi::placeholder { color:rgba(255,255,255,0.3); }
  .qfr { display:flex; justify-content:space-between; padding:9px 0; border-bottom:1px solid #f0f0f0; font-size:13px; }
  .qfr:last-child { border-bottom:none; }
  .npill { display:inline-block; background:#1a2744; color:#fff; font-size:10.5px; font-weight:600; padding:2px 7px; border-radius:3px; margin:2px 2px 0 0; }
  .pimg { background:#fff; height:110px; display:flex; align-items:center; justify-content:center; padding:12px; border-bottom:1px solid #e2e6ec; overflow:hidden; }
  .pimg img { max-height:100%; max-width:100%; object-fit:contain; transition:transform 0.2s; }
  .pcard:hover .pimg img { transform:scale(1.04); }
</style>

  <div class="bg-gray-50 border-b border-gray-200">
    <div class="section py-2.5">
      <nav class="flex items-center gap-1.5 text-xs text-gray-400">
        <a href="/" class="hover:text-gray-700 no-underline">Home</a>
        <span>/</span>
        <a href="/lafd-regulation-4/" class="hover:text-gray-700 no-underline">LAFD Regulation 4</a>
        <span>/</span>
        <span class="text-gray-700 font-medium">{NEIGHBORHOOD}</span>
      </nav>
    </div>
  </div>

  <div class="hood-hero py-14">
    <div class="section">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-center">
        <div class="lg:col-span-2">
          <div class="inline-flex items-center gap-2 bg-red-brand/20 border border-red-brand/40 text-red-300 text-xs font-bold tracking-widest uppercase px-3 py-1.5 rounded mb-5">
            <span class="w-1.5 h-1.5 rounded-full bg-red-brand inline-block"></span>
            Koreatown — Los Angeles City Limits — LAFD Jurisdiction
          </div>
          <h1 class="text-4xl lg:text-5xl font-bold text-white tracking-tight leading-tight mb-4">
            LAFD Regulation 4 Compliance in Koreatown
          </h1>
          <p class="text-lg text-blue-200 max-w-2xl leading-relaxed mb-6">
            Koreatown is the densest neighborhood in Los Angeles — and one of the most complex under Regulation 4. Korean BBQ restaurants with table-top grill suppression, karaoke venues, dense mid-rise apartment buildings, and 24-hour commercial operations all carry distinct fire protection obligations that the LAFD enforces aggressively.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="bg-white/10 border border-white/15 text-blue-100 text-xs font-medium px-3 py-1.5 rounded">KBBQ Suppression Specialists</span>
            <span class="bg-white/10 border border-white/15 text-blue-100 text-xs font-medium px-3 py-1.5 rounded">Semi-Annual Kitchen Compliance</span>
            <span class="bg-white/10 border border-white/15 text-blue-100 text-xs font-medium px-3 py-1.5 rounded">7-Day Compliance Engine Filing</span>
            <span class="bg-white/10 border border-white/15 text-blue-100 text-xs font-medium px-3 py-1.5 rounded">48hr Equipment Fulfillment</span>
          </div>
        </div>
        <div class="flex flex-col gap-2">
          <div class="bg-white/10 border border-white/10 rounded-xl p-4 text-center">
            <div class="text-3xl font-bold text-white mb-1">#1</div>
            <div class="text-xs text-blue-300">Densest neighborhood in LA — highest concentration of F&B Reg 4 obligations per square mile</div>
          </div>
          <div class="bg-white/10 border border-white/10 rounded-xl p-4 text-center">
            <div class="text-3xl font-bold text-white mb-1">2x/yr</div>
            <div class="text-xs text-blue-300">KBBQ and restaurant kitchen suppression inspection frequency under NFPA 96</div>
          </div>
          <div class="bg-white/10 border border-white/10 rounded-xl p-4 text-center">
            <div class="text-3xl font-bold text-white mb-1">30</div>
            <div class="text-xs text-blue-300">Days to correct deficiencies and retest after inspection</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="alert-strip px-6 py-4">
    <div class="section flex items-start gap-3">
      <span class="text-red-brand text-lg mt-0.5 flex-shrink-0">⚠</span>
      <p class="text-sm text-red-900 leading-relaxed">
        <strong class="text-red-brand">Koreatown Compliance Notice:</strong> Koreatown falls entirely within Los Angeles City limits under LAFD jurisdiction. Korean BBQ operators: table-top grill suppression systems are subject to LAFD inspection separate from overhead hood systems. <strong>Both require semi-annual service under NFPA 96.</strong> Results must be filed via thecomplianceengine.com within <strong>7 days</strong>.
      </p>
    </div>
  </div>

  <div class="section py-14">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start">
      <div class="lg:col-span-2 space-y-14">

        <div>
          <div class="tag text-red-brand mb-2">Context</div>
          <h2 class="text-3xl font-bold tracking-tight mb-4">Regulation 4 in Koreatown</h2>
          <p class="text-gray-600 leading-relaxed mb-4">Koreatown's commercial density — centered on Wilshire Boulevard, Western Avenue, and 6th Street — concentrates more Regulation 4 obligations per block than almost any other LA neighborhood. The combination of KBBQ restaurants, karaoke venues, 24-hour retail, and aging mid-rise residential buildings creates a compounding compliance load that many property managers underestimate.</p>
          <p class="text-gray-600 leading-relaxed mb-6">A common misconception among KBBQ operators is that a semi-annual hood suppression inspection covers all kitchen fire protection obligations under Reg 4. It does not. Table-top charcoal and gas grill suppression systems — if installed — require their own semi-annual inspection by a separately certified LAFD tester. Properties without proper table-level suppression for open-flame cooking are increasingly targeted during LAFD compliance sweeps.</p>
          <div class="grid grid-cols-2 gap-3">
            <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
              <div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">AHJ</div>
              <div class="text-sm font-semibold text-gray-800">Los Angeles Fire Department</div>
              <div class="text-xs text-gray-500 mt-0.5">All of Koreatown is LAFD jurisdiction</div>
            </div>
            <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
              <div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">Key Risk</div>
              <div class="text-sm font-semibold text-gray-800">KBBQ Table-Top Suppression</div>
              <div class="text-xs text-gray-500 mt-0.5">Separate from hood — often missed</div>
            </div>
            <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
              <div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">Filing Platform</div>
              <div class="text-sm font-semibold text-gray-800">thecomplianceengine.com</div>
              <div class="text-xs text-gray-500 mt-0.5">7-day electronic submission required</div>
            </div>
            <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
              <div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">Equipment Lead Time</div>
              <div class="text-sm font-semibold text-red-brand">48 Hours</div>
              <div class="text-xs text-gray-500 mt-0.5">FSSH fulfillment for Koreatown addresses</div>
            </div>
          </div>
        </div>

        <div>
          <div class="tag text-red-brand mb-2">By Building Type</div>
          <h2 class="text-3xl font-bold tracking-tight mb-4">Koreatown Building Types &amp; Requirements</h2>
          <p class="text-gray-600 leading-relaxed mb-4">F&B and mixed-use buildings dominate Koreatown's Reg 4 compliance calendar.</p>
          <div class="overflow-x-auto rounded-xl border border-gray-200">
            <table class="w-full text-sm border-collapse">
              <thead>
                <tr class="bg-[#1a2744] text-white">
                  <th class="text-left px-4 py-3 text-xs font-semibold tracking-wider">Building Type</th>
                  <th class="text-left px-4 py-3 text-xs font-semibold tracking-wider hidden md:table-cell">NFPA Standards</th>
                  <th class="text-left px-4 py-3 text-xs font-semibold tracking-wider">Frequency</th>
                </tr>
              </thead>
              <tbody>
                {buildingTypes.map((bt, i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                    <td class="px-4 py-3 border-b border-gray-100 font-semibold text-[#1a2744] align-top text-sm">{bt.type}</td>
                    <td class="px-4 py-3 border-b border-gray-100 align-top hidden md:table-cell">
                      {bt.nfpa.map(n => <span class="npill">{n}</span>)}
                    </td>
                    <td class="px-4 py-3 border-b border-gray-100 text-xs text-gray-600 align-top leading-relaxed">{bt.freq}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <div>
          <div class="tag text-red-brand mb-2">What Gets Flagged</div>
          <h2 class="text-3xl font-bold tracking-tight mb-4">Most Common Reg 4 Deficiencies in Koreatown</h2>
          <p class="text-gray-600 leading-relaxed mb-4">High-density F&B operations and rapid tenant turnover make Koreatown one of LAFD's most active Regulation 4 enforcement areas.</p>
          <div class="flex flex-col gap-3">
            {deficiencies.map(d => (
              <div class="flex items-start gap-3 bg-red-light border border-red-200 border-l-4 border-l-red-brand rounded-r-lg px-4 py-3 text-sm text-red-900">
                <span class="text-red-brand flex-shrink-0 mt-0.5">⚠</span>
                {d}
              </div>
            ))}
          </div>
        </div>

        <div>
          <div class="tag text-red-brand mb-2">FAQ</div>
          <h2 class="text-3xl font-bold tracking-tight mb-6">Koreatown — Regulation 4 FAQs</h2>
          <div class="divide-y divide-gray-100">
            {[
              { q: 'Does my KBBQ restaurant need suppression at each grill table, not just the overhead hood?', a: 'This is the most common Koreatown compliance gap. Overhead hood systems (NFPA 96) cover the exhaust duct and cooking surface below the hood. If your restaurant uses table-top charcoal or gas grills, the open-flame cooking surface may require supplemental suppression coverage at the table level. LAFD inspectors have increased scrutiny of KBBQ setups specifically. Confirm with an LAFD-certified NFPA 96 tester what coverage your specific layout requires.' },
              { q: 'My karaoke venue has private rooms. Does each room need individual fire alarm devices?', a: 'Yes. Private karaoke suites constitute separate occupancies for fire alarm and egress purposes. Each room requires compliant smoke detection, emergency lighting, and exit signage meeting NFPA 72 and NFPA 101 standards. LAFD has flagged multiple Koreatown venues for inadequate detection coverage in enclosed suite configurations.' },
              { q: 'We own a mid-rise apartment building on Wilshire with ground-floor commercial. Who is responsible for Reg 4?', a: 'The building owner carries ultimate Reg 4 compliance responsibility for both the residential and commercial portions. Commercial tenants with their own cooking equipment (restaurants, cafes) are often responsible for kitchen suppression compliance under their lease, but the building owner remains liable if the system goes uninspected. Review your lease agreements and confirm compliance status across all ground-floor tenants annually.' },
              { q: 'How far in advance should I book a Koreatown Reg 4 tester?', a: 'Demand for LAFD-certified testers in Koreatown typically runs 4–6 weeks out, especially in Q1 (January–March) when annual compliance windows come due simultaneously. Book well ahead of your compliance deadline, not after. Late filing with the Compliance Engine incurs penalties separate from the inspection violation itself.' },
              { q: 'What equipment is most commonly replaced after a Koreatown Reg 4 inspection?', a: 'Kitchen suppression agent cylinders (ANSUL or equivalent), smoke detectors in residential common areas, fire alarm control panels in buildings with obsolete systems, and portable extinguishers across retail spaces are the most frequent replacement items. FSSH maintains stock of all these categories with 48-hour delivery to Koreatown addresses.' },
            ].map(faq => (
              <details class="group py-4">
                <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">
                  <span class="text-sm font-semibold text-gray-800 group-open:text-red-brand transition-colors">{faq.q}</span>
                  <span class="w-6 h-6 flex-shrink-0 bg-gray-100 group-open:bg-red-brand rounded-full flex items-center justify-center text-gray-600 group-open:text-white text-base leading-none transition-all">+</span>
                </summary>
                <p class="text-sm text-gray-600 leading-relaxed mt-3 pb-1">{faq.a}</p>
              </details>
            ))}
          </div>
        </div>

        <div>
          <div class="tag text-red-brand mb-2">Other Neighborhoods</div>
          <h2 class="text-3xl font-bold tracking-tight mb-4">Other Los Angeles City Neighborhoods</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            {nearbyHoods.map(hood => (
              <a href={`/lafd-regulation-4/${hood.slug}/`} class="flex items-center justify-between border border-gray-200 rounded-xl p-4 hover:border-[#1a2744] hover:bg-gray-50 no-underline transition-all">
                <div>
                  <div class="text-sm font-semibold text-[#1a2744]">{hood.name}</div>
                  <div class="text-xs text-gray-400 mt-0.5">{hood.type}</div>
                </div>
                <span class="text-gray-300 ml-3">→</span>
              </a>
            ))}
            <a href="/lafd-regulation-4/" class="flex items-center border border-gray-200 rounded-xl p-4 hover:border-red-brand hover:bg-red-light no-underline transition-all">
              <span class="text-sm font-semibold text-red-brand">View All LA City Neighborhoods</span>
            </a>
          </div>
        </div>

      </div>

      <div class="space-y-5 lg:sticky lg:top-20">
        <div class="sform">
          <div class="bg-white/10 border-b border-white/10 px-5 py-3.5">
            <span class="text-xs font-bold uppercase tracking-wider text-blue-300">Free Koreatown Compliance Assessment</span>
          </div>
          <div class="p-5">
            <p class="text-xs text-blue-200 mb-4 leading-relaxed">Building in Koreatown? We'll review your Reg 4 status and connect you with an LAFD-certified tester.</p>
            <input id="kt-name" type="text" class="fi" placeholder="Your name" />
            <input id="kt-address" type="text" class="fi" placeholder="Building address (Koreatown)" />
            <select id="kt-type" class="fi">
              <option value="">Building type...</option>
              <option>Restaurant / Korean BBQ</option>
              <option>Mid-Rise Apartment / Mixed-Use</option>
              <option>Nightclub / Karaoke Bar</option>
              <option>Retail Strip / Commercial</option>
              <option>Hotel / Motel</option>
              <option>Medical / Dental Office</option>
            </select>
            <input id="kt-floors" type="text" class="fi" placeholder="Number of floors" />
            <select id="kt-inspection" class="fi">
              <option value="">Last inspection...</option>
              <option>Within the last year</option>
              <option>1-2 years ago</option>
              <option>2+ years ago</option>
              <option>Never / Unknown</option>
            </select>
            <input id="kt-email" type="email" class="fi" placeholder="Email address" />
            <input id="kt-phone" type="tel" class="fi" placeholder="Phone number" />
            <button id="kt-submit" class="w-full bg-red-brand text-white py-3.5 rounded-lg text-sm font-bold hover:bg-red-dark transition-colors cursor-pointer border-0">Get Free Assessment</button>
            <div id="kt-success" style="display:none" class="text-center text-green-300 text-sm font-medium mt-3">✓ Received — we'll be in touch within one business day.</div>
            <p class="text-xs text-center mt-3" style="color:rgba(147,197,253,0.4)">Response within one business day.</p>
          </div>
        </div>

        <div class="border border-gray-200 rounded-xl overflow-hidden">
          <div class="bg-gray-50 border-b border-gray-200 px-4 py-3">
            <span class="text-xs font-bold uppercase tracking-wider text-gray-400">Koreatown Quick Facts</span>
          </div>
          <div class="p-4">
            <div class="qfr"><span class="text-gray-400 font-medium">Jurisdiction</span><span class="text-gray-800 font-semibold">LA City (LAFD)</span></div>
            <div class="qfr"><span class="text-gray-400 font-medium">Fire Alarms</span><span class="text-gray-800 font-semibold">Annual</span></div>
            <div class="qfr"><span class="text-gray-400 font-medium">Kitchen / KBBQ</span><span class="font-bold text-red-brand">Semi-Annual</span></div>
            <div class="qfr"><span class="text-gray-400 font-medium">Sprinklers</span><span class="font-bold text-red-brand">5 Years</span></div>
            <div class="qfr"><span class="text-gray-400 font-medium">Repair/Retest</span><span class="font-bold text-red-brand">30 days</span></div>
            <div class="qfr"><span class="text-gray-400 font-medium">Filing Deadline</span><span class="text-gray-800 font-semibold">7 days</span></div>
            <div class="qfr"><span class="text-gray-400 font-medium">Equipment Lead Time</span><span class="text-gray-800 font-semibold">48 hours</span></div>
          </div>
        </div>

        <div class="border border-gray-200 rounded-xl overflow-hidden">
          <div class="bg-gray-50 border-b border-gray-200 px-4 py-3">
            <span class="text-xs font-bold uppercase tracking-wider text-gray-400">LAFD Reg 4 Unit</span>
          </div>
          <div class="p-4 space-y-2">
            <p class="text-xs text-gray-600 leading-relaxed">Bureau of Fire Prevention and Public Safety<br/>Chief's Regulation No. 4 Unit<br/>200 North Main Street, Room 1750<br/>Los Angeles, CA 90012</p>
            <a href="tel:+12139783560" class="block text-sm font-bold text-red-brand no-underline hover:text-red-dark">(213) 978-3560</a>
            <a href="mailto:LafdReg4@lacity.org" class="block text-xs text-red-brand no-underline hover:text-red-dark">LafdReg4@lacity.org</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{ N8N_WEBHOOK, NEIGHBORHOOD }}>
    document.getElementById('kt-submit').addEventListener('click', async function() {
      const btn = this;
      btn.textContent = 'Submitting...';
      btn.disabled = true;
      const payload = {
        neighborhood: NEIGHBORHOOD,
        name: document.getElementById('kt-name').value,
        address: document.getElementById('kt-address').value,
        buildingType: document.getElementById('kt-type').value,
        floors: document.getElementById('kt-floors').value,
        lastInspection: document.getElementById('kt-inspection').value,
        email: document.getElementById('kt-email').value,
        phone: document.getElementById('kt-phone').value,
        source: 'FSSH Reg 4 — Koreatown',
      };
      try {
        await fetch(N8N_WEBHOOK, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
      } catch(e) {}
      document.getElementById('kt-success').style.display = 'block';
      btn.style.display = 'none';
    });
  </script>

</Base>

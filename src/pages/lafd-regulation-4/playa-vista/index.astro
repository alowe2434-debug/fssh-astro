---
import Base from '../../../layouts/Base.astro';
const N8N_WEBHOOK = 'https://shiro770.app.n8n.cloud/webhook/fssh-reg4-lead';
const NEIGHBORHOOD = 'Playa Vista';
const SLUG = 'playa-vista';
const schema = {"@context":"https://schema.org","@graph":[{"@type":"WebPage","@id":`https://firesafetysupplyhouse.com/lafd-regulation-4/${SLUG}/`,"url":`https://firesafetysupplyhouse.com/lafd-regulation-4/${SLUG}/`,"name":`LAFD Regulation 4 Compliance — ${NEIGHBORHOOD}`,"breadcrumb":{"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://firesafetysupplyhouse.com/"},{"@type":"ListItem","position":2,"name":"LAFD Regulation 4","item":"https://firesafetysupplyhouse.com/lafd-regulation-4/"},{"@type":"ListItem","position":3,"name":NEIGHBORHOOD,"item":`https://firesafetysupplyhouse.com/lafd-regulation-4/${SLUG}/`}]}}]};
const buildingTypes = [
  { type: 'Tech Campus / Creative Office', systems: 'Fire alarm, sprinkler, clean agent (server rooms), cafeteria kitchen suppression', nfpa: ['NFPA 72','NFPA 25','NFPA 2001','NFPA 96'], freq: 'Alarm: Annual · Clean Agent: Annual · Cafeteria: Semi-annual · Sprinkler: 5 Years' },
  { type: 'Mixed-Use / Ground-Floor Retail', systems: 'Fire alarm, sprinkler, kitchen suppression', nfpa: ['NFPA 72','NFPA 25','NFPA 96'], freq: 'Alarm: Annual · Kitchen: Semi-annual · Sprinkler: 5 Years' },
  { type: 'Mid-Rise Residential', systems: 'Fire alarm, sprinkler, standpipe, emergency generator', nfpa: ['NFPA 72','NFPA 25','NFPA 14','NFPA 110'], freq: 'Alarm: Annual · Generator: Annual · Standpipe: 5 Years' },
  { type: 'Restaurant / Cafe', systems: 'Kitchen suppression, fire alarm, extinguishers', nfpa: ['NFPA 96','NFPA 10','NFPA 72'], freq: 'Suppression: Semi-annual · Alarm: Annual' },
  { type: 'Fitness / Wellness Center', systems: 'Fire alarm, sprinkler, extinguishers', nfpa: ['NFPA 72','NFPA 25','NFPA 10'], freq: 'Alarm: Annual · Sprinkler: 5 Years' },
  { type: 'Data Center / Server Room', systems: 'Clean agent suppression, fire alarm, emergency power', nfpa: ['NFPA 2001','NFPA 72','NFPA 110'], freq: 'Alarm: Annual · Clean Agent: Annual · Generator: Annual' },
];
const nearbyHoods = [
  { slug: 'westwood', name: 'Westwood', type: 'Medical · University' },
  { slug: 'century-city', name: 'Century City', type: 'Office towers · Medical' },
  { slug: 'mid-wilshire', name: 'Mid-Wilshire', type: 'Office · Retail · Cultural' },
  { slug: 'downtown-los-angeles', name: 'Downtown Los Angeles', type: 'High-rise · Hotel · Office' },
];
const deficiencies = [
  'First-year compliance drift on new tech campuses — facility managers assume the building inspector sign-off at certificate of occupancy covers ongoing Reg 4 obligations; it does not initiate the TCE filing cycle',
  'Clean agent suppression systems in server rooms not on annual inspection schedules — FM-200, Novec 1230, and CO2 systems require annual LAFD inspection and TCE filing separate from the building fire alarm test',
  'Corporate cafeteria kitchen suppression compliance gaps — high-volume cooking operations at tech campuses require semi-annual NFPA 96 inspections that are frequently not calendared by facility teams',
  'Multi-building campus compliance fragmentation — each building on a Playa Vista campus is a separate Reg 4 entity requiring independent inspection scheduling and individual TCE filings',
  'Emergency generator testing deferral in newer mid-rise residential buildings — NFPA 110 annual load-bank testing required for generators serving life safety loads frequently missed in recently occupied construction',
  'Standpipe hose valve testing not initiated on newer mid-rise construction — property managers unaware that the 5-year standpipe test cycle begins at occupancy, not at some future date',
];
const faqs = [
  { q: 'Our tech campus just opened two years ago. Do we already need Reg 4 inspections?', a: 'Yes — from day one. Regulation 4 obligations begin at occupancy, not after a grace period. Your fire alarm system required its first annual inspection within one year of certificate of occupancy. Corporate cafeteria kitchen suppression systems required their first semi-annual inspection within six months. Check with your facility manager to confirm your TCE filing history and current compliance status.' },
  { q: 'We have a server room with a clean agent suppression system (FM-200). Does Reg 4 require annual inspection?', a: 'Yes. Clean agent suppression systems — FM-200, Novec 1230, CO2, and others — require annual inspection by an LAFD-certified tester in the appropriate category. Results must be filed through thecomplianceengine.com within 7 days. This is separate from the building-wide fire alarm test. Many Playa Vista facility managers are unaware of this requirement until an LAFD compliance sweep flags the gap.' },
  { q: 'We operate multiple buildings on our Playa Vista campus. Can we do one filing for all of them?', a: 'No. Each building is a separate structure with a separate address and a separate Regulation 4 compliance obligation. You need individual inspections and individual TCE filings for each building. Engage a fire protection contractor experienced with multi-building campus compliance to coordinate scheduling across all structures simultaneously — staggered inspections create compliance windows that leave some buildings out of compliance.' },
  { q: 'Our corporate cafeteria serves hundreds of employees daily. What kitchen suppression compliance does Reg 4 require?', a: "High-volume commercial cooking operations trigger NFPA 96 requirements regardless of whether the cafeteria is open to the public. Your hood suppression system requires semi-annual inspection by an LAFD-certified NFPA 96 tester, filed through thecomplianceengine.com within 7 days. Hood cleaning frequency — quarterly or semi-annually depending on cooking volume — must also be documented. Corporate cafeterias are among the most cited Reg 4 gaps at Playa Vista tech campuses." },
];
---
<Base title="LAFD Regulation 4 Compliance — Playa Vista | Fire Safety Supply House" description="LAFD Regulation 4 fire system compliance for Playa Vista buildings. Silicon Beach tech campuses, corporate offices, server rooms, cafeterias, and mid-rise residential — fire alarm and suppression testing, equipment supply, and LAFD-certified tester referrals." canonical={`https://firesafetysupplyhouse.com/lafd-regulation-4/${SLUG}/`} schema={schema}>
<style>
  .hood-hero { background: #1a2744; }
  .alert-strip { background: #fdf2f0; border-top: 3px solid #c0392b; border-bottom: 1px solid #fbd5d0; }
  .sform { background: #1a2744; border-radius: 12px; overflow: hidden; }
  .fi { width:100%; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.15); border-radius:6px; padding:10px 12px; font-size:13.5px; color:#fff; font-family:inherit; outline:none; margin-bottom:10px; }
  .fi::placeholder { color:rgba(255,255,255,0.3); }
  .qfr { display:flex; justify-content:space-between; padding:9px 0; border-bottom:1px solid #f0f0f0; font-size:13px; }
  .qfr:last-child { border-bottom:none; }
  .npill { display:inline-block; background:#1a2744; color:#fff; font-size:10.5px; font-weight:600; padding:2px 7px; border-radius:3px; margin:2px 2px 0 0; }
</style>
  <div class="bg-gray-50 border-b border-gray-200"><div class="section py-2.5"><nav class="flex items-center gap-1.5 text-xs text-gray-400"><a href="/" class="hover:text-gray-700 no-underline">Home</a><span>/</span><a href="/lafd-regulation-4/" class="hover:text-gray-700 no-underline">LAFD Regulation 4</a><span>/</span><span class="text-gray-700 font-medium">{NEIGHBORHOOD}</span></nav></div></div>
  <div class="hood-hero py-14"><div class="section"><div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-center"><div class="lg:col-span-2">
    <div class="inline-flex items-center gap-2 bg-red-brand/20 border border-red-brand/40 text-red-300 text-xs font-bold tracking-widest uppercase px-3 py-1.5 rounded mb-5"><span class="w-1.5 h-1.5 rounded-full bg-red-brand inline-block"></span>{NEIGHBORHOOD} — Los Angeles City Limits — LAFD Jurisdiction</div>
    <h1 class="text-4xl lg:text-5xl font-bold text-white tracking-tight leading-tight mb-4">LAFD Regulation 4 Compliance in {NEIGHBORHOOD}</h1>
    <p class="text-lg text-blue-200 max-w-2xl leading-relaxed mb-6">Playa Vista — Silicon Beach's master-planned tech campus — contains the newest commercial building stock subject to LAFD Regulation 4 in western Los Angeles. New construction doesn't mean automatic compliance. Annual fire alarm testing, semi-annual cafeteria kitchen suppression, clean agent server room inspection, and 5-year sprinkler testing all apply from occupancy day one regardless of building age.</p>
    <div class="flex flex-wrap gap-2"><span class="bg-white/10 border border-white/15 text-blue-100 text-xs font-medium px-3 py-1.5 rounded">Tech Campus Compliance</span><span class="bg-white/10 border border-white/15 text-blue-100 text-xs font-medium px-3 py-1.5 rounded">Clean Agent Server Room Testing</span><span class="bg-white/10 border border-white/15 text-blue-100 text-xs font-medium px-3 py-1.5 rounded">7-Day Compliance Engine Filing</span><span class="bg-white/10 border border-white/15 text-blue-100 text-xs font-medium px-3 py-1.5 rounded">48hr Equipment Fulfillment</span></div>
  </div><div class="flex flex-col gap-2">
    <div class="bg-white/10 border border-white/10 rounded-xl p-4 text-center"><div class="text-3xl font-bold text-white mb-1">Day 1</div><div class="text-xs text-blue-300">Regulation 4 obligations begin at occupancy — new construction is not exempt from annual fire system testing</div></div>
    <div class="bg-white/10 border border-white/10 rounded-xl p-4 text-center"><div class="text-3xl font-bold text-white mb-1">Per building</div><div class="text-xs text-blue-300">Each campus building requires a separate TCE filing — multi-building campuses must track compliance independently</div></div>
    <div class="bg-white/10 border border-white/10 rounded-xl p-4 text-center"><div class="text-3xl font-bold text-white mb-1">30</div><div class="text-xs text-blue-300">Days to correct deficiencies and retest after inspection</div></div>
  </div></div></div></div>
  <div class="alert-strip px-6 py-4"><div class="section flex items-start gap-3"><span class="text-red-brand text-lg mt-0.5 flex-shrink-0">⚠</span><p class="text-sm text-red-900 leading-relaxed"><strong class="text-red-brand">Playa Vista Compliance Notice:</strong> Playa Vista is within Los Angeles City limits under LAFD jurisdiction. <strong>New buildings are not automatically exempt from Regulation 4 obligations</strong> — annual fire alarm testing, semi-annual cafeteria kitchen suppression, clean agent system inspection, and 5-year sprinkler testing apply from day one. Tech campus operators must file per-building results within <strong>7 days</strong> via thecomplianceengine.com.</p></div></div>
  <div class="section py-14"><div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start"><div class="lg:col-span-2 space-y-14">
    <div><div class="tag text-red-brand mb-2">Context</div><h2 class="text-3xl font-bold tracking-tight mb-4">Regulation 4 in {NEIGHBORHOOD}</h2>
    <p class="text-gray-600 leading-relaxed mb-4">Playa Vista's master-planned Silicon Beach campus is the most modern commercial district subject to LAFD Regulation 4 in western Los Angeles. Large tech company offices, creative agency campuses, mid-rise residential buildings, and ground-floor retail along Lincoln and Jefferson all fall within Los Angeles City limits and carry full Regulation 4 obligations from the day they open.</p>
    <p class="text-gray-600 leading-relaxed mb-6">The primary compliance risk here is not aging systems — it's complacency about new construction. Facility managers at Playa Vista tech campuses often assume that because the building is new, it is compliant. It is compliant at time of issuance. But Regulation 4 is an ongoing annual obligation that requires active management: scheduling testers, tracking TCE filings, and maintaining separate compliance calendars for each building and each system category on site.</p>
    <div class="grid grid-cols-2 gap-3">
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-4"><div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">AHJ</div><div class="text-sm font-semibold text-gray-800">Los Angeles Fire Department</div><div class="text-xs text-gray-500 mt-0.5">All of Playa Vista is LAFD jurisdiction</div></div>
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-4"><div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">Key Risk</div><div class="text-sm font-semibold text-gray-800">New Build Complacency</div><div class="text-xs text-gray-500 mt-0.5">Recent construction is not self-compliant</div></div>
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-4"><div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">Filing Platform</div><div class="text-sm font-semibold text-gray-800">thecomplianceengine.com</div><div class="text-xs text-gray-500 mt-0.5">7-day electronic submission per building</div></div>
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-4"><div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">Equipment Lead Time</div><div class="text-sm font-semibold text-red-brand">48 Hours</div><div class="text-xs text-gray-500 mt-0.5">FSSH fulfillment for Playa Vista addresses</div></div>
    </div></div>
    <div><div class="tag text-red-brand mb-2">By Building Type</div><h2 class="text-3xl font-bold tracking-tight mb-4">{NEIGHBORHOOD} Building Types &amp; Requirements</h2>
    <div class="overflow-x-auto rounded-xl border border-gray-200"><table class="w-full text-sm border-collapse"><thead><tr class="bg-[#1a2744] text-white"><th class="text-left px-4 py-3 text-xs font-semibold tracking-wider">Building Type</th><th class="text-left px-4 py-3 text-xs font-semibold tracking-wider hidden md:table-cell">NFPA Standards</th><th class="text-left px-4 py-3 text-xs font-semibold tracking-wider">Frequency</th></tr></thead><tbody>
      {buildingTypes.map((bt, i) => (<tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}><td class="px-4 py-3 border-b border-gray-100 font-semibold text-[#1a2744] align-top text-sm">{bt.type}</td><td class="px-4 py-3 border-b border-gray-100 align-top hidden md:table-cell">{bt.nfpa.map(n => <span class="npill">{n}</span>)}</td><td class="px-4 py-3 border-b border-gray-100 text-xs text-gray-600 align-top leading-relaxed">{bt.freq}</td></tr>))}
    </tbody></table></div></div>
    <div><div class="tag text-red-brand mb-2">What Gets Flagged</div><h2 class="text-3xl font-bold tracking-tight mb-4">Most Common Reg 4 Deficiencies in {NEIGHBORHOOD}</h2>
    <div class="flex flex-col gap-3">{deficiencies.map(d => (<div class="flex items-start gap-3 bg-red-light border border-red-200 border-l-4 border-l-red-brand rounded-r-lg px-4 py-3 text-sm text-red-900"><span class="text-red-brand flex-shrink-0 mt-0.5">⚠</span>{d}</div>))}</div></div>
    <div><div class="tag text-red-brand mb-2">FAQ</div><h2 class="text-3xl font-bold tracking-tight mb-6">{NEIGHBORHOOD} — Regulation 4 FAQs</h2>
    <div class="divide-y divide-gray-100">{faqs.map(faq => (<details class="group py-4"><summary class="flex items-center justify-between gap-4 cursor-pointer list-none"><span class="text-sm font-semibold text-gray-800 group-open:text-red-brand transition-colors">{faq.q}</span><span class="w-6 h-6 flex-shrink-0 bg-gray-100 group-open:bg-red-brand rounded-full flex items-center justify-center text-gray-600 group-open:text-white text-base leading-none transition-all">+</span></summary><p class="text-sm text-gray-600 leading-relaxed mt-3 pb-1">{faq.a}</p></details>))}</div></div>
    <div><div class="tag text-red-brand mb-2">Other Neighborhoods</div><h2 class="text-3xl font-bold tracking-tight mb-4">Other Los Angeles City Neighborhoods</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">{nearbyHoods.map(hood => (<a href={`/lafd-regulation-4/${hood.slug}/`} class="flex items-center justify-between border border-gray-200 rounded-xl p-4 hover:border-[#1a2744] hover:bg-gray-50 no-underline transition-all"><div><div class="text-sm font-semibold text-[#1a2744]">{hood.name}</div><div class="text-xs text-gray-400 mt-0.5">{hood.type}</div></div><span class="text-gray-300 ml-3">→</span></a>))}<a href="/lafd-regulation-4/" class="flex items-center border border-gray-200 rounded-xl p-4 hover:border-red-brand hover:bg-red-light no-underline transition-all"><span class="text-sm font-semibold text-red-brand">View All LA City Neighborhoods</span></a></div></div>
  </div>
  <div class="space-y-5 lg:sticky lg:top-20">
    <div class="sform"><div class="bg-white/10 border-b border-white/10 px-5 py-3.5"><span class="text-xs font-bold uppercase tracking-wider text-blue-300">Free {NEIGHBORHOOD} Compliance Assessment</span></div>
    <div class="p-5"><p class="text-xs text-blue-200 mb-4 leading-relaxed">Building in {NEIGHBORHOOD}? We'll review your Reg 4 status and connect you with an LAFD-certified tester.</p>
      <input id="pv-name" type="text" class="fi" placeholder="Your name" />
      <input id="pv-address" type="text" class="fi" placeholder="Building address" />
      <select id="pv-type" class="fi"><option value="">Building type...</option><option>Tech Campus / Creative Office</option><option>Mixed-Use / Ground-Floor Retail</option><option>Mid-Rise Residential</option><option>Restaurant / Cafe</option><option>Fitness / Wellness Center</option><option>Data Center / Server Room</option></select>
      <input id="pv-floors" type="text" class="fi" placeholder="Number of floors" />
      <select id="pv-inspection" class="fi"><option value="">Last inspection...</option><option>Within the last year</option><option>1-2 years ago</option><option>2+ years ago</option><option>Never / Unknown</option></select>
      <input id="pv-email" type="email" class="fi" placeholder="Email address" />
      <input id="pv-phone" type="tel" class="fi" placeholder="Phone number" />
      <button id="pv-submit" class="w-full bg-red-brand text-white py-3.5 rounded-lg text-sm font-bold hover:bg-red-dark transition-colors cursor-pointer border-0">Get Free Assessment</button>
      <div id="pv-success" style="display:none" class="text-center text-green-300 text-sm font-medium mt-3">✓ Received — we'll be in touch within one business day.</div>
      <p class="text-xs text-center mt-3" style="color:rgba(147,197,253,0.4)">Response within one business day.</p>
    </div></div>
    <div class="border border-gray-200 rounded-xl overflow-hidden"><div class="bg-gray-50 border-b border-gray-200 px-4 py-3"><span class="text-xs font-bold uppercase tracking-wider text-gray-400">{NEIGHBORHOOD} Quick Facts</span></div>
    <div class="p-4"><div class="qfr"><span class="text-gray-400 font-medium">Jurisdiction</span><span class="text-gray-800 font-semibold">LA City (LAFD)</span></div><div class="qfr"><span class="text-gray-400 font-medium">Fire Alarms</span><span class="text-gray-800 font-semibold">Annual</span></div><div class="qfr"><span class="text-gray-400 font-medium">Kitchen / Cafeteria</span><span class="font-bold text-red-brand">Semi-Annual</span></div><div class="qfr"><span class="text-gray-400 font-medium">Clean Agent Systems</span><span class="font-bold text-red-brand">Annual</span></div><div class="qfr"><span class="text-gray-400 font-medium">Sprinklers / Standpipe</span><span class="font-bold text-red-brand">5 Years</span></div><div class="qfr"><span class="text-gray-400 font-medium">Repair/Retest</span><span class="font-bold text-red-brand">30 days</span></div><div class="qfr"><span class="text-gray-400 font-medium">Filing Deadline</span><span class="text-gray-800 font-semibold">7 days (per building)</span></div><div class="qfr"><span class="text-gray-400 font-medium">Equipment Lead Time</span><span class="text-gray-800 font-semibold">48 hours</span></div></div></div>
    <div class="border border-gray-200 rounded-xl overflow-hidden"><div class="bg-gray-50 border-b border-gray-200 px-4 py-3"><span class="text-xs font-bold uppercase tracking-wider text-gray-400">LAFD Reg 4 Unit</span></div>
    <div class="p-4 space-y-2"><p class="text-xs text-gray-600 leading-relaxed">Bureau of Fire Prevention and Public Safety<br/>200 North Main Street, Room 1750<br/>Los Angeles, CA 90012</p><a href="tel:+12139783560" class="block text-sm font-bold text-red-brand no-underline">(213) 978-3560</a><a href="mailto:LafdReg4@lacity.org" class="block text-xs text-red-brand no-underline">LafdReg4@lacity.org</a></div></div>
    <div class="border border-gray-200 rounded-xl overflow-hidden"><div class="bg-gray-50 border-b border-gray-200 px-4 py-3"><span class="text-xs font-bold uppercase tracking-wider text-gray-400">NFPA Standards</span></div><div class="p-4 flex flex-wrap gap-1.5">{['NFPA 10','NFPA 14','NFPA 25','NFPA 72','NFPA 96','NFPA 101','NFPA 110','NFPA 2001','Title 19 CCR'].map(tag => (<span class="npill">{tag}</span>))}</div></div>
  </div></div></div>
  <script define:vars={{ N8N_WEBHOOK, NEIGHBORHOOD }}>
    document.getElementById('pv-submit').addEventListener('click', async function() {
      const btn = this; btn.textContent = 'Submitting...'; btn.disabled = true;
      const payload = { neighborhood: NEIGHBORHOOD, name: document.getElementById('pv-name').value, address: document.getElementById('pv-address').value, buildingType: document.getElementById('pv-type').value, floors: document.getElementById('pv-floors').value, lastInspection: document.getElementById('pv-inspection').value, email: document.getElementById('pv-email').value, phone: document.getElementById('pv-phone').value, source: 'FSSH Reg 4 — Playa Vista' };
      try { await fetch(N8N_WEBHOOK, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) }); } catch(e) {}
      document.getElementById('pv-success').style.display = 'block'; btn.style.display = 'none';
    });
  </script>
</Base>

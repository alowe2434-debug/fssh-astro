---
import Base from '../../../layouts/Base.astro';
const N8N_WEBHOOK = 'https://shiro770.app.n8n.cloud/webhook/fssh-reg4-lead';
const NEIGHBORHOOD = 'Mid-Wilshire / Miracle Mile';
const SLUG = 'mid-wilshire';
const schema = {{"@context":"https://schema.org","@graph":[{{"@type":"WebPage","@id":`https://firesafetysupplyhouse.com/lafd-regulation-4/${{SLUG}}/`,"url":`https://firesafetysupplyhouse.com/lafd-regulation-4/${{SLUG}}/`,"name":`LAFD Regulation 4 Compliance — ${{NEIGHBORHOOD}}`,"breadcrumb":{{"@type":"BreadcrumbList","itemListElement":[{{"@type":"ListItem","position":1,"name":"Home","item":"https://firesafetysupplyhouse.com/"}},{{"@type":"ListItem","position":2,"name":"LAFD Regulation 4","item":"https://firesafetysupplyhouse.com/lafd-regulation-4/"}},{{"@type":"ListItem","position":3,"name":NEIGHBORHOOD,"item":`https://firesafetysupplyhouse.com/lafd-regulation-4/${{SLUG}}/`}}]}}}}]}};
const buildingTypes = [{ type: "Art Deco Office Building (1920s\u20131950s)", systems: "Fire alarm retrofit, sprinkler retrofit, extinguishers", nfpa: ["NFPA 72", "NFPA 25", "NFPA 10"], freq: "Alarm: Annual \u00b7 Sprinkler: 5 Years" },{ type: "Medical / Healthcare Facility", systems: "Fire alarm, sprinkler, medical gas, emergency power", nfpa: ["NFPA 72", "NFPA 25", "NFPA 99", "NFPA 110"], freq: "Alarm: Annual \u00b7 Sprinkler: 5 Years \u00b7 Generator: Annual" },{ type: "Museum / Cultural Institution", systems: "Fire alarm, sprinkler, special hazard (clean agent)", nfpa: ["NFPA 72", "NFPA 25", "NFPA 2001"], freq: "Alarm: Annual \u00b7 Sprinkler: 5 Years" },{ type: "Retail / Restaurant (Wilshire)", systems: "Fire alarm, kitchen suppression, extinguishers", nfpa: ["NFPA 72", "NFPA 96", "NFPA 10"], freq: "Alarm: Annual \u00b7 Kitchen: Semi-annual" },{ type: "Mid-Century Office / Mixed-Use", systems: "Fire alarm, sprinkler systems", nfpa: ["NFPA 72", "NFPA 25"], freq: "Alarm: Annual \u00b7 Sprinkler: 5 Years" },{ type: "Residential High-Rise (Park Mile)", systems: "Fire alarm, sprinkler, standpipe", nfpa: ["NFPA 72", "NFPA 25", "NFPA 14"], freq: "Alarm: Annual \u00b7 Sprinkler/Standpipe: 5 Years" }];
const nearbyHoods = [{ slug: "downtown-los-angeles", name: "Downtown Los Angeles", type: "High-rise \u00b7 Hotel \u00b7 Office" },{ slug: "koreatown", name: "Koreatown", type: "Dense commercial \u00b7 Restaurants" },{ slug: "hollywood", name: "Hollywood", type: "Entertainment \u00b7 Commercial" },{ slug: "westwood", name: "Westwood", type: "Medical \u00b7 University" }];
const deficiencies = ["Outdated fire alarm panels in 1930s\u20131950s Wilshire Boulevard office buildings \u2014 original wiring and panel infrastructure incompatible with modern addressable system requirements", "Unsprinklered floors in pre-1940 commercial buildings \u2014 California's sprinkler retrofit mandates have increased LAFD scrutiny of multi-story commercial properties without full coverage", "Missing kitchen suppression records in Miracle Mile restaurant spaces \u2014 rapid turnover of F&B tenants in ground-floor commercial units leaves suppression service history incomplete", "Emergency egress lighting failures in basement and sub-grade retail spaces \u2014 NFPA 101 violations frequently cited in older Wilshire Blvd commercial buildings", "HVAC and smoke damper testing gaps in mid-century office buildings \u2014 annual smoke damper testing required under Reg 4 is frequently not scheduled alongside the fire alarm test", "Medical gas system compliance gaps in Wilshire Medical Corridor facilities \u2014 NFPA 99 obligations often fall outside the scope of standard fire alarm testers"];
const faqs = [{ q: "Our building was constructed in 1938. Are we exempt from modern Regulation 4 requirements?", a: "No. LAFD Regulation 4 applies to commercial buildings based on their current occupancy and use, not their construction date. There is no blanket grandfathering for pre-war buildings. You are required to maintain fire protection systems appropriate to your current building use and occupancy under NFPA standards and Reg 4 \u2014 regardless of the original construction year." },{ q: "Do smoke dampers need to be tested annually in our Mid-Wilshire office?", a: "Yes. Smoke dampers and fire dampers in HVAC systems of commercial buildings are subject to annual testing under NFPA 90A and Reg 4. This test must be performed by an LAFD-certified tester in the appropriate category and filed through thecomplianceengine.com within 7 days. This is separate from the fire alarm test and is frequently missed in older Wilshire Blvd buildings." },{ q: "We're adjacent to LACMA. Does our building face additional compliance obligations?", a: "Proximity to LACMA does not create additional Reg 4 obligations for neighboring buildings. However, properties that share infrastructure (shared egress, connected HVAC, adjacent loading docks) with museum campuses should confirm fire system independence with a licensed fire protection engineer. LACMA itself has its own extensive Reg 4 compliance program managed separately." },{ q: "Our medical office building has emergency backup power. What does Reg 4 require?", a: "Emergency generators serving life safety loads in healthcare facilities require annual load-bank testing under NFPA 110 and NFPA 99. This test must be documented and filed through thecomplianceengine.com. Medical facilities with backup power often have both fire alarm and generator compliance obligations tracked under separate Reg 4 tester categories." }];
---
<Base title="LAFD Regulation 4 Compliance — Mid-Wilshire / Miracle Mile | Fire Safety Supply House" description="LAFD Regulation 4 fire system compliance for Mid-Wilshire and Miracle Mile buildings. 1920s–1950s art deco offices, museums, medical buildings, and retail along Wilshire Boulevard — fire alarm and suppression testing, equipment supply, and LAFD-certified tester referrals." canonical={{`https://firesafetysupplyhouse.com/lafd-regulation-4/${{SLUG}}/`}} schema={{schema}}>
<style>
  .hood-hero {{ background: #1a2744; }}
  .alert-strip {{ background: #fdf2f0; border-top: 3px solid #c0392b; border-bottom: 1px solid #fbd5d0; }}
  .sform {{ background: #1a2744; border-radius: 12px; overflow: hidden; }}
  .fi {{ width:100%; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.15); border-radius:6px; padding:10px 12px; font-size:13.5px; color:#fff; font-family:inherit; outline:none; margin-bottom:10px; }}
  .fi::placeholder {{ color:rgba(255,255,255,0.3); }}
  .qfr {{ display:flex; justify-content:space-between; padding:9px 0; border-bottom:1px solid #f0f0f0; font-size:13px; }}
  .qfr:last-child {{ border-bottom:none; }}
  .npill {{ display:inline-block; background:#1a2744; color:#fff; font-size:10.5px; font-weight:600; padding:2px 7px; border-radius:3px; margin:2px 2px 0 0; }}
</style>
  <div class="bg-gray-50 border-b border-gray-200"><div class="section py-2.5"><nav class="flex items-center gap-1.5 text-xs text-gray-400"><a href="/" class="hover:text-gray-700 no-underline">Home</a><span>/</span><a href="/lafd-regulation-4/" class="hover:text-gray-700 no-underline">LAFD Regulation 4</a><span>/</span><span class="text-gray-700 font-medium">{{NEIGHBORHOOD}}</span></nav></div></div>
  <div class="hood-hero py-14"><div class="section"><div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-center"><div class="lg:col-span-2">
    <div class="inline-flex items-center gap-2 bg-red-brand/20 border border-red-brand/40 text-red-300 text-xs font-bold tracking-widest uppercase px-3 py-1.5 rounded mb-5"><span class="w-1.5 h-1.5 rounded-full bg-red-brand inline-block"></span>{{NEIGHBORHOOD}} — Los Angeles City Limits — LAFD Jurisdiction</div>
    <h1 class="text-4xl lg:text-5xl font-bold text-white tracking-tight leading-tight mb-4">LAFD Regulation 4 Compliance in {{NEIGHBORHOOD}}</h1>
    <p class="text-lg text-blue-200 max-w-2xl leading-relaxed mb-6">Mid-Wilshire's Wilshire Boulevard corridor — anchored by the Miracle Mile cultural district and stretching through Park Mile and the Medical Corridor — contains some of Los Angeles's oldest commercial building stock still subject to full Regulation 4 obligations. Art deco office ...</p>
    <div class="flex flex-wrap gap-2"><span class="bg-white/10 border border-white/15 text-blue-100 text-xs font-medium px-3 py-1.5 rounded">LAFD-Certified Testers</span><span class="bg-white/10 border border-white/15 text-blue-100 text-xs font-medium px-3 py-1.5 rounded">Semi-Annual Kitchen Compliance</span><span class="bg-white/10 border border-white/15 text-blue-100 text-xs font-medium px-3 py-1.5 rounded">7-Day Compliance Engine Filing</span><span class="bg-white/10 border border-white/15 text-blue-100 text-xs font-medium px-3 py-1.5 rounded">48hr Equipment Fulfillment</span></div>
  </div><div class="flex flex-col gap-2"><div class="bg-white/10 border border-white/10 rounded-xl p-4 text-center"><div class="text-3xl font-bold text-white mb-1">200+</div><div class="text-xs text-blue-300">Commercial buildings along Wilshire Blvd between La Brea and Fairfax subject to Reg 4</div></div>
<div class="bg-white/10 border border-white/10 rounded-xl p-4 text-center"><div class="text-3xl font-bold text-white mb-1">1920s</div><div class="text-xs text-blue-300">Oldest building stock in active commercial use — original fire systems require aggressive maintenance</div></div>
<div class="bg-white/10 border border-white/10 rounded-xl p-4 text-center"><div class="text-3xl font-bold text-white mb-1">30</div><div class="text-xs text-blue-300">Days to correct deficiencies and retest after inspection</div></div></div></div></div></div>
  <div class="alert-strip px-6 py-4"><div class="section flex items-start gap-3"><span class="text-red-brand text-lg mt-0.5 flex-shrink-0">⚠</span><p class="text-sm text-red-900 leading-relaxed"><strong class="text-red-brand">Mid-Wilshire / Miracle Mile Compliance Notice:</strong> Mid-Wilshire falls entirely within Los Angeles City limits under LAFD jurisdiction. Pre-war commercial buildings on Wilshire Boulevard are <strong>not exempt</strong> from Regulation 4 regardless of age or original construction standards. LAFD inspectors are actively enforcing fire system compliance across the Miracle Mile and Medical Corridor. Results must be filed within <strong>7 days</strong> via thecomplianceengine.com.</p></div></div>
  <div class="section py-14"><div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start"><div class="lg:col-span-2 space-y-14">
    <div><div class="tag text-red-brand mb-2">Context</div><h2 class="text-3xl font-bold tracking-tight mb-4">Regulation 4 in {{NEIGHBORHOOD}}</h2>
    <p class="text-gray-600 leading-relaxed mb-4">Mid-Wilshire's Wilshire Boulevard corridor — anchored by the Miracle Mile cultural district and stretching through Park Mile and the Medical Corridor — contains some of Los Angeles's oldest commercial building stock still subject to full Regulation 4 obligations. Art deco office buildings from the 1920s–1940s, mid-century medical facilities, and the museum campus around LACMA all carry distinct fire protection requirements that aging infrastructure makes difficult to satisfy.</p><p class="text-gray-600 leading-relaxed mb-6">The compliance challenge in Mid-Wilshire is scope awareness. Property managers of pre-war buildings often operate on the assumption that their systems — installed decades ago — were grandfathered out of modern requirements. They are not. Reg 4 applies based on current use, not construction date. LAFD inspectors have identified Mid-Wilshire as an active enforcement zone for aging commercial properties with deferred fire system maintenance.</p>
    <div class="grid grid-cols-2 gap-3">
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-4"><div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">AHJ</div><div class="text-sm font-semibold text-gray-800">Los Angeles Fire Department</div><div class="text-xs text-gray-500 mt-0.5">All of {{NEIGHBORHOOD}} is LAFD jurisdiction</div></div>
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-4"><div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">Key Risk</div><div class="text-sm font-semibold text-gray-800">Aging Building Stock</div><div class="text-xs text-gray-500 mt-0.5">Pre-war systems often non-compliant</div></div>
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-4"><div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">Filing Platform</div><div class="text-sm font-semibold text-gray-800">thecomplianceengine.com</div><div class="text-xs text-gray-500 mt-0.5">7-day electronic submission required</div></div>
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-4"><div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">Equipment Lead Time</div><div class="text-sm font-semibold text-red-brand">48 Hours</div><div class="text-xs text-gray-500 mt-0.5">FSSH fulfillment for {{NEIGHBORHOOD}} addresses</div></div>
    </div></div>
    <div><div class="tag text-red-brand mb-2">By Building Type</div><h2 class="text-3xl font-bold tracking-tight mb-4">{{NEIGHBORHOOD}} Building Types &amp; Requirements</h2>
    <div class="overflow-x-auto rounded-xl border border-gray-200"><table class="w-full text-sm border-collapse"><thead><tr class="bg-[#1a2744] text-white"><th class="text-left px-4 py-3 text-xs font-semibold tracking-wider">Building Type</th><th class="text-left px-4 py-3 text-xs font-semibold tracking-wider hidden md:table-cell">NFPA Standards</th><th class="text-left px-4 py-3 text-xs font-semibold tracking-wider">Frequency</th></tr></thead><tbody>{{buildingTypes.map((bt, i) => (<tr class={{i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}}><td class="px-4 py-3 border-b border-gray-100 font-semibold text-[#1a2744] align-top text-sm">{{bt.type}}</td><td class="px-4 py-3 border-b border-gray-100 align-top hidden md:table-cell">{{bt.nfpa.map(n => <span class="npill">{{n}}</span>)}}</td><td class="px-4 py-3 border-b border-gray-100 text-xs text-gray-600 align-top leading-relaxed">{{bt.freq}}</td></tr>))}</tbody></table></div></div>
    <div><div class="tag text-red-brand mb-2">What Gets Flagged</div><h2 class="text-3xl font-bold tracking-tight mb-4">Most Common Reg 4 Deficiencies in {{NEIGHBORHOOD}}</h2>
    <div class="flex flex-col gap-3">{{deficiencies.map(d => (<div class="flex items-start gap-3 bg-red-light border border-red-200 border-l-4 border-l-red-brand rounded-r-lg px-4 py-3 text-sm text-red-900"><span class="text-red-brand flex-shrink-0 mt-0.5">⚠</span>{{d}}</div>))}}</div></div>
    <div><div class="tag text-red-brand mb-2">FAQ</div><h2 class="text-3xl font-bold tracking-tight mb-6">{{NEIGHBORHOOD}} — Regulation 4 FAQs</h2>
    <div class="divide-y divide-gray-100">{{faqs.map(faq => (<details class="group py-4"><summary class="flex items-center justify-between gap-4 cursor-pointer list-none"><span class="text-sm font-semibold text-gray-800 group-open:text-red-brand transition-colors">{{faq.q}}</span><span class="w-6 h-6 flex-shrink-0 bg-gray-100 group-open:bg-red-brand rounded-full flex items-center justify-center text-gray-600 group-open:text-white text-base leading-none transition-all">+</span></summary><p class="text-sm text-gray-600 leading-relaxed mt-3 pb-1">{{faq.a}}</p></details>))}}</div></div>
    <div><div class="tag text-red-brand mb-2">Other Neighborhoods</div><h2 class="text-3xl font-bold tracking-tight mb-4">Other Los Angeles City Neighborhoods</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">{{nearbyHoods.map(hood => (<a href={{`/lafd-regulation-4/${{hood.slug}}/`}} class="flex items-center justify-between border border-gray-200 rounded-xl p-4 hover:border-[#1a2744] hover:bg-gray-50 no-underline transition-all"><div><div class="text-sm font-semibold text-[#1a2744]">{{hood.name}}</div><div class="text-xs text-gray-400 mt-0.5">{{hood.type}}</div></div><span class="text-gray-300 ml-3">→</span></a>))}<a href="/lafd-regulation-4/" class="flex items-center border border-gray-200 rounded-xl p-4 hover:border-red-brand hover:bg-red-light no-underline transition-all"><span class="text-sm font-semibold text-red-brand">View All LA City Neighborhoods</span></a></div></div>
  </div>
  <div class="space-y-5 lg:sticky lg:top-20">
    <div class="sform"><div class="bg-white/10 border-b border-white/10 px-5 py-3.5"><span class="text-xs font-bold uppercase tracking-wider text-blue-300">Free {{NEIGHBORHOOD}} Compliance Assessment</span></div>
    <div class="p-5"><p class="text-xs text-blue-200 mb-4 leading-relaxed">Building in {{NEIGHBORHOOD}}? We'll review your Reg 4 status and connect you with an LAFD-certified tester.</p>
      <input id="mw-name" type="text" class="fi" placeholder="Your name" />
      <input id="mw-address" type="text" class="fi" placeholder="Building address" />
      <select id="mw-type" class="fi"><option value="">Building type...</option><option>Art Deco Office Building</option>
<option>Medical / Healthcare Facility</option>
<option>Museum / Cultural Institution</option>
<option>Retail / Restaurant</option>
<option>Mid-Century Office / Mixed-Use</option>
<option>Residential High-Rise</option></select>
      <input id="mw-floors" type="text" class="fi" placeholder="Number of floors" />
      <select id="mw-inspection" class="fi"><option value="">Last inspection...</option><option>Within the last year</option><option>1-2 years ago</option><option>2+ years ago</option><option>Never / Unknown</option></select>
      <input id="mw-email" type="email" class="fi" placeholder="Email address" />
      <input id="mw-phone" type="tel" class="fi" placeholder="Phone number" />
      <button id="mw-submit" class="w-full bg-red-brand text-white py-3.5 rounded-lg text-sm font-bold hover:bg-red-dark transition-colors cursor-pointer border-0">Get Free Assessment</button>
      <div id="mw-success" style="display:none" class="text-center text-green-300 text-sm font-medium mt-3">✓ Received — we'll be in touch within one business day.</div>
      <p class="text-xs text-center mt-3" style="color:rgba(147,197,253,0.4)">Response within one business day.</p>
    </div></div>
    <div class="border border-gray-200 rounded-xl overflow-hidden"><div class="bg-gray-50 border-b border-gray-200 px-4 py-3"><span class="text-xs font-bold uppercase tracking-wider text-gray-400">{{NEIGHBORHOOD}} Quick Facts</span></div>
    <div class="p-4"><div class="qfr"><span class="text-gray-400 font-medium">Jurisdiction</span><span class="text-gray-800 font-semibold">LA City (LAFD)</span></div><div class="qfr"><span class="text-gray-400 font-medium">Fire Alarms</span><span class=" font-bold text-red-brand">Annual</span></div>
<div class="qfr"><span class="text-gray-400 font-medium">Smoke Dampers</span><span class=" font-bold text-red-brand">Annual</span></div>
<div class="qfr"><span class="text-gray-400 font-medium">Sprinklers / Standpipe</span><span class=" font-bold text-red-brand">5 Years</span></div>
<div class="qfr"><span class="text-gray-400 font-medium">Kitchen Suppression</span><span class=" font-bold text-red-brand">Semi-Annual</span></div>
<div class="qfr"><span class="text-gray-400 font-medium">Repair/Retest</span><span class=" font-bold text-red-brand">30 days</span></div>
<div class="qfr"><span class="text-gray-400 font-medium">Filing Deadline</span><span class=" text-gray-800 font-semibold">7 days</span></div><div class="qfr"><span class="text-gray-400 font-medium">Equipment Lead Time</span><span class="text-gray-800 font-semibold">48 hours</span></div></div></div>
    <div class="border border-gray-200 rounded-xl overflow-hidden"><div class="bg-gray-50 border-b border-gray-200 px-4 py-3"><span class="text-xs font-bold uppercase tracking-wider text-gray-400">LAFD Reg 4 Unit</span></div>
    <div class="p-4 space-y-2"><p class="text-xs text-gray-600 leading-relaxed">Bureau of Fire Prevention and Public Safety<br/>200 North Main Street, Room 1750<br/>Los Angeles, CA 90012</p><a href="tel:+12139783560" class="block text-sm font-bold text-red-brand no-underline">(213) 978-3560</a><a href="mailto:LafdReg4@lacity.org" class="block text-xs text-red-brand no-underline">LafdReg4@lacity.org</a></div></div>
    <div class="border border-gray-200 rounded-xl overflow-hidden"><div class="bg-gray-50 border-b border-gray-200 px-4 py-3"><span class="text-xs font-bold uppercase tracking-wider text-gray-400">NFPA Standards</span></div><div class="p-4 flex flex-wrap gap-1.5"><span class="npill">NFPA 10</span>
<span class="npill">NFPA 14</span>
<span class="npill">NFPA 25</span>
<span class="npill">NFPA 72</span>
<span class="npill">NFPA 90A</span>
<span class="npill">NFPA 96</span>
<span class="npill">NFPA 99</span>
<span class="npill">NFPA 101</span>
<span class="npill">NFPA 110</span>
<span class="npill">NFPA 2001</span>
<span class="npill">Title 19 CCR</span></div></div>
  </div></div></div>
  <script define:vars={{{{ N8N_WEBHOOK, NEIGHBORHOOD }}}}>
    document.getElementById('mw-submit').addEventListener('click', async function() {{
      const btn = this; btn.textContent = 'Submitting...'; btn.disabled = true;
      const payload = {{ neighborhood: NEIGHBORHOOD, name: document.getElementById('mw-name').value, address: document.getElementById('mw-address').value, buildingType: document.getElementById('mw-type').value, floors: document.getElementById('mw-floors').value, lastInspection: document.getElementById('mw-inspection').value, email: document.getElementById('mw-email').value, phone: document.getElementById('mw-phone').value, source: 'FSSH Reg 4 — ' + NEIGHBORHOOD }};
      try {{ await fetch(N8N_WEBHOOK, {{ method: 'POST', headers: {{ 'Content-Type': 'application/json' }}, body: JSON.stringify(payload) }}); }} catch(e) {{}}
      document.getElementById('mw-success').style.display = 'block'; btn.style.display = 'none';
    }});
  </script>
</Base>

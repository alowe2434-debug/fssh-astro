---
import Base from '../../../layouts/Base.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": "https://firesafetysupplyhouse.com/lafd-regulation-4/downtown-los-angeles/",
      "url": "https://firesafetysupplyhouse.com/lafd-regulation-4/downtown-los-angeles/",
      "name": "LAFD Regulation 4 Compliance — Downtown Los Angeles",
      "breadcrumb": {
        "@type": "BreadcrumbList",
        "itemListElement": [
          {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://firesafetysupplyhouse.com/"},
          {"@type": "ListItem", "position": 2, "name": "LAFD Regulation 4", "item": "https://firesafetysupplyhouse.com/lafd-regulation-4/"},
          {"@type": "ListItem", "position": 3, "name": "Downtown Los Angeles", "item": "https://firesafetysupplyhouse.com/lafd-regulation-4/downtown-los-angeles/"}
        ]
      }
    }
  ]
};

const buildingTypes = [
  { type: 'High-Rise (75ft+)', systems: 'Fire alarm, sprinkler, standpipe, emergency egress', nfpa: ['NFPA 72','NFPA 25','NFPA 14','NFPA 101'], freq: 'Alarm: Annual · Sprinkler/Standpipe: 5 Years' },
  { type: 'Hotel / Hospitality', systems: 'Fire alarm, sprinkler, kitchen suppression', nfpa: ['NFPA 72','NFPA 25','NFPA 96'], freq: 'Alarm: Annual · Sprinkler: 5 Years · Kitchen: Semi-annual' },
  { type: 'Commercial Office', systems: 'Fire alarm, sprinkler systems', nfpa: ['NFPA 72','NFPA 25'], freq: 'Alarm: Annual · Sprinkler: 5 Years' },
  { type: 'Restaurant / Food Hall', systems: 'Kitchen suppression, fire alarm, extinguishers', nfpa: ['NFPA 96','NFPA 10','NFPA 72'], freq: 'Suppression: Semi-annual · Alarm: Annual' },
  { type: 'Mixed-Use / Residential Commercial', systems: 'Fire alarm, sprinkler, standpipe', nfpa: ['NFPA 72','NFPA 25','NFPA 14'], freq: 'Alarm: Annual · Sprinkler/Standpipe: 5 Years' },
  { type: 'Warehouse / Converted Industrial', systems: 'Sprinkler, fire alarm, extinguishers', nfpa: ['NFPA 25','NFPA 72','NFPA 10'], freq: 'Alarm: Annual · Sprinkler: 5 Years' },
];

const nearbyHoods = [
  { slug: 'arts-district', name: 'Arts District', type: 'Warehouse · Converted commercial' },
  { slug: 'chinatown', name: 'Chinatown / Little Tokyo', type: 'Commercial · Restaurants' },
  { slug: 'koreatown', name: 'Koreatown', type: 'Dense commercial · Restaurants' },
  { slug: 'hollywood', name: 'Hollywood', type: 'Commercial · Entertainment' },
  { slug: 'mid-wilshire', name: 'Mid-Wilshire', type: 'Office · Retail' },
];

const deficiencies = [
  'Fire alarm control panels past service life or with obsolete firmware — common in buildings from the 1980s–2000s',
  'Smoke detectors exceeding their 10-year replacement window — present but failing at required detection thresholds',
  'Corroded or obstructed sprinkler heads — especially in basement and parking structure levels',
  'Kitchen suppression components in restaurant spaces not serviced since the previous tenant buildout',
  'Emergency egress lighting with failed or degraded battery backup systems — flagged under NFPA 101',
  'Missing or expired portable fire extinguisher annual inspection tags in common areas and mechanical rooms',
];
---

<Base
  title="LAFD Regulation 4 Compliance — Downtown Los Angeles"
  description="LAFD Regulation 4 fire system compliance for Downtown Los Angeles buildings. High-rise, hotel, and commercial office fire alarm and suppression system testi"
  canonical="https://firesafetysupplyhouse.com/lafd-regulation-4/downtown-los-angeles/"
  schema={schema}
>
<style>
  .dtla-hero { background: #1a2744; }
  .alert-strip { background: #fdf2f0; border-top: 3px solid #c0392b; border-bottom: 1px solid #fbd5d0; }
  .sform { background: #1a2744; border-radius: 12px; overflow: hidden; }
  .fi { width:100%; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.15); border-radius:6px; padding:10px 12px; font-size:13.5px; color:#fff; font-family:inherit; outline:none; margin-bottom:10px; }
  .fi::placeholder { color:rgba(255,255,255,0.3); }
  .qfr { display:flex; justify-content:space-between; padding:9px 0; border-bottom:1px solid #f0f0f0; font-size:13px; }
  .qfr:last-child { border-bottom:none; }
  .npill { display:inline-block; background:#1a2744; color:#fff; font-size:10.5px; font-weight:600; padding:2px 7px; border-radius:3px; margin:2px 2px 0 0; }
  .pimg { background:#fff; height:110px; display:flex; align-items:center; justify-content:center; padding:12px; border-bottom:1px solid #e2e6ec; overflow:hidden; }
  .pimg img { max-height:100%; max-width:100%; object-fit:contain; transition:transform 0.2s; }
  .pcard:hover .pimg img { transform:scale(1.04); }
</style>

  <div class="bg-gray-50 border-b border-gray-200">
    <div class="section py-2.5">
      <nav class="flex items-center gap-1.5 text-xs text-gray-400">
        <a href="/" class="hover:text-gray-700 no-underline">Home</a>
        <span>/</span>
        <a href="/lafd-regulation-4/" class="hover:text-gray-700 no-underline">LAFD Regulation 4</a>
        <span>/</span>
        <span class="text-gray-700 font-medium">Downtown Los Angeles</span>
      </nav>
    </div>
  </div>

  <div class="dtla-hero py-14">
    <div class="section">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-center">
        <div class="lg:col-span-2">
          <div class="inline-flex items-center gap-2 bg-red-brand/20 border border-red-brand/40 text-red-300 text-xs font-bold tracking-widest uppercase px-3 py-1.5 rounded mb-5">
            <span class="w-1.5 h-1.5 rounded-full bg-red-brand inline-block"></span>
            DTLA — Los Angeles City Limits — LAFD Jurisdiction
          </div>
          <h1 class="text-4xl lg:text-5xl font-bold text-white tracking-tight leading-tight mb-4">
            LAFD Regulation 4 Compliance in Downtown Los Angeles
          </h1>
          <p class="text-lg text-blue-200 max-w-2xl leading-relaxed mb-6">
            Downtown Los Angeles has the highest concentration of Regulation 4-subject buildings in the city — high-rises, hotels, commercial offices, and restaurants all requiring mandatory annual fire system testing by LAFD-certified professionals.
          </p>
          <div class="flex flex-wrap gap-2">
            <span class="bg-white/10 border border-white/15 text-blue-100 text-xs font-medium px-3 py-1.5 rounded">High-Rise Specialists</span>
            <span class="bg-white/10 border border-white/15 text-blue-100 text-xs font-medium px-3 py-1.5 rounded">Annual Fire System Testing</span>
            <span class="bg-white/10 border border-white/15 text-blue-100 text-xs font-medium px-3 py-1.5 rounded">7-Day Compliance Engine Filing</span>
            <span class="bg-white/10 border border-white/15 text-blue-100 text-xs font-medium px-3 py-1.5 rounded">48hr Equipment Fulfillment</span>
          </div>
        </div>
        <div class="flex flex-col gap-2">
          <div class="bg-white/10 border border-white/10 rounded-xl p-4 text-center">
            <div class="text-3xl font-bold text-white mb-1">500+</div>
            <div class="text-xs text-blue-300">High-rise and large commercial buildings in DTLA</div>
          </div>
          <div class="bg-white/10 border border-white/10 rounded-xl p-4 text-center">
            <div class="text-3xl font-bold text-white mb-1">30</div>
            <div class="text-xs text-blue-300">Days to correct deficiencies and retest after inspection</div>
          </div>
          <div class="bg-white/10 border border-white/10 rounded-xl p-4 text-center">
            <div class="text-3xl font-bold text-white mb-1">7</div>
            <div class="text-xs text-blue-300">Days to file results in The Compliance Engine</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="alert-strip px-6 py-4">
    <div class="section flex items-start gap-3">
      <span class="text-red-brand text-lg mt-0.5 flex-shrink-0">⚠</span>
      <p class="text-sm text-red-900 leading-relaxed">
        <strong class="text-red-brand">DTLA Compliance Notice:</strong> All of Downtown Los Angeles falls under LAFD jurisdiction and is subject to <strong>LAFD Chief's Regulation 4</strong> — separate from California Title 19. Results must be filed via thecomplianceengine.com within <strong>7 days</strong>. Defects must be corrected and retested within <strong>30 days</strong>.
      </p>
    </div>
  </div>

  <div class="section py-14">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start">
      <div class="lg:col-span-2 space-y-14">

        <div>
          <div class="tag text-red-brand mb-2">Context</div>
          <h2 class="text-3xl font-bold tracking-tight mb-4">Regulation 4 in Downtown Los Angeles</h2>
          <p class="text-gray-600 leading-relaxed mb-4">Downtown Los Angeles is entirely within LAFD jurisdiction. DTLA has the highest density of Regulation 4-subject buildings in the city: high-rises along Bunker Hill and the Financial District, hotels throughout South Park, and dense commercial buildings across the Historic Core, Arts District, and Little Tokyo.</p>
          <p class="text-gray-600 leading-relaxed mb-6">Property managers in DTLA face compounding requirements. A mixed-use high-rise with ground-floor restaurants must satisfy NFPA 25 sprinkler testing (5-year cycle) AND NFPA 96 kitchen suppression inspection (semi-annual) — each with separate certified tester categories and filing deadlines.</p>
          <div class="grid grid-cols-2 gap-3">
            <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
              <div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">AHJ</div>
              <div class="text-sm font-semibold text-gray-800">Los Angeles Fire Department</div>
              <div class="text-xs text-gray-500 mt-0.5">All of DTLA is LAFD jurisdiction</div>
            </div>
            <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
              <div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">Regulation</div>
              <div class="text-sm font-semibold text-gray-800">Reg 4 + Title 19 CCR</div>
              <div class="text-xs text-gray-500 mt-0.5">Both apply simultaneously</div>
            </div>
            <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
              <div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">Filing Platform</div>
              <div class="text-sm font-semibold text-gray-800">thecomplianceengine.com</div>
              <div class="text-xs text-gray-500 mt-0.5">7-day electronic submission required</div>
            </div>
            <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
              <div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">Equipment Lead Time</div>
              <div class="text-sm font-semibold text-red-brand">48 Hours</div>
              <div class="text-xs text-gray-500 mt-0.5">FSSH fulfillment for DTLA addresses</div>
            </div>
          </div>
        </div>

        <div>
          <div class="tag text-red-brand mb-2">By Building Type</div>
          <h2 class="text-3xl font-bold tracking-tight mb-4">DTLA Building Types &amp; Requirements</h2>
          <p class="text-gray-600 leading-relaxed mb-4">Frequencies vary significantly — not all systems test annually.</p>
          <div class="overflow-x-auto rounded-xl border border-gray-200">
            <table class="w-full text-sm border-collapse">
              <thead>
                <tr class="bg-[#1a2744] text-white">
                  <th class="text-left px-4 py-3 text-xs font-semibold tracking-wider">Building Type</th>
                  <th class="text-left px-4 py-3 text-xs font-semibold tracking-wider hidden md:table-cell">NFPA Standards</th>
                  <th class="text-left px-4 py-3 text-xs font-semibold tracking-wider">Frequency</th>
                </tr>
              </thead>
              <tbody>
                {buildingTypes.map((bt, i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}>
                    <td class="px-4 py-3 border-b border-gray-100 font-semibold text-[#1a2744] align-top text-sm">{bt.type}</td>
                    <td class="px-4 py-3 border-b border-gray-100 align-top hidden md:table-cell">
                      {bt.nfpa.map(n => <span class="npill">{n}</span>)}
                    </td>
                    <td class="px-4 py-3 border-b border-gray-100 text-xs text-gray-600 align-top leading-relaxed">{bt.freq}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <div>
          <div class="tag text-red-brand mb-2">What Gets Flagged</div>
          <h2 class="text-3xl font-bold tracking-tight mb-4">Most Common Reg 4 Deficiencies in DTLA</h2>
          <p class="text-gray-600 leading-relaxed mb-4">Based on common inspection patterns in aging Downtown LA commercial buildings.</p>
          <div class="flex flex-col gap-3">
            {deficiencies.map(d => (
              <div class="flex items-start gap-3 bg-red-light border border-red-200 border-l-4 border-l-red-brand rounded-r-lg px-4 py-3 text-sm text-red-900">
                <span class="text-red-brand flex-shrink-0 mt-0.5">⚠</span>
                {d}
              </div>
            ))}
          </div>
        </div>

        <div>
          <div class="tag text-red-brand mb-2">Equipment Supply</div>
          <h2 class="text-3xl font-bold tracking-tight mb-4">Equipment for DTLA Reg 4 Compliance</h2>
          <p class="text-gray-600 leading-relaxed mb-6">Wholesale pricing. 48-hour fulfillment for DTLA addresses. All products meet applicable NFPA standards.</p>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            {[
              { img: '/images/products/notifier-nfs2-3030.png', name: 'Fire Alarm Systems', desc: 'Notifier, Honeywell — addressable panels for high-rise buildings' },
              { img: '/images/products/viking-vk102.png', name: 'Sprinkler Systems', desc: 'Viking, Victaulic — NFPA 25 heads, valves, fittings' },
              { img: '/images/products/ss-2151.png', name: 'Smoke & CO Detectors', desc: 'System Sensor, Notifier — addressable and conventional' },
              { img: '/images/products/ansul-r102.png', name: 'Kitchen Suppression', desc: 'Ansul R-102, Amerex — NFPA 96 restaurant systems' },
              { img: '/images/products/amerex-b402.png', name: 'Fire Extinguishers', desc: 'Amerex, Kidde — NFPA 10 compliant' },
              { img: '/images/products/ss-spsr.png', name: 'Emergency Egress Lighting', desc: 'NFPA 101 exit signs and emergency units' },
            ].map(prod => (
              <div class="pcard card">
                <div class="pimg">
                  <img src={prod.img} alt={prod.name} loading="lazy" />
                </div>
                <div class="p-4">
                  <div class="text-sm font-semibold text-gray-800 mb-1">{prod.name}</div>
                  <div class="text-xs text-gray-400 mb-3 leading-snug">{prod.desc}</div>
                  <button onclick={`openRFQ('','','${prod.name} — DTLA Reg 4')`} class="w-full bg-red-brand text-white text-xs font-bold py-2.5 rounded-lg hover:bg-red-dark transition-colors cursor-pointer border-0">Request Quote</button>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div>
          <div class="tag text-red-brand mb-2">FAQ</div>
          <h2 class="text-3xl font-bold tracking-tight mb-6">Downtown LA — Regulation 4 FAQs</h2>
          <div class="divide-y divide-gray-100">
            {[
              { q: 'Does Regulation 4 apply to all buildings in DTLA?', a: "Yes. All of Downtown Los Angeles falls within Los Angeles City limits serviced by the LAFD. High-rises, hotels, commercial offices, restaurants, and other commercial occupancies in DTLA are all subject to mandatory LAFD Chief's Regulation 4." },
              { q: 'My building was inspected by a licensed fire contractor. Does that satisfy Reg 4?', a: "Only if that contractor holds a current LAFD Reg 4 certification in the specific system category tested. There are 20+ distinct tester categories each requiring separate LAFD certification. Confirm your tester appears on the LAFD list for the relevant category and that results were filed through thecomplianceengine.com within 7 days." },
              { q: 'We have restaurant tenants. Are they separately responsible for Reg 4?', a: 'Kitchen fire suppression systems (NFPA 96) require semi-annual inspection separate from the annual fire alarm cycle. Building owners typically hold ultimate compliance responsibility — even if a tenant operates the kitchen. Review your lease agreements to clarify responsibility.' },
              { q: 'How quickly can deficiency equipment be replaced after a failed inspection?', a: 'Speed matters — defects must be corrected and retested within 30 days. FSSH fulfills replacement equipment for DTLA buildings within 48 hours for in-stock items: fire alarm components, sprinkler heads, suppression agents, and extinguishers. Submit your deficiency report immediately after the inspection.' },
              { q: "What is the penalty for missing the 7-day Compliance Engine filing window?", a: 'The LAFD treats late filing as a separate violation from the inspection requirement. Penalties for late TCE submission are assessed on top of any penalties for overdue inspections. Always confirm filing with your tester the same day and request TCE confirmation documentation for your records.' },
            ].map(faq => (
              <details class="group py-4">
                <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">
                  <span class="text-sm font-semibold text-gray-800 group-open:text-red-brand transition-colors">{faq.q}</span>
                  <span class="w-6 h-6 flex-shrink-0 bg-gray-100 group-open:bg-red-brand rounded-full flex items-center justify-center text-gray-600 group-open:text-white text-base leading-none transition-all">+</span>
                </summary>
                <p class="text-sm text-gray-600 leading-relaxed mt-3 pb-1">{faq.a}</p>
              </details>
            ))}
          </div>
        </div>

        <div>
          <div class="tag text-red-brand mb-2">Other Neighborhoods</div>
          <h2 class="text-3xl font-bold tracking-tight mb-4">Other Los Angeles City Neighborhoods</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            {nearbyHoods.map(hood => (
              <a href={`/lafd-regulation-4/${hood.slug}/`} class="flex items-center justify-between border border-gray-200 rounded-xl p-4 hover:border-[#1a2744] hover:bg-gray-50 no-underline transition-all">
                <div>
                  <div class="text-sm font-semibold text-[#1a2744]">{hood.name}</div>
                  <div class="text-xs text-gray-400 mt-0.5">{hood.type}</div>
                </div>
                <span class="text-gray-300 ml-3">arrow</span>
              </a>
            ))}
            <a href="/lafd-regulation-4/" class="flex items-center border border-gray-200 rounded-xl p-4 hover:border-red-brand hover:bg-red-light no-underline transition-all">
              <span class="text-sm font-semibold text-red-brand">View All LA City Neighborhoods</span>
            </a>
          </div>
        </div>

      </div>

      <div class="space-y-5 lg:sticky lg:top-20">
        <div class="sform">
          <div class="bg-white/10 border-b border-white/10 px-5 py-3.5">
            <span class="text-xs font-bold uppercase tracking-wider text-blue-300">Free DTLA Compliance Assessment</span>
          </div>
          <div class="p-5">
            <p class="text-xs text-blue-200 mb-4 leading-relaxed">Building in Downtown LA? We'll review your Reg 4 status and connect you with an LAFD-certified tester.</p>
            <input type="text" class="fi" placeholder="Building address (DTLA)" />
            <select class="fi">
              <option value="">Building type...</option>
              <option>High-Rise (75ft+)</option>
              <option>Hotel / Hospitality</option>
              <option>Commercial Office</option>
              <option>Mixed-Use</option>
              <option>Restaurant / Food Hall</option>
              <option>Warehouse / Industrial</option>
            </select>
            <input type="text" class="fi" placeholder="Number of floors" />
            <select class="fi">
              <option value="">Last inspection...</option>
              <option>Within the last year</option>
              <option>1-2 years ago</option>
              <option>2+ years ago</option>
              <option>Never / Unknown</option>
            </select>
            <input type="email" class="fi" placeholder="Email address" />
            <button onclick="openRFQ('','','Reg 4 Assessment — Downtown LA')" class="w-full bg-red-brand text-white py-3.5 rounded-lg text-sm font-bold hover:bg-red-dark transition-colors cursor-pointer border-0">Get Free Assessment</button>
            <p class="text-xs text-center mt-3" style="color:rgba(147,197,253,0.4)">Response within one business day.</p>
          </div>
        </div>

        <div class="border border-gray-200 rounded-xl overflow-hidden">
          <div class="bg-gray-50 border-b border-gray-200 px-4 py-3">
            <span class="text-xs font-bold uppercase tracking-wider text-gray-400">DTLA Quick Facts</span>
          </div>
          <div class="p-4">
            <div class="qfr"><span class="text-gray-400 font-medium">Jurisdiction</span><span class="text-gray-800 font-semibold">LA City (LAFD)</span></div>
            <div class="qfr"><span class="text-gray-400 font-medium">Fire Alarms</span><span class="text-gray-800 font-semibold">Annual</span></div>
            <div class="qfr"><span class="text-gray-400 font-medium">Sprinklers / Standpipe</span><span class="font-bold text-red-brand">5 Years</span></div>
            <div class="qfr"><span class="text-gray-400 font-medium">High-Rises</span><span class="text-gray-800 font-semibold">500+ buildings</span></div>
            <div class="qfr"><span class="text-gray-400 font-medium">Repair/Retest</span><span class="font-bold text-red-brand">30 days</span></div>
            <div class="qfr"><span class="text-gray-400 font-medium">Filing Deadline</span><span class="text-gray-800 font-semibold">7 days</span></div>
            <div class="qfr"><span class="text-gray-400 font-medium">Equipment Lead Time</span><span class="text-gray-800 font-semibold">48 hours</span></div>
          </div>
        </div>

        <div class="border border-gray-200 rounded-xl overflow-hidden">
          <div class="bg-gray-50 border-b border-gray-200 px-4 py-3">
            <span class="text-xs font-bold uppercase tracking-wider text-gray-400">LAFD Reg 4 Unit</span>
          </div>
          <div class="p-4 space-y-2">
            <p class="text-xs text-gray-600 leading-relaxed">Bureau of Fire Prevention and Public Safety, Chief's Regulation No. 4 Unit<br/>200 North Main Street, Room 1750<br/>Los Angeles, CA 90012</p>
            <a href="tel:+12139783560" class="block text-sm font-bold text-red-brand no-underline hover:text-red-dark">(213) 978-3560</a>
            <a href="mailto:LafdReg4@lacity.org" class="block text-xs text-red-brand no-underline hover:text-red-dark">LafdReg4@lacity.org</a>
          </div>
        </div>

        <div class="border border-gray-200 rounded-xl overflow-hidden">
          <div class="bg-gray-50 border-b border-gray-200 px-4 py-3">
            <span class="text-xs font-bold uppercase tracking-wider text-gray-400">NFPA Standards</span>
          </div>
          <div class="p-4 flex flex-wrap gap-1.5">
            {['NFPA 10','NFPA 25','NFPA 72','NFPA 96','NFPA 101','NFPA 14','Title 19 CCR'].map(tag => (
              <span class="npill">{tag}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

</Base>

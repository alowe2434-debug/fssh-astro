---
import Base from '../../../layouts/Base.astro';
const N8N_WEBHOOK = 'https://shiro770.app.n8n.cloud/webhook/fssh-reg4-lead';
const NEIGHBORHOOD = 'Century City';
const SLUG = 'century-city';
const schema = {"@context":"https://schema.org","@graph":[{"@type":"WebPage","@id":`https://firesafetysupplyhouse.com/lafd-regulation-4/${SLUG}/`,"url":`https://firesafetysupplyhouse.com/lafd-regulation-4/${SLUG}/`,"name":`LAFD Regulation 4 Compliance — ${NEIGHBORHOOD}`,"breadcrumb":{"@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://firesafetysupplyhouse.com/"},{"@type":"ListItem","position":2,"name":"LAFD Regulation 4","item":"https://firesafetysupplyhouse.com/lafd-regulation-4/"},{"@type":"ListItem","position":3,"name":NEIGHBORHOOD,"item":`https://firesafetysupplyhouse.com/lafd-regulation-4/${SLUG}/`}]}}]};
const buildingTypes = [
  { type: 'Class A Office Tower', systems: 'Fire alarm, sprinkler, standpipe, smoke management', nfpa: ['NFPA 72','NFPA 25','NFPA 14','NFPA 92'], freq: 'Alarm: Annual · Smoke Mgmt: Annual · Sprinkler/Standpipe: 5 Years' },
  { type: 'Luxury High-Rise Residential', systems: 'Fire alarm, sprinkler, standpipe, emergency generator', nfpa: ['NFPA 72','NFPA 25','NFPA 14','NFPA 110'], freq: 'Alarm: Annual · Generator: Annual · Sprinkler/Standpipe: 5 Years' },
  { type: 'Retail Mall / Food Court', systems: 'Fire alarm, sprinkler, kitchen suppression, standpipe', nfpa: ['NFPA 72','NFPA 25','NFPA 96','NFPA 14'], freq: 'Alarm: Annual · Kitchen: Semi-annual · Sprinkler: 5 Years' },
  { type: 'Medical Office Building', systems: 'Fire alarm, sprinkler, medical gas suppression', nfpa: ['NFPA 72','NFPA 25','NFPA 99'], freq: 'Alarm: Annual · Sprinkler: 5 Years' },
  { type: 'Hotel / Extended Stay', systems: 'Fire alarm, sprinkler, kitchen suppression', nfpa: ['NFPA 72','NFPA 25','NFPA 96'], freq: 'Alarm: Annual · Kitchen: Semi-annual' },
  { type: 'Entertainment / Cinema Complex', systems: 'Fire alarm, sprinkler, egress, smoke management', nfpa: ['NFPA 72','NFPA 25','NFPA 101','NFPA 92'], freq: 'Alarm: Annual · Smoke/Egress: Annual · Sprinkler: 5 Years' },
];
const nearbyHoods = [
  { slug: 'westwood', name: 'Westwood', type: 'Medical · University' },
  { slug: 'mid-wilshire', name: 'Mid-Wilshire', type: 'Office · Retail · Cultural' },
  { slug: 'downtown-los-angeles', name: 'Downtown Los Angeles', type: 'High-rise · Hotel · Office' },
  { slug: 'hollywood', name: 'Hollywood', type: 'Entertainment · Commercial' },
];
const deficiencies = [
  'Smoke management system testing deferrals in high-rise office towers — LAFD requires annual testing of smoke control systems per NFPA 92, frequently delayed due to tenant disruption concerns',
  'Emergency generator load-bank testing gaps — many Century City towers with backup power systems defer annual NFPA 110 testing required under Regulation 4',
  'Standpipe hose valve pressure testing overdue in buildings 15+ years old — NFPA 14 five-year standpipe service cycle missed in multiple Constellation Boulevard properties',
  'Restaurant kitchen suppression lapsing during Westfield food court tenant transitions — new operators assume prior tenant compliance; inspection records are not automatically transferred',
  'Sprinkler head corrosion in 1970s–1980s office construction — original heads exceed manufacturer service life without planned replacement programs',
  'Medical gas suppression compliance gaps in medical office buildings — NFPA 99 obligations often fall outside standard Reg 4 tester scope and go unaddressed',
];
---
<Base title="LAFD Regulation 4 Compliance — Century City" description="LAFD Regulation 4 fire system compliance for Century City buildings. Class A office towers, luxury high-rises, Westfield retail," canonical={`https://firesafetysupplyhouse.com/lafd-regulation-4/${SLUG}/`} schema={schema}>
<style>
  .hood-hero { background: #1a2744; }
  .alert-strip { background: #fdf2f0; border-top: 3px solid #c0392b; border-bottom: 1px solid #fbd5d0; }
  .sform { background: #1a2744; border-radius: 12px; overflow: hidden; }
  .fi { width:100%; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.15); border-radius:6px; padding:10px 12px; font-size:13.5px; color:#fff; font-family:inherit; outline:none; margin-bottom:10px; }
  .fi::placeholder { color:rgba(255,255,255,0.3); }
  .qfr { display:flex; justify-content:space-between; padding:9px 0; border-bottom:1px solid #f0f0f0; font-size:13px; }
  .qfr:last-child { border-bottom:none; }
  .npill { display:inline-block; background:#1a2744; color:#fff; font-size:10.5px; font-weight:600; padding:2px 7px; border-radius:3px; margin:2px 2px 0 0; }
</style>
  <div class="bg-gray-50 border-b border-gray-200"><div class="section py-2.5"><nav class="flex items-center gap-1.5 text-xs text-gray-400"><a href="/" class="hover:text-gray-700 no-underline">Home</a><span>/</span><a href="/lafd-regulation-4/" class="hover:text-gray-700 no-underline">LAFD Regulation 4</a><span>/</span><span class="text-gray-700 font-medium">{NEIGHBORHOOD}</span></nav></div></div>
  <div class="hood-hero py-14"><div class="section"><div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-center"><div class="lg:col-span-2">
    <div class="inline-flex items-center gap-2 bg-red-brand/20 border border-red-brand/40 text-red-300 text-xs font-bold tracking-widest uppercase px-3 py-1.5 rounded mb-5"><span class="w-1.5 h-1.5 rounded-full bg-red-brand inline-block"></span>Century City — Los Angeles City Limits — LAFD Jurisdiction</div>
    <h1 class="text-4xl lg:text-5xl font-bold text-white tracking-tight leading-tight mb-4">LAFD Regulation 4 Compliance in Century City</h1>
    <p class="text-lg text-blue-200 max-w-2xl leading-relaxed mb-6">Century City's cluster of Class A office towers, luxury residential high-rises, and the Westfield Century City complex creates some of the largest Regulation 4 footprints in western Los Angeles. Smoke management systems, standpipe testing, and multi-tenant kitchen suppression all require separate LAFD-certified tester categories on annual and five-year cycles.</p>
    <div class="flex flex-wrap gap-2"><span class="bg-white/10 border border-white/15 text-blue-100 text-xs font-medium px-3 py-1.5 rounded">High-Rise Smoke Management</span><span class="bg-white/10 border border-white/15 text-blue-100 text-xs font-medium px-3 py-1.5 rounded">Standpipe 5-Year Cycle</span><span class="bg-white/10 border border-white/15 text-blue-100 text-xs font-medium px-3 py-1.5 rounded">7-Day Compliance Engine Filing</span><span class="bg-white/10 border border-white/15 text-blue-100 text-xs font-medium px-3 py-1.5 rounded">48hr Equipment Fulfillment</span></div>
  </div><div class="flex flex-col gap-2">
    <div class="bg-white/10 border border-white/10 rounded-xl p-4 text-center"><div class="text-3xl font-bold text-white mb-1">40+</div><div class="text-xs text-blue-300">High-rise and large commercial buildings subject to Reg 4 in Century City</div></div>
    <div class="bg-white/10 border border-white/10 rounded-xl p-4 text-center"><div class="text-3xl font-bold text-white mb-1">Annual</div><div class="text-xs text-blue-300">Smoke management system testing required for every high-rise under NFPA 92</div></div>
    <div class="bg-white/10 border border-white/10 rounded-xl p-4 text-center"><div class="text-3xl font-bold text-white mb-1">7</div><div class="text-xs text-blue-300">Days to file inspection results in The Compliance Engine</div></div>
  </div></div></div></div>
  <div class="alert-strip px-6 py-4"><div class="section flex items-start gap-3"><span class="text-red-brand text-lg mt-0.5 flex-shrink-0">⚠</span><p class="text-sm text-red-900 leading-relaxed"><strong class="text-red-brand">Century City Compliance Notice:</strong> Century City is within Los Angeles City limits under LAFD jurisdiction. High-rise buildings must test smoke management systems <strong>annually</strong> under NFPA 92 — separate from the 5-year sprinkler and standpipe cycle. Retail food court tenants require <strong>semi-annual</strong> kitchen suppression inspection. All results filed within <strong>7 days</strong> via thecomplianceengine.com.</p></div></div>
  <div class="section py-14"><div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start"><div class="lg:col-span-2 space-y-14">
    <div><div class="tag text-red-brand mb-2">Context</div><h2 class="text-3xl font-bold tracking-tight mb-4">Regulation 4 in Century City</h2>
    <p class="text-gray-600 leading-relaxed mb-4">Century City concentrates more large commercial buildings subject to Regulation 4 per square block than most of western Los Angeles. The Avenue of the Stars office corridor, Constellation Boulevard towers, and the Westfield complex represent hundreds of separate Reg 4 obligations — each with distinct tester category requirements and testing cycles that must be tracked independently.</p>
    <p class="text-gray-600 leading-relaxed mb-6">The most common compliance gap in Century City is not the annual fire alarm test — it's the five-year standpipe cycle and annual smoke management verification. Both are mandatory under Reg 4, and late filing penalties from the Compliance Engine apply regardless of whether the inspection was missed or simply not submitted on time.</p>
    <div class="grid grid-cols-2 gap-3">
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-4"><div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">AHJ</div><div class="text-sm font-semibold text-gray-800">Los Angeles Fire Department</div><div class="text-xs text-gray-500 mt-0.5">All of Century City is LAFD jurisdiction</div></div>
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-4"><div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">Key Risk</div><div class="text-sm font-semibold text-gray-800">Smoke Mgmt + Standpipe</div><div class="text-xs text-gray-500 mt-0.5">Most deferred systems in high-rises</div></div>
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-4"><div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">Filing Platform</div><div class="text-sm font-semibold text-gray-800">thecomplianceengine.com</div><div class="text-xs text-gray-500 mt-0.5">7-day electronic submission required</div></div>
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-4"><div class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-1">Equipment Lead Time</div><div class="text-sm font-semibold text-red-brand">48 Hours</div><div class="text-xs text-gray-500 mt-0.5">FSSH fulfillment for Century City</div></div>
    </div></div>
    <div><div class="tag text-red-brand mb-2">By Building Type</div><h2 class="text-3xl font-bold tracking-tight mb-4">Century City Building Types &amp; Requirements</h2>
    <div class="overflow-x-auto rounded-xl border border-gray-200"><table class="w-full text-sm border-collapse"><thead><tr class="bg-[#1a2744] text-white"><th class="text-left px-4 py-3 text-xs font-semibold tracking-wider">Building Type</th><th class="text-left px-4 py-3 text-xs font-semibold tracking-wider hidden md:table-cell">NFPA Standards</th><th class="text-left px-4 py-3 text-xs font-semibold tracking-wider">Frequency</th></tr></thead><tbody>{buildingTypes.map((bt, i) => (<tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}><td class="px-4 py-3 border-b border-gray-100 font-semibold text-[#1a2744] align-top text-sm">{bt.type}</td><td class="px-4 py-3 border-b border-gray-100 align-top hidden md:table-cell">{bt.nfpa.map(n => <span class="npill">{n}</span>)}</td><td class="px-4 py-3 border-b border-gray-100 text-xs text-gray-600 align-top leading-relaxed">{bt.freq}</td></tr>))}</tbody></table></div></div>
    <div><div class="tag text-red-brand mb-2">What Gets Flagged</div><h2 class="text-3xl font-bold tracking-tight mb-4">Most Common Reg 4 Deficiencies in Century City</h2>
    <div class="flex flex-col gap-3">{deficiencies.map(d => (<div class="flex items-start gap-3 bg-red-light border border-red-200 border-l-4 border-l-red-brand rounded-r-lg px-4 py-3 text-sm text-red-900"><span class="text-red-brand flex-shrink-0 mt-0.5">⚠</span>{d}</div>))}</div></div>
    <div><div class="tag text-red-brand mb-2">FAQ</div><h2 class="text-3xl font-bold tracking-tight mb-6">Century City — Regulation 4 FAQs</h2>
    <div class="divide-y divide-gray-100">{[
      { q: 'Does smoke management testing apply to our Century City office tower?', a: 'Yes. Any high-rise in Los Angeles City limits with a smoke control or management system must test annually under NFPA 92 per Reg 4. This is separate from the annual fire alarm test — it requires a different LAFD-certified tester category and must be filed independently through thecomplianceengine.com within 7 days.' },
      { q: 'When does our standpipe system need testing?', a: 'Standpipe systems (Class I, II, and III) are on a five-year testing cycle under NFPA 14 and Regulation 4. The test includes flow tests, hose valve pressure verification, and full outlet inspection. Many Century City towers on original 1970s–1980s construction are overdue — check your last TCE filing date.' },
      { q: 'We manage multiple tenants. Who files Reg 4 results?', a: "The building owner or property manager is responsible for base-building and common-area fire systems. Commercial tenants with their own cooking equipment are typically responsible for kitchen suppression under their lease terms. Clarify scope in writing with each tenant's lease addendum to avoid compliance gaps." },
      { q: 'Our building has an emergency generator. Does that require annual Reg 4 testing?', a: 'Yes. Emergency generators serving life safety loads require annual load-bank testing under NFPA 110 as required by Regulation 4. Many Century City properties with generator systems defer this test — it is a mandatory Reg 4 obligation, not optional maintenance.' },
    ].map(faq => (<details class="group py-4"><summary class="flex items-center justify-between gap-4 cursor-pointer list-none"><span class="text-sm font-semibold text-gray-800 group-open:text-red-brand transition-colors">{faq.q}</span><span class="w-6 h-6 flex-shrink-0 bg-gray-100 group-open:bg-red-brand rounded-full flex items-center justify-center text-gray-600 group-open:text-white text-base leading-none transition-all">+</span></summary><p class="text-sm text-gray-600 leading-relaxed mt-3 pb-1">{faq.a}</p></details>))}</div></div>
    <div><div class="tag text-red-brand mb-2">Other Neighborhoods</div><h2 class="text-3xl font-bold tracking-tight mb-4">Other Los Angeles City Neighborhoods</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">{nearbyHoods.map(hood => (<a href={`/lafd-regulation-4/${hood.slug}/`} class="flex items-center justify-between border border-gray-200 rounded-xl p-4 hover:border-[#1a2744] hover:bg-gray-50 no-underline transition-all"><div><div class="text-sm font-semibold text-[#1a2744]">{hood.name}</div><div class="text-xs text-gray-400 mt-0.5">{hood.type}</div></div><span class="text-gray-300 ml-3">→</span></a>))}<a href="/lafd-regulation-4/" class="flex items-center border border-gray-200 rounded-xl p-4 hover:border-red-brand hover:bg-red-light no-underline transition-all"><span class="text-sm font-semibold text-red-brand">View All LA City Neighborhoods</span></a></div></div>
  </div>
  <div class="space-y-5 lg:sticky lg:top-20">
    <div class="sform"><div class="bg-white/10 border-b border-white/10 px-5 py-3.5"><span class="text-xs font-bold uppercase tracking-wider text-blue-300">Free Century City Compliance Assessment</span></div>
    <div class="p-5"><p class="text-xs text-blue-200 mb-4 leading-relaxed">Building in Century City? We'll review your Reg 4 status and connect you with an LAFD-certified tester.</p>
      <input id="cc-name" type="text" class="fi" placeholder="Your name" />
      <input id="cc-address" type="text" class="fi" placeholder="Building address" />
      <select id="cc-type" class="fi"><option value="">Building type...</option><option>Class A Office Tower</option><option>Luxury High-Rise Residential</option><option>Retail Mall / Shopping Center</option><option>Medical Office Building</option><option>Hotel / Extended Stay</option><option>Entertainment / Cinema Complex</option></select>
      <input id="cc-floors" type="text" class="fi" placeholder="Number of floors" />
      <select id="cc-inspection" class="fi"><option value="">Last inspection...</option><option>Within the last year</option><option>1-2 years ago</option><option>2+ years ago</option><option>Never / Unknown</option></select>
      <input id="cc-email" type="email" class="fi" placeholder="Email address" />
      <input id="cc-phone" type="tel" class="fi" placeholder="Phone number" />
      <button id="cc-submit" class="w-full bg-red-brand text-white py-3.5 rounded-lg text-sm font-bold hover:bg-red-dark transition-colors cursor-pointer border-0">Get Free Assessment</button>
      <div id="cc-success" style="display:none" class="text-center text-green-300 text-sm font-medium mt-3">✓ Received — we'll be in touch within one business day.</div>
      <p class="text-xs text-center mt-3" style="color:rgba(147,197,253,0.4)">Response within one business day.</p>
    </div></div>
    <div class="border border-gray-200 rounded-xl overflow-hidden"><div class="bg-gray-50 border-b border-gray-200 px-4 py-3"><span class="text-xs font-bold uppercase tracking-wider text-gray-400">Century City Quick Facts</span></div>
    <div class="p-4"><div class="qfr"><span class="text-gray-400 font-medium">Jurisdiction</span><span class="text-gray-800 font-semibold">LA City (LAFD)</span></div><div class="qfr"><span class="text-gray-400 font-medium">Fire Alarms</span><span class="text-gray-800 font-semibold">Annual</span></div><div class="qfr"><span class="text-gray-400 font-medium">Smoke Management</span><span class="font-bold text-red-brand">Annual</span></div><div class="qfr"><span class="text-gray-400 font-medium">Sprinklers / Standpipe</span><span class="font-bold text-red-brand">5 Years</span></div><div class="qfr"><span class="text-gray-400 font-medium">Repair/Retest</span><span class="font-bold text-red-brand">30 days</span></div><div class="qfr"><span class="text-gray-400 font-medium">Filing Deadline</span><span class="text-gray-800 font-semibold">7 days</span></div></div></div>
    <div class="border border-gray-200 rounded-xl overflow-hidden"><div class="bg-gray-50 border-b border-gray-200 px-4 py-3"><span class="text-xs font-bold uppercase tracking-wider text-gray-400">LAFD Reg 4 Unit</span></div>
    <div class="p-4 space-y-2"><p class="text-xs text-gray-600 leading-relaxed">Bureau of Fire Prevention and Public Safety<br/>200 North Main Street, Room 1750<br/>Los Angeles, CA 90012</p><a href="tel:+12139783560" class="block text-sm font-bold text-red-brand no-underline">(213) 978-3560</a><a href="mailto:LafdReg4@lacity.org" class="block text-xs text-red-brand no-underline">LafdReg4@lacity.org</a></div></div>
  </div></div></div>
  <script define:vars={{ N8N_WEBHOOK, NEIGHBORHOOD }}>
    document.getElementById('cc-submit').addEventListener('click', async function() {
      const btn = this; btn.textContent = 'Submitting...'; btn.disabled = true;
      const payload = { neighborhood: NEIGHBORHOOD, name: document.getElementById('cc-name').value, address: document.getElementById('cc-address').value, buildingType: document.getElementById('cc-type').value, floors: document.getElementById('cc-floors').value, lastInspection: document.getElementById('cc-inspection').value, email: document.getElementById('cc-email').value, phone: document.getElementById('cc-phone').value, source: 'FSSH Reg 4 — Century City' };
      try { await fetch(N8N_WEBHOOK, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) }); } catch(e) {}
      document.getElementById('cc-success').style.display = 'block'; btn.style.display = 'none';
    });
  </script>
</Base>

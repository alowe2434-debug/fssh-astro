---
import Base from '../layouts/Base.astro';
const city = 'San Diego';
const state = 'CA';
const stateFull = 'California';
const slug = 'san-diego-ca';
const county = 'San Diego County';
const fireDept = 'San Diego Fire-Rescue Department';
---
<Base title={`Fire Safety Services ${city}, ${state}`} description={`Fire inspection, alarm, sprinkler, and kitchen suppression services for San Diego, CA — California Fire Code compliance & San Diego Fire-Rescue Department v`} canonical={`https://firesafetysupplyhouse.com/fire-safety-services-san-diego-ca/`}>
  <section class="bg-gradient-to-b from-gray-50 to-white py-16"><div class="section">
    <nav class="flex items-center gap-2 text-xs text-gray-400 mb-8"><a href="/" class="hover:text-gray-700 no-underline">Home</a><span>/</span><span class="text-gray-700">Fire Safety Services in {city}, {state}</span></nav>
    <div class="max-w-3xl">
      <div class="text-xs font-bold uppercase tracking-widest text-red-brand mb-3">Serving San Diego, California — San Diego County</div>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-5 leading-tight">Fire Safety Services in San Diego, CA</h1>
      <p class="text-lg text-gray-500 leading-relaxed mb-6">Complete fire protection services for commercial properties in San Diego, California. Fire extinguisher inspection, fire alarm installation, sprinkler systems, kitchen suppression, and California Fire Code compliance consulting — performed by licensed professionals to keep your building compliant with San Diego Fire-Rescue Department requirements and NFPA standards.</p>
      <div class="flex flex-wrap gap-3"><button onclick={`openRFQ('','','Fire Safety Services - ${city}, ${state}')`} class="btn-primary text-sm">Schedule a Fire Safety Inspection</button><a href="mailto:quotes@firesafetysupplyhouse.com" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-gray-200 text-sm font-medium text-gray-700 hover:border-gray-400 transition-colors no-underline">Contact Us</a></div>
    </div>
  </div></section>
  <section class="bg-red-brand text-white py-4"><div class="section text-center"><p class="text-sm font-medium">⚠️ Don't wait for a violation. California Fire Code violations carry per-day fines. San Diego Fire-Rescue actively enforces compliance in biotech, entertainment, and WUI zones.</p></div></section>
  <section class="py-16"><div class="section">
    <div class="text-center mb-12"><h2 class="text-3xl font-bold tracking-tight mb-3">Fire Protection Services for San Diego Businesses</h2><p class="text-base text-gray-500 max-w-2xl mx-auto">We provide every fire safety service your San Diego commercial property needs to stay compliant with San Diego Fire-Rescue Department requirements and NFPA standards.</p></div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="card p-6 flex flex-col"><div class="text-3xl mb-3">🧯</div><h3 class="text-lg font-bold mb-2">Fire Extinguisher Inspection &amp; Service</h3><p class="text-sm text-gray-600 leading-relaxed flex-1 mb-3">NFPA 10 compliant fire extinguisher inspections for San Diego commercial properties. Monthly visual checks, annual professional inspections, 6-year internal examinations, and 12-year hydrostatic testing. All service by licensed fire protection technicians.</p><div class="flex items-center justify-between"><span class="text-xs font-bold text-red-brand bg-red-light px-2 py-1 rounded">NFPA 10</span><button onclick={`openRFQ('','','Fire Extinguisher Service - ${city}, ${state}')`} class="text-xs font-bold text-red-brand hover:underline bg-transparent border-0 cursor-pointer">Get Quote →</button></div></div>
      <div class="card p-6 flex flex-col"><div class="text-3xl mb-3">🔔</div><h3 class="text-lg font-bold mb-2">Fire Alarm System Installation &amp; Testing</h3><p class="text-sm text-gray-600 leading-relaxed flex-1 mb-3">Complete fire alarm system design, installation, and annual testing for San Diego commercial buildings. Addressable and conventional systems, smoke detectors, pull stations, horn/strobes, and monitoring. Full compliance with NFPA 72 and San Diego Fire-Rescue Department requirements.</p><div class="flex items-center justify-between"><span class="text-xs font-bold text-red-brand bg-red-light px-2 py-1 rounded">NFPA 72</span><button onclick={`openRFQ('','','Fire Alarm Installation - ${city}, ${state}')`} class="text-xs font-bold text-red-brand hover:underline bg-transparent border-0 cursor-pointer">Get Quote →</button></div></div>
      <div class="card p-6 flex flex-col"><div class="text-3xl mb-3">💧</div><h3 class="text-lg font-bold mb-2">Fire Sprinkler System Installation &amp; Inspection</h3><p class="text-sm text-gray-600 leading-relaxed flex-1 mb-3">Fire sprinkler design, installation, and inspection for San Diego commercial properties. Wet, dry, pre-action, and deluge systems. Quarterly, semi-annual, and five-year inspections per NFPA 25. California mandates sprinklers in most new commercial construction. San Diego also has fire hazard severity zone requirements for WUI properties.</p><div class="flex items-center justify-between"><span class="text-xs font-bold text-red-brand bg-red-light px-2 py-1 rounded">NFPA 13 / NFPA 25</span><button onclick={`openRFQ('','','Fire Sprinkler Inspection - ${city}, ${state}')`} class="text-xs font-bold text-red-brand hover:underline bg-transparent border-0 cursor-pointer">Get Quote →</button></div></div>
      <div class="card p-6 flex flex-col"><div class="text-3xl mb-3">🍳</div><h3 class="text-lg font-bold mb-2">Commercial Kitchen Fire Suppression</h3><p class="text-sm text-gray-600 leading-relaxed flex-1 mb-3">Wet chemical fire suppression for San Diego restaurants and food service operations. Design, installation, semi-annual inspection, and recharge. Ansul, Amerex, and Kidde certified. Required for all commercial cooking per NFPA 96.</p><div class="flex items-center justify-between"><span class="text-xs font-bold text-red-brand bg-red-light px-2 py-1 rounded">NFPA 96</span><button onclick={`openRFQ('','','Kitchen Suppression - ${city}, ${state}')`} class="text-xs font-bold text-red-brand hover:underline bg-transparent border-0 cursor-pointer">Get Quote →</button></div></div>
      <div class="card p-6 flex flex-col"><div class="text-3xl mb-3">📋</div><h3 class="text-lg font-bold mb-2">Fire Code Compliance Consulting</h3><p class="text-sm text-gray-600 leading-relaxed flex-1 mb-3">Fire code compliance audits, violation remediation, and pre-inspection consulting for San Diego commercial properties. We help property managers resolve San Diego Fire-Rescue Department violations and prepare for inspections under the California Fire Code.</p><div class="flex items-center justify-between"><span class="text-xs font-bold text-red-brand bg-red-light px-2 py-1 rounded">NFPA 101</span><button onclick={`openRFQ('','','Fire Code Compliance - ${city}, ${state}')`} class="text-xs font-bold text-red-brand hover:underline bg-transparent border-0 cursor-pointer">Get Quote →</button></div></div>
    </div>
  </div></section>
  <section class="bg-gray-50 py-16"><div class="section"><div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
    <div>
      <h2 class="text-3xl font-bold tracking-tight mb-4">San Diego Fire Code Requirements</h2>
      <p class="text-sm text-gray-600 leading-relaxed mb-4">The City of San Diego enforces the California Fire Code (Title 19 CCR) through the San Diego Fire-Rescue Department Fire Prevention Division. As California's second-largest city and one of the nation's leading biotech and defense technology hubs, San Diego oversees a vast commercial landscape spanning the Gaslamp Quarter entertainment district, the Sorrento Valley and Torrey Pines biotech and pharmaceutical research corridor, the Downtown convention center and Petco Park district, major military-support commercial operations near Naval Base San Diego and MCAS Miramar, and significant port and marine industrial operations.</p>
      <p class="text-sm text-gray-600 leading-relaxed mb-4">San Diego's world-class biotech sector — concentrated in Sorrento Valley, Torrey Pines, and the Scripps Research Institute corridor — creates fire protection requirements that go significantly beyond standard commercial buildings. Pharmaceutical research labs, biologics manufacturing facilities, cryogenic storage operations, and clinical trial facilities all carry specialized fire protection obligations. San Diego's significant wildland-urban interface zones — including Scripps Ranch, Rancho Bernardo, and Otay Ranch — also create enhanced defensible space and ignition-resistant construction requirements for properties in those fire hazard severity zones.</p>
      <p class="text-sm text-gray-600 leading-relaxed mb-4">Key standards include <a href="/compliance/nfpa-10/" class="text-red-brand hover:underline">NFPA 10</a>, <a href="/compliance/nfpa-72/" class="text-red-brand hover:underline">NFPA 72</a>, and <a href="/compliance/nfpa-25/" class="text-red-brand hover:underline">NFPA 25</a>.</p>
    </div>
    <div>
      <div class="bg-white rounded-xl p-6 border border-gray-200 mb-6">
        <h3 class="text-lg font-bold mb-4">San Diego Fire Prevention Contacts</h3>
        <div class="flex flex-col gap-3">
          <div><p class="text-sm font-bold text-gray-800">San Diego Fire-Rescue Department — Fire Prevention</p><p class="text-xs text-gray-600">1010 Second Ave, Suite 400, San Diego, CA 92101</p><p class="text-xs text-gray-600">Phone: (619) 533-4300</p></div>
          <div class="border-t border-gray-100 pt-3"><p class="text-sm font-bold text-gray-800">California State Fire Marshal's Office</p><p class="text-xs text-gray-600">Licensing & Enforcement: (916) 445-8200</p></div>
        </div>
      </div>
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3 class="text-lg font-bold mb-4">Inspection Frequency Requirements</h3>
        <div class="flex flex-col gap-2">
          <div class="flex justify-between items-center py-2 border-b border-gray-100"><span class="text-sm text-gray-700">Fire Extinguishers (visual)</span><span class="text-xs font-bold text-red-brand">Monthly</span></div>
          <div class="flex justify-between items-center py-2 border-b border-gray-100"><span class="text-sm text-gray-700">Fire Extinguishers (professional)</span><span class="text-xs font-bold text-red-brand">Annual</span></div>
          <div class="flex justify-between items-center py-2 border-b border-gray-100"><span class="text-sm text-gray-700">Fire Alarm Systems</span><span class="text-xs font-bold text-red-brand">Annual</span></div>
          <div class="flex justify-between items-center py-2 border-b border-gray-100"><span class="text-sm text-gray-700">Fire Sprinkler Systems</span><span class="text-xs font-bold text-red-brand">Quarterly+</span></div>
          <div class="flex justify-between items-center py-2"><span class="text-sm text-gray-700">Kitchen Suppression</span><span class="text-xs font-bold text-red-brand">Semi-Annual</span></div>
        </div>
      </div>
    </div>
  </div></div></section>
  <section class="py-16"><div class="section">
    <h2 class="text-3xl font-bold tracking-tight mb-3 text-center">Commercial Properties We Serve in San Diego</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4"><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Biotech & Pharmaceutical Labs</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Hotels & Convention Center</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Restaurants & Gaslamp Quarter</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Military Support Facilities</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Office & Corporate</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Port & Marine Operations</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Multi-Family Residential</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Healthcare & Medical Centers</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Schools & Universities</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Retail & Shopping</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Houses of Worship</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Mixed-Use Developments</span></div></div>
  </div></section>
  <section class="bg-gray-50 py-16"><div class="section max-w-3xl">
    <h2 class="text-3xl font-bold tracking-tight mb-8 text-center">Frequently Asked Questions</h2>
    <div class="flex flex-col gap-4">
      <div class="bg-white rounded-xl p-5 border border-gray-200"><h3 class="text-sm font-bold mb-2">What fire safety services are required for commercial buildings in San Diego, CA?</h3><p class="text-sm text-gray-600 leading-relaxed">San Diego enforces the California Fire Code (Title 19 CCR). Requirements include fire extinguishers (NFPA 10), fire alarms (NFPA 72), sprinklers (NFPA 13/25), and kitchen suppression for commercial cooking (NFPA 96). California mandates sprinklers in most new commercial construction. San Diego also has fire hazard severity zone requirements for WUI properties.</p></div>
      <div class="bg-white rounded-xl p-5 border border-gray-200"><h3 class="text-sm font-bold mb-2">How often are fire inspections required in San Diego?</h3><p class="text-sm text-gray-600 leading-relaxed">The San Diego Fire-Rescue Department conducts annual commercial property inspections. Fire extinguishers: monthly visual checks and annual professional inspection. Fire alarms: annual testing. Sprinklers: quarterly, semi-annual, and annual inspections. Kitchen suppression: semi-annual per NFPA 96.</p></div>
      <div class="bg-white rounded-xl p-5 border border-gray-200"><h3 class="text-sm font-bold mb-2">Our San Diego facility is a biotech or pharmaceutical research lab. What fire protection does California require?</h3><p class="text-sm text-gray-600 leading-relaxed">Biotech and pharmaceutical research facilities in San Diego face fire protection requirements under the California Fire Code, NFPA 45 (Laboratories Using Chemicals), and potentially NFPA 30 (Flammable and Combustible Liquids) depending on chemical storage volumes. Cryogenic storage areas (liquid nitrogen, liquid oxygen) require specialized ventilation and detection systems under NFPA 55. Clean rooms with specialty gases may require gas detection and interlocks. The San Diego Fire-Rescue Department has significant experience with the Sorrento Valley biotech corridor and enforces these requirements actively. A licensed fire protection engineer with lab experience is essential.</p></div>
      <div class="bg-white rounded-xl p-5 border border-gray-200"><h3 class="text-sm font-bold mb-2">Do restaurants in San Diego need special fire suppression systems?</h3><p class="text-sm text-gray-600 leading-relaxed">Yes. All commercial cooking producing grease-laden vapors requires a wet chemical suppression system per NFPA 96, plus a Class K extinguisher within 30 feet of cooking equipment. Systems must be inspected semi-annually by a licensed technician.</p></div>
      <div class="bg-white rounded-xl p-5 border border-gray-200"><h3 class="text-sm font-bold mb-2">Who enforces fire codes in San Diego, CA?</h3><p class="text-sm text-gray-600 leading-relaxed">The San Diego Fire-Rescue Department enforces fire codes within San Diego limits. The California State Fire Marshal's Office licenses fire protection contractors at (916) 445-8200.</p></div>
    </div>
  </div></section>
  <section class="py-16"><div class="section text-center max-w-2xl">
    <h2 class="text-3xl font-bold tracking-tight mb-4">Schedule Your Fire Safety Inspection in San Diego, CA</h2>
    <p class="text-base text-gray-500 mb-6">Don't wait for the San Diego Fire-Rescue Department to find violations. Get ahead of California Fire Code requirements with a comprehensive fire safety assessment of your San Diego property.</p>
    <button onclick={`openRFQ('','','Fire Safety Inspection - ${city}, ${state}')`} class="btn-primary text-sm">Get a Free Quote</button>
    <p class="text-xs text-gray-400 mt-3">Or email us: <a href="mailto:quotes@firesafetysupplyhouse.com" class="text-red-brand hover:underline">quotes@firesafetysupplyhouse.com</a></p>
  </div></section>
  <section class="bg-gray-50 py-12"><div class="section">
    <h3 class="text-lg font-bold mb-4">Related Resources</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <a href="/compliance/nfpa-10/" class="card p-4 no-underline group"><span class="text-xs font-bold text-red-brand">Compliance</span><p class="text-sm font-bold group-hover:text-red-brand transition-colors">NFPA 10 Fire Extinguisher Requirements</p></a>
      <a href="/compliance/nfpa-72/" class="card p-4 no-underline group"><span class="text-xs font-bold text-red-brand">Compliance</span><p class="text-sm font-bold group-hover:text-red-brand transition-colors">NFPA 72 Fire Alarm System Standards</p></a>
      <a href="/fire-safety-services-chula-vista-ca/" class="card p-4 no-underline group"><span class="text-xs font-bold text-red-brand">City</span><p class="text-sm font-bold group-hover:text-red-brand transition-colors">Fire Safety Services in Chula Vista, CA</p></a>
      <a href="/fire-safety-services-long-beach-ca/" class="card p-4 no-underline group"><span class="text-xs font-bold text-red-brand">City</span><p class="text-sm font-bold group-hover:text-red-brand transition-colors">Fire Safety Services in Long Beach, CA</p></a>
      <a href="/fire-safety-services-irvine-ca/" class="card p-4 no-underline group"><span class="text-xs font-bold text-red-brand">City</span><p class="text-sm font-bold group-hover:text-red-brand transition-colors">Fire Safety Services in Irvine, CA</p></a>
      <a href="/resources/fire-safety-checklist-property-managers/" class="card p-4 no-underline group"><span class="text-xs font-bold text-red-brand">Resources</span><p class="text-sm font-bold group-hover:text-red-brand transition-colors">Fire Safety Checklist for Property Managers</p></a>
    </div>
  </div></section>
</Base>

---
import Base from '../layouts/Base.astro';

const city = 'Bakersfield';
const state = 'CA';
const stateFull = 'California';
const slug = 'bakersfield-ca';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": `Fire Safety Supply House — ${city}, ${state}`,
      "description": `Fire safety inspection, fire extinguisher service, fire alarm installation, fire sprinkler systems, and fire code compliance services in ${city}, ${stateFull}.`,
      "url": `https://firesafetysupplyhouse.com/fire-safety-services-${slug}/`,
      "areaServed": {
        "@type": "City",
        "name": city,
        "containedInPlace": { "@type": "State", "name": stateFull }
      },
      "serviceType": [
        "Fire Extinguisher Inspection",
        "Fire Alarm Installation",
        "Fire Sprinkler Installation",
        "Fire Suppression System Installation",
        "Fire Code Compliance Consulting"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "Sales",
        "email": "quotes@firesafetysupplyhouse.com"
      }
    },
    {
      "@type": "Service",
      "name": `Fire Safety Services in ${city}, ${state}`,
      "provider": { "@type": "Organization", "name": "Fire Safety Supply House" },
      "areaServed": { "@type": "City", "name": city },
      "serviceType": "Fire Protection Services",
      "description": `Complete fire safety services for commercial properties in ${city}, ${stateFull}: fire extinguisher inspection, fire alarm installation, fire sprinkler systems, fire suppression, and fire code compliance consulting.`
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": `What fire safety services are required for commercial buildings in ${city}, ${state}?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `Commercial buildings in ${city}, ${stateFull} must comply with the California Fire Code (Title 24, Part 9), which adopts the International Fire Code with California amendments. This includes maintaining inspected fire extinguishers (NFPA 10), operational fire alarm systems with UL-listed monitoring (NFPA 72), fire sprinkler systems where required (NFPA 13/25), and commercial kitchen fire suppression systems (NFPA 96). The Bakersfield Fire Department Fire Prevention Bureau enforces these requirements through routine inspections.`
          }
        },
        {
          "@type": "Question",
          "name": `How often are fire inspections required in ${city}, ${state}?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `The Bakersfield Fire Department conducts annual fire inspections of most commercial properties. Fire extinguishers require monthly visual checks and annual professional inspections per NFPA 10. Fire alarm systems need annual testing per NFPA 72. Fire sprinkler systems require quarterly, semi-annual, and annual inspections per NFPA 25. Commercial kitchen suppression systems need semi-annual inspections per NFPA 96.`
          }
        },
        {
          "@type": "Question",
          "name": `What are the penalties for fire code violations in ${city}, ${state}?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `Fire code violations in ${city} can result in substantial fines under California Health and Safety Code. The Bakersfield Fire Department can issue citations, stop-work orders, or vacate orders for serious safety deficiencies. Property owners typically receive a correction period for first-time violations. Repeat violations or life-safety hazards face immediate enforcement action and escalated penalties.`
          }
        },
        {
          "@type": "Question",
          "name": `Do restaurants in ${city} need special fire suppression systems?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `Yes. All commercial cooking operations in ${city} that produce grease-laden vapors must have an automatic fire suppression system (typically a wet chemical hood system) per NFPA 96. This applies to restaurants, hotel kitchens, hospital cafeterias, school kitchens, and food trucks. These systems must be inspected and serviced semi-annually by a licensed technician. Class K fire extinguishers are also required within 30 feet of cooking equipment.`
          }
        },
        {
          "@type": "Question",
          "name": `Who enforces fire codes in ${city}, ${state}?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `The Bakersfield Fire Department Fire Prevention Bureau enforces fire codes within the city limits. The Kern County Fire Department handles unincorporated areas of Kern County. The California State Fire Marshal (CAL FIRE OSFM) oversees licensing of fire protection service companies statewide and enforces state fire safety regulations.`
          }
        }
      ]
    }
  ]
};

const services = [
  {
    title: 'Fire Extinguisher Inspection & Service',
    icon: '🧯',
    desc: `NFPA 10 compliant fire extinguisher inspections for ${city} commercial properties. Monthly visual checks, annual professional inspections, 6-year internal examinations, and 12-year hydrostatic testing. All service performed by California-certified technicians.`,
    nfpa: 'NFPA 10',
    keywords: `fire extinguisher inspection ${city}, fire extinguisher service ${city} ${state}, fire extinguisher recharge ${city}`
  },
  {
    title: 'Fire Alarm System Installation & Testing',
    icon: '🔔',
    desc: `Complete fire alarm system design, installation, and annual testing for ${city} commercial buildings. Addressable and conventional systems, pull stations, smoke detectors, horn/strobes, and UL-listed central station monitoring. Full compliance with NFPA 72, California Fire Code, and local AHJ requirements.`,
    nfpa: 'NFPA 72',
    keywords: `fire alarm installation ${city}, fire alarm testing ${city} ${state}, fire alarm companies ${city}`
  },
  {
    title: 'Fire Sprinkler System Installation & Inspection',
    icon: '💧',
    desc: `Fire sprinkler system design, installation, and inspection for new construction and retrofit projects in ${city}. Wet, dry, pre-action, and deluge systems. Quarterly, semi-annual, and annual inspections per NFPA 25. Five-year internal pipe inspections and obstruction investigations.`,
    nfpa: 'NFPA 13 / NFPA 25',
    keywords: `fire sprinkler installation ${city}, fire sprinkler inspection ${city} ${state}, sprinkler system service ${city}`
  },
  {
    title: 'Commercial Kitchen Fire Suppression',
    icon: '🍳',
    desc: `Wet chemical fire suppression systems for commercial kitchens, restaurants, and food service operations in ${city}. Design, installation, semi-annual inspection, and recharge services. Ansul, Amerex, and Kidde system certified technicians. Required for all commercial cooking operations per NFPA 96.`,
    nfpa: 'NFPA 96',
    keywords: `commercial kitchen fire suppression ${city}, restaurant fire suppression ${city} ${state}, ansul system ${city}`
  },
  {
    title: 'Fire Code Compliance Consulting',
    icon: '📋',
    desc: `Fire code compliance audits, violation remediation, and pre-inspection consulting for ${city} commercial properties. We help property managers, building owners, and facility teams prepare for Bakersfield Fire Department inspections and resolve existing violations quickly.`,
    nfpa: 'California Fire Code / NFPA 101',
    keywords: `fire code compliance ${city}, fire safety inspection ${city} ${state}, fire marshal inspection ${city}`
  }
];
---

<Base
  title={`Fire Safety Services in ${city}, ${state} — Inspection, Installation & Compliance`}
  description={`Fire safety services for ${city}, ${state} commercial properties. Fire extinguisher inspection, fire alarm installation, sprinkler systems, kitchen suppression, and fire code compliance.`}
  schema={schema}
>
  <!-- HERO -->
  <section class="bg-gradient-to-b from-gray-50 to-white py-16">
    <div class="section">
      <nav class="flex items-center gap-2 text-xs text-gray-400 mb-8">
        <a href="/" class="hover:text-gray-700 no-underline">Home</a>
        <span>/</span>
        <span class="text-gray-700">Fire Safety Services in {city}, {state}</span>
      </nav>
      <div class="max-w-3xl">
        <div class="text-xs font-bold uppercase tracking-widest text-red-brand mb-3">Serving {city}, {stateFull} & Kern County</div>
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-5 leading-tight">Fire Safety Services in {city}, {state}</h1>
        <p class="text-lg text-gray-500 leading-relaxed mb-6">Complete fire protection services for commercial properties in {city}, {stateFull}. Fire extinguisher inspection, fire alarm installation, sprinkler systems, kitchen suppression, and fire code compliance consulting — all performed by licensed professionals to keep your building compliant with Bakersfield Fire Department requirements, California Fire Code (Title 24, Part 9), and NFPA standards.</p>
        <div class="flex flex-wrap gap-3">
          <button onclick={`openRFQ('','','Fire Safety Services - ${city}, ${state}')`} class="btn-primary text-sm">Schedule a Fire Safety Inspection</button>
          <a href="mailto:quotes@firesafetysupplyhouse.com" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-gray-200 text-sm font-medium text-gray-700 hover:border-gray-400 transition-colors no-underline">Contact Us</a>
        </div>
      </div>
    </div>
  </section>

  <!-- URGENCY BANNER -->
  <section class="bg-red-brand text-white py-4">
    <div class="section text-center">
      <p class="text-sm font-medium">⚠️ Don't wait for a violation. The Bakersfield Fire Department conducts routine inspections of all commercial properties. Non-compliant buildings face substantial fines under California Health and Safety Code.</p>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="py-16">
    <div class="section">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold tracking-tight mb-3">Fire Protection Services for {city} Businesses</h2>
        <p class="text-base text-gray-500 max-w-2xl mx-auto">From fire extinguisher inspections to full fire alarm installations, we provide every fire safety service your {city} property needs to stay compliant with California Fire Code requirements.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(s => (
          <div class="card p-6 flex flex-col">
            <div class="text-3xl mb-3">{s.icon}</div>
            <h3 class="text-lg font-bold mb-2">{s.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed flex-1 mb-3">{s.desc}</p>
            <div class="flex items-center justify-between">
              <span class="text-xs font-bold text-red-brand bg-red-light px-2 py-1 rounded">{s.nfpa}</span>
              <button onclick={`openRFQ('','','${s.title} - ${city}, ${state}')`} class="text-xs font-bold text-red-brand hover:underline bg-transparent border-0 cursor-pointer">Get Quote →</button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LOCAL INFO -->
  <section class="bg-gray-50 py-16">
    <div class="section">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-3xl font-bold tracking-tight mb-4">{city} Fire Code Requirements</h2>
          <p class="text-sm text-gray-600 leading-relaxed mb-4">{city} and Kern County enforce the California Fire Code (Title 24, Part 9), which adopts the International Fire Code with California-specific amendments. The Bakersfield Fire Department Fire Prevention Bureau is responsible for enforcing fire codes across all commercial properties within city limits. This includes plan review for new construction, routine inspections of existing buildings, and enforcement actions for violations.</p>
          <p class="text-sm text-gray-600 leading-relaxed mb-4">Kern County's economy spans agriculture, oil and gas production, manufacturing, and warehouse distribution. New commercial properties are coming online regularly across the Highway 99 corridor, the Rosedale area, and the Panama Lane commercial corridor. Every property — from agricultural processing facilities to industrial warehouses to office parks — needs fire protection systems designed, installed, and maintained in compliance with NFPA standards and California Fire Code requirements.</p>
          <p class="text-sm text-gray-600 leading-relaxed mb-4">Key NFPA standards that apply to {city} commercial properties include <a href="/compliance/nfpa-10/" class="text-red-brand hover:underline">NFPA 10</a> (portable fire extinguishers), <a href="/compliance/nfpa-72/" class="text-red-brand hover:underline">NFPA 72</a> (fire alarm systems), <a href="/compliance/nfpa-25/" class="text-red-brand hover:underline">NFPA 25</a> (water-based fire protection systems), and NFPA 96 (commercial cooking operations). California also requires fire alarm systems to be monitored by a UL-listed central station. The specific requirements depend on your building's occupancy type, size, and hazard classification under the California Fire Code.</p>
        </div>
        <div>
          <div class="bg-white rounded-xl p-6 border border-gray-200 mb-6">
            <h3 class="text-lg font-bold mb-4">Bakersfield Fire Prevention Contacts</h3>
            <div class="flex flex-col gap-3">
              <div>
                <p class="text-sm font-bold text-gray-800">Bakersfield Fire Department — Fire Prevention Bureau</p>
                <p class="text-xs text-gray-600">2101 H Street, {city}, {state} 93301</p>
                <p class="text-xs text-gray-600">Phone: (661) 326-3911</p>
              </div>
              <div class="border-t border-gray-100 pt-3">
                <p class="text-sm font-bold text-gray-800">Kern County Fire Department</p>
                <p class="text-xs text-gray-600">5642 Victor Street, {city}, {state} 93308</p>
                <p class="text-xs text-gray-600">Phone: (661) 391-7000</p>
                <p class="text-xs text-gray-600">Serves unincorporated areas of Kern County</p>
              </div>
              <div class="border-t border-gray-100 pt-3">
                <p class="text-sm font-bold text-gray-800">California State Fire Marshal</p>
                <p class="text-xs text-gray-600">(CAL FIRE OSFM)</p>
                <p class="text-xs text-gray-600">Phone: (916) 568-2500</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-gray-200">
            <h3 class="text-lg font-bold mb-4">Inspection Frequency Requirements</h3>
            <div class="flex flex-col gap-2">
              <div class="flex justify-between items-center py-2 border-b border-gray-100">
                <span class="text-sm text-gray-700">Fire Extinguishers (visual)</span>
                <span class="text-xs font-bold text-red-brand">Monthly</span>
              </div>
              <div class="flex justify-between items-center py-2 border-b border-gray-100">
                <span class="text-sm text-gray-700">Fire Extinguishers (professional)</span>
                <span class="text-xs font-bold text-red-brand">Annual</span>
              </div>
              <div class="flex justify-between items-center py-2 border-b border-gray-100">
                <span class="text-sm text-gray-700">Fire Alarm Systems</span>
                <span class="text-xs font-bold text-red-brand">Annual</span>
              </div>
              <div class="flex justify-between items-center py-2 border-b border-gray-100">
                <span class="text-sm text-gray-700">Fire Sprinkler Systems</span>
                <span class="text-xs font-bold text-red-brand">Quarterly+</span>
              </div>
              <div class="flex justify-between items-center py-2">
                <span class="text-sm text-gray-700">Kitchen Suppression</span>
                <span class="text-xs font-bold text-red-brand">Semi-Annual</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROPERTY TYPES -->
  <section class="py-16">
    <div class="section">
      <h2 class="text-3xl font-bold tracking-tight mb-3 text-center">Commercial Properties We Serve in {city}</h2>
      <p class="text-base text-gray-500 max-w-2xl mx-auto text-center mb-10">From the Highway 99 corridor to the Panama Lane commercial district to the Bakersfield Business Park, we provide fire safety services for every type of commercial property in Kern County.</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          'Restaurants & Food Service',
          'Hotels & Event Venues',
          'Office Buildings',
          'Retail & Strip Centers',
          'Warehouses & Distribution',
          'Manufacturing Facilities',
          'Agricultural Processing',
          'Healthcare & Medical',
          'Schools & Education',
          'Oil & Gas Operations',
          'Houses of Worship',
          'Mixed-Use Developments'
        ].map(type => (
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <span class="text-sm font-medium text-gray-700">{type}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-gray-50 py-16">
    <div class="section max-w-3xl">
      <h2 class="text-3xl font-bold tracking-tight mb-8 text-center">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-4">
        <div class="bg-white rounded-xl p-5 border border-gray-200">
          <h3 class="text-sm font-bold mb-2">What fire safety services are required for commercial buildings in {city}, {state}?</h3>
          <p class="text-sm text-gray-600 leading-relaxed">Commercial buildings must comply with the California Fire Code (Title 24, Part 9), which adopts the International Fire Code with California amendments. This includes fire extinguishers (NFPA 10), fire alarm systems with UL-listed monitoring (NFPA 72), sprinkler systems where required (NFPA 13/25), and kitchen suppression systems for commercial cooking (NFPA 96).</p>
        </div>
        <div class="bg-white rounded-xl p-5 border border-gray-200">
          <h3 class="text-sm font-bold mb-2">How often are fire inspections required in {city}?</h3>
          <p class="text-sm text-gray-600 leading-relaxed">The Bakersfield Fire Department conducts annual inspections of most commercial properties. Individual fire protection systems have their own inspection frequencies: fire extinguishers monthly/annually, fire alarms annually, sprinklers quarterly+, and kitchen suppression semi-annually. Kern County Fire Department handles unincorporated areas with similar requirements.</p>
        </div>
        <div class="bg-white rounded-xl p-5 border border-gray-200">
          <h3 class="text-sm font-bold mb-2">What are the penalties for fire code violations in {city}?</h3>
          <p class="text-sm text-gray-600 leading-relaxed">Fire code violations in California can result in substantial fines under the Health and Safety Code. The Bakersfield Fire Department can issue citations, stop-work orders, or vacate orders for serious safety deficiencies. First-time violators typically receive a correction period, while repeat violations face escalated penalties.</p>
        </div>
        <div class="bg-white rounded-xl p-5 border border-gray-200">
          <h3 class="text-sm font-bold mb-2">Do restaurants in {city} need special fire suppression systems?</h3>
          <p class="text-sm text-gray-600 leading-relaxed">Yes. All commercial cooking operations producing grease-laden vapors need an automatic wet chemical fire suppression system per NFPA 96, plus Class K fire extinguishers within 30 feet of cooking equipment. Systems must be inspected semi-annually by a licensed technician.</p>
        </div>
        <div class="bg-white rounded-xl p-5 border border-gray-200">
          <h3 class="text-sm font-bold mb-2">Who enforces fire codes in {city}, {state}?</h3>
          <p class="text-sm text-gray-600 leading-relaxed">The Bakersfield Fire Department Fire Prevention Bureau handles all fire code enforcement within city limits. The Kern County Fire Department enforces codes in unincorporated areas. The California State Fire Marshal (CAL FIRE OSFM) oversees licensing of fire protection service companies statewide and state-level fire safety regulations.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16">
    <div class="section text-center max-w-2xl">
      <h2 class="text-3xl font-bold tracking-tight mb-4">Schedule Your Fire Safety Inspection in {city}, {state}</h2>
      <p class="text-base text-gray-500 mb-6">Don't wait for the Bakersfield Fire Department to find violations. Get ahead of compliance requirements with a comprehensive fire safety assessment of your property.</p>
      <button onclick={`openRFQ('','','Fire Safety Inspection - ${city}, ${state}')`} class="btn-primary text-sm">Get a Free Quote</button>
      <p class="text-xs text-gray-400 mt-3">Or email us directly: <a href="mailto:quotes@firesafetysupplyhouse.com" class="text-red-brand hover:underline">quotes@firesafetysupplyhouse.com</a></p>
    </div>
  </section>

  <!-- INTERNAL LINKS -->
  <section class="bg-gray-50 py-12">
    <div class="section">
      <h3 class="text-lg font-bold mb-4">Related Resources</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a href="/blog/fire-alarm-installation-bakersfield-ca/" class="card p-4 no-underline group">
          <span class="text-xs font-bold text-red-brand">Blog</span>
          <p class="text-sm font-bold group-hover:text-red-brand transition-colors">Fire Alarm Installation in {city}, CA: Complete Guide</p>
        </a>
        <a href="/blog/commercial-fire-extinguisher-inspection-guide/" class="card p-4 no-underline group">
          <span class="text-xs font-bold text-red-brand">Compliance</span>
          <p class="text-sm font-bold group-hover:text-red-brand transition-colors">NFPA 10 Commercial Inspection Requirements</p>
        </a>
        <a href="/resources/fire-safety-checklist-property-managers/" class="card p-4 no-underline group">
          <span class="text-xs font-bold text-red-brand">Resources</span>
          <p class="text-sm font-bold group-hover:text-red-brand transition-colors">Fire Safety Checklist for Property Managers</p>
        </a>
        <a href="/fire-safety-services-tampa-fl/" class="card p-4 no-underline group">
          <span class="text-xs font-bold text-red-brand">City</span>
          <p class="text-sm font-bold group-hover:text-red-brand transition-colors">Fire Safety Services in Tampa, FL</p>
        </a>
        <a href="/fire-safety-services-arlington-tx/" class="card p-4 no-underline group">
          <span class="text-xs font-bold text-red-brand">City</span>
          <p class="text-sm font-bold group-hover:text-red-brand transition-colors">Fire Safety Services in Arlington, TX</p>
        </a>
        <a href="/blog/fire-sprinkler-installation-tampa-fl/" class="card p-4 no-underline group">
          <span class="text-xs font-bold text-red-brand">Blog</span>
          <p class="text-sm font-bold group-hover:text-red-brand transition-colors">Fire Sprinkler Installation Tampa FL: NFPA 13 Guide</p>
        </a>
      </div>
    </div>
  </section>
</Base>

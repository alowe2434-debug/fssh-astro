<Base title={`Fire Safety Services ${city}, ${state}`} description={`Fire inspection, alarm, sprinkler, and kitchen suppression services for New York, NY — NYC Fire Code compliance & Fire Department of New York (FDNY) violati`} canonical={`https://firesafetysupplyhouse.com/fire-safety-services-new-york-ny/`}>

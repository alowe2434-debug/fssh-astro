---
import Base from '../layouts/Base.astro';
const city = 'Houston';
const state = 'TX';
const stateFull = 'Texas';
const slug = 'houston-tx';
const county = 'Harris County';
const fireDept = 'Houston Fire Department';
---
<Base title={`Fire Safety Services ${city}, ${state}`} description={`Fire inspection, alarm, sprinkler, and kitchen suppression services for Houston, TX — International Fire Code compliance & Houston Fire Department violation`} canonical={`https://firesafetysupplyhouse.com/fire-safety-services-houston-tx/`}>
  <section class="bg-gradient-to-b from-gray-50 to-white py-16"><div class="section">
    <nav class="flex items-center gap-2 text-xs text-gray-400 mb-8"><a href="/" class="hover:text-gray-700 no-underline">Home</a><span>/</span><span class="text-gray-700">Fire Safety Services in {city}, {state}</span></nav>
    <div class="max-w-3xl">
      <div class="text-xs font-bold uppercase tracking-widest text-red-brand mb-3">Serving Houston, Texas — Harris County</div>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-5 leading-tight">Fire Safety Services in Houston, TX</h1>
      <p class="text-lg text-gray-500 leading-relaxed mb-6">Complete fire protection services for commercial properties in Houston, Texas. Fire extinguisher inspection, fire alarm installation, sprinkler systems, kitchen suppression, and International Fire Code compliance consulting — performed by licensed professionals to keep your building compliant with Houston Fire Department requirements and NFPA standards.</p>
      <div class="flex flex-wrap gap-3"><button onclick={`openRFQ('','','Fire Safety Services - ${city}, ${state}')`} class="btn-primary text-sm">Schedule a Fire Safety Inspection</button><a href="mailto:quotes@firesafetysupplyhouse.com" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-gray-200 text-sm font-medium text-gray-700 hover:border-gray-400 transition-colors no-underline">Contact Us</a></div>
    </div>
  </div></section>
  <section class="bg-red-brand text-white py-4"><div class="section text-center"><p class="text-sm font-medium">⚠️ Don't wait for a violation. Fire code violations in Houston carry fines starting at $500/day per uncorrected violation. Houston Fire Department is one of the nation's largest and most active enforcement agencies.</p></div></section>
  <section class="py-16"><div class="section">
    <div class="text-center mb-12"><h2 class="text-3xl font-bold tracking-tight mb-3">Fire Protection Services for Houston Businesses</h2><p class="text-base text-gray-500 max-w-2xl mx-auto">We provide every fire safety service your Houston commercial property needs to stay compliant with Houston Fire Department requirements and NFPA standards.</p></div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="card p-6 flex flex-col"><div class="text-3xl mb-3">🧯</div><h3 class="text-lg font-bold mb-2">Fire Extinguisher Inspection &amp; Service</h3><p class="text-sm text-gray-600 leading-relaxed flex-1 mb-3">NFPA 10 compliant fire extinguisher inspections for Houston commercial properties. Monthly visual checks, annual professional inspections, 6-year internal examinations, and 12-year hydrostatic testing. All service by licensed fire protection technicians.</p><div class="flex items-center justify-between"><span class="text-xs font-bold text-red-brand bg-red-light px-2 py-1 rounded">NFPA 10</span><button onclick={`openRFQ('','','Fire Extinguisher Service - ${city}, ${state}')`} class="text-xs font-bold text-red-brand hover:underline bg-transparent border-0 cursor-pointer">Get Quote →</button></div></div>
      <div class="card p-6 flex flex-col"><div class="text-3xl mb-3">🔔</div><h3 class="text-lg font-bold mb-2">Fire Alarm System Installation &amp; Testing</h3><p class="text-sm text-gray-600 leading-relaxed flex-1 mb-3">Complete fire alarm system design, installation, and annual testing for Houston commercial buildings. Addressable and conventional systems, smoke detectors, pull stations, horn/strobes, and monitoring. Full compliance with NFPA 72 and Houston Fire Department requirements.</p><div class="flex items-center justify-between"><span class="text-xs font-bold text-red-brand bg-red-light px-2 py-1 rounded">NFPA 72</span><button onclick={`openRFQ('','','Fire Alarm Installation - ${city}, ${state}')`} class="text-xs font-bold text-red-brand hover:underline bg-transparent border-0 cursor-pointer">Get Quote →</button></div></div>
      <div class="card p-6 flex flex-col"><div class="text-3xl mb-3">💧</div><h3 class="text-lg font-bold mb-2">Fire Sprinkler System Installation &amp; Inspection</h3><p class="text-sm text-gray-600 leading-relaxed flex-1 mb-3">Fire sprinkler design, installation, and inspection for Houston commercial properties. Wet, dry, pre-action, and deluge systems. Quarterly, semi-annual, and five-year inspections per NFPA 25. Texas enforces the IFC with local amendments. The Texas State Fire Marshal licenses all fire protection contractors statewide.</p><div class="flex items-center justify-between"><span class="text-xs font-bold text-red-brand bg-red-light px-2 py-1 rounded">NFPA 13 / NFPA 25</span><button onclick={`openRFQ('','','Fire Sprinkler Inspection - ${city}, ${state}')`} class="text-xs font-bold text-red-brand hover:underline bg-transparent border-0 cursor-pointer">Get Quote →</button></div></div>
      <div class="card p-6 flex flex-col"><div class="text-3xl mb-3">🍳</div><h3 class="text-lg font-bold mb-2">Commercial Kitchen Fire Suppression</h3><p class="text-sm text-gray-600 leading-relaxed flex-1 mb-3">Wet chemical fire suppression for Houston restaurants and food service operations. Design, installation, semi-annual inspection, and recharge. Ansul, Amerex, and Kidde certified. Required for all commercial cooking per NFPA 96.</p><div class="flex items-center justify-between"><span class="text-xs font-bold text-red-brand bg-red-light px-2 py-1 rounded">NFPA 96</span><button onclick={`openRFQ('','','Kitchen Suppression - ${city}, ${state}')`} class="text-xs font-bold text-red-brand hover:underline bg-transparent border-0 cursor-pointer">Get Quote →</button></div></div>
      <div class="card p-6 flex flex-col"><div class="text-3xl mb-3">📋</div><h3 class="text-lg font-bold mb-2">Fire Code Compliance Consulting</h3><p class="text-sm text-gray-600 leading-relaxed flex-1 mb-3">Fire code compliance audits, violation remediation, and pre-inspection consulting for Houston commercial properties. We help property managers resolve Houston Fire Department violations and prepare for inspections under the International Fire Code.</p><div class="flex items-center justify-between"><span class="text-xs font-bold text-red-brand bg-red-light px-2 py-1 rounded">NFPA 101</span><button onclick={`openRFQ('','','Fire Code Compliance - ${city}, ${state}')`} class="text-xs font-bold text-red-brand hover:underline bg-transparent border-0 cursor-pointer">Get Quote →</button></div></div>
    </div>
  </div></section>
  <section class="bg-gray-50 py-16"><div class="section"><div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
    <div>
      <h2 class="text-3xl font-bold tracking-tight mb-4">Houston Fire Code Requirements</h2>
      <p class="text-sm text-gray-600 leading-relaxed mb-4">The City of Houston enforces the International Fire Code (IFC) with local amendments through the Houston Fire Department — the fourth-largest city fire department in the United States. As the energy capital of the world and home to the Texas Medical Center (the largest medical complex globally), Houston oversees a commercial landscape of extraordinary scope spanning the Downtown oil and gas office tower corridor, the Medical Center's 54 institutions and 60+ million square feet of medical facilities, the Midtown and Montrose restaurant and entertainment districts, the Port of Houston — the nation's largest inland port — and extensive petrochemical and refining operations along the Houston Ship Channel.</p>
      <p class="text-sm text-gray-600 leading-relaxed mb-4">Houston's petrochemical and energy sector creates fire protection compliance obligations that dwarf standard commercial requirements. Refineries, chemical plants, pipeline facilities, and LNG terminals operate under NFPA 30, NFPA 59A, API standards, and Texas Commission on Environmental Quality requirements in addition to standard fire code obligations. The Texas Medical Center's concentration of hospitals and research facilities creates one of the most complex healthcare fire protection compliance environments in the world. Houston's gulf coast humidity and heat also create accelerated corrosion challenges for fire protection systems, particularly in outdoor and coastal industrial installations.</p>
      <p class="text-sm text-gray-600 leading-relaxed mb-4">Key standards include <a href="/compliance/nfpa-10/" class="text-red-brand hover:underline">NFPA 10</a>, <a href="/compliance/nfpa-72/" class="text-red-brand hover:underline">NFPA 72</a>, and <a href="/compliance/nfpa-25/" class="text-red-brand hover:underline">NFPA 25</a>.</p>
    </div>
    <div>
      <div class="bg-white rounded-xl p-6 border border-gray-200 mb-6">
        <h3 class="text-lg font-bold mb-4">Houston Fire Prevention Contacts</h3>
        <div class="flex flex-col gap-3">
          <div><p class="text-sm font-bold text-gray-800">Houston Fire Department — Fire Prevention</p><p class="text-xs text-gray-600">500 Jefferson Street, Houston, TX 77002</p><p class="text-xs text-gray-600">Phone: (713) 884-3800</p></div>
          <div class="border-t border-gray-100 pt-3"><p class="text-sm font-bold text-gray-800">Texas State Fire Marshal's Office</p><p class="text-xs text-gray-600">Licensing & Enforcement: (512) 676-6000</p></div>
        </div>
      </div>
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3 class="text-lg font-bold mb-4">Inspection Frequency Requirements</h3>
        <div class="flex flex-col gap-2">
          <div class="flex justify-between items-center py-2 border-b border-gray-100"><span class="text-sm text-gray-700">Fire Extinguishers (visual)</span><span class="text-xs font-bold text-red-brand">Monthly</span></div>
          <div class="flex justify-between items-center py-2 border-b border-gray-100"><span class="text-sm text-gray-700">Fire Extinguishers (professional)</span><span class="text-xs font-bold text-red-brand">Annual</span></div>
          <div class="flex justify-between items-center py-2 border-b border-gray-100"><span class="text-sm text-gray-700">Fire Alarm Systems</span><span class="text-xs font-bold text-red-brand">Annual</span></div>
          <div class="flex justify-between items-center py-2 border-b border-gray-100"><span class="text-sm text-gray-700">Fire Sprinkler Systems</span><span class="text-xs font-bold text-red-brand">Quarterly+</span></div>
          <div class="flex justify-between items-center py-2"><span class="text-sm text-gray-700">Kitchen Suppression</span><span class="text-xs font-bold text-red-brand">Semi-Annual</span></div>
        </div>
      </div>
    </div>
  </div></div></section>
  <section class="py-16"><div class="section">
    <h2 class="text-3xl font-bold tracking-tight mb-3 text-center">Commercial Properties We Serve in Houston</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4"><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Petrochemical & Refining</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Hospitals & Medical Centers</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Corporate Headquarters</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Restaurants & Entertainment</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Hotels & Convention Center</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Port & Marine Operations</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Warehouses & Distribution</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Multi-Family Residential</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Healthcare & Research</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Schools & Universities</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Houses of Worship</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Industrial & Manufacturing</span></div></div>
  </div></section>
  <section class="bg-gray-50 py-16"><div class="section max-w-3xl">
    <h2 class="text-3xl font-bold tracking-tight mb-8 text-center">Frequently Asked Questions</h2>
    <div class="flex flex-col gap-4">
      <div class="bg-white rounded-xl p-5 border border-gray-200"><h3 class="text-sm font-bold mb-2">What fire safety services are required for commercial buildings in Houston, TX?</h3><p class="text-sm text-gray-600 leading-relaxed">Houston enforces the International Fire Code (IFC). Requirements include fire extinguishers (NFPA 10), fire alarms (NFPA 72), sprinklers (NFPA 13/25), and kitchen suppression for commercial cooking (NFPA 96). Texas enforces the IFC with local amendments. The Texas State Fire Marshal licenses all fire protection contractors statewide.</p></div>
      <div class="bg-white rounded-xl p-5 border border-gray-200"><h3 class="text-sm font-bold mb-2">How often are fire inspections required in Houston?</h3><p class="text-sm text-gray-600 leading-relaxed">The Houston Fire Department conducts annual commercial property inspections. Fire extinguishers: monthly visual checks and annual professional inspection. Fire alarms: annual testing. Sprinklers: quarterly, semi-annual, and annual inspections. Kitchen suppression: semi-annual per NFPA 96.</p></div>
      <div class="bg-white rounded-xl p-5 border border-gray-200"><h3 class="text-sm font-bold mb-2">Our Houston facility is in the petrochemical or energy sector. What fire code requirements apply beyond the IFC?</h3><p class="text-sm text-gray-600 leading-relaxed">Petrochemical facilities, refineries, and chemical plants in Houston operate under a complex multi-regulatory framework beyond the IFC. NFPA 30 (Flammable and Combustible Liquids), NFPA 58 (Liquefied Petroleum Gas), API Recommended Practices (including API 2001, API 2003), Texas Commission on Environmental Quality (TCEQ) risk management plans, and OSHA Process Safety Management (PSM) regulations all apply depending on facility type and stored materials. A licensed fire protection engineer with petrochemical industry experience is essential for these facilities.</p></div>
      <div class="bg-white rounded-xl p-5 border border-gray-200"><h3 class="text-sm font-bold mb-2">Do restaurants in Houston need special fire suppression systems?</h3><p class="text-sm text-gray-600 leading-relaxed">Yes. All commercial cooking producing grease-laden vapors requires a wet chemical suppression system per NFPA 96, plus a Class K extinguisher within 30 feet of cooking equipment. Systems must be inspected semi-annually by a licensed technician.</p></div>
      <div class="bg-white rounded-xl p-5 border border-gray-200"><h3 class="text-sm font-bold mb-2">Who enforces fire codes in Houston, TX?</h3><p class="text-sm text-gray-600 leading-relaxed">The Houston Fire Department enforces fire codes within Houston limits. The Texas State Fire Marshal's Office licenses fire protection contractors at (512) 676-6000.</p></div>
    </div>
  </div></section>
  <section class="py-16"><div class="section text-center max-w-2xl">
    <h2 class="text-3xl font-bold tracking-tight mb-4">Schedule Your Fire Safety Inspection in Houston, TX</h2>
    <p class="text-base text-gray-500 mb-6">Don't wait for the Houston Fire Department to find violations. Get ahead of International Fire Code requirements with a comprehensive fire safety assessment of your Houston property.</p>
    <button onclick={`openRFQ('','','Fire Safety Inspection - ${city}, ${state}')`} class="btn-primary text-sm">Get a Free Quote</button>
    <p class="text-xs text-gray-400 mt-3">Or email us: <a href="mailto:quotes@firesafetysupplyhouse.com" class="text-red-brand hover:underline">quotes@firesafetysupplyhouse.com</a></p>
  </div></section>
  <section class="bg-gray-50 py-12"><div class="section">
    <h3 class="text-lg font-bold mb-4">Related Resources</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <a href="/compliance/nfpa-10/" class="card p-4 no-underline group"><span class="text-xs font-bold text-red-brand">Compliance</span><p class="text-sm font-bold group-hover:text-red-brand transition-colors">NFPA 10 Fire Extinguisher Requirements</p></a>
      <a href="/compliance/nfpa-72/" class="card p-4 no-underline group"><span class="text-xs font-bold text-red-brand">Compliance</span><p class="text-sm font-bold group-hover:text-red-brand transition-colors">NFPA 72 Fire Alarm System Standards</p></a>
      <a href="/fire-safety-services-corpus-christi-tx/" class="card p-4 no-underline group"><span class="text-xs font-bold text-red-brand">City</span><p class="text-sm font-bold group-hover:text-red-brand transition-colors">Fire Safety Services in Corpus Christi, TX</p></a>
      <a href="/fire-safety-services-arlington-tx/" class="card p-4 no-underline group"><span class="text-xs font-bold text-red-brand">City</span><p class="text-sm font-bold group-hover:text-red-brand transition-colors">Fire Safety Services in Arlington, TX</p></a>
      <a href="/fire-safety-services-san-antonio-tx/" class="card p-4 no-underline group"><span class="text-xs font-bold text-red-brand">City</span><p class="text-sm font-bold group-hover:text-red-brand transition-colors">Fire Safety Services in San Antonio, TX</p></a>
      <a href="/resources/fire-safety-checklist-property-managers/" class="card p-4 no-underline group"><span class="text-xs font-bold text-red-brand">Resources</span><p class="text-sm font-bold group-hover:text-red-brand transition-colors">Fire Safety Checklist for Property Managers</p></a>
    </div>
  </div></section>
</Base>

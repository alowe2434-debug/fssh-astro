---
import Base from '../layouts/Base.astro';

const city = 'Corpus Christi';
const state = 'TX';
const stateFull = 'Texas';
const slug = 'corpus-christi-tx';
const county = 'Nueces County';
const fireDept = 'Corpus Christi Fire Department';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": `Fire Safety Supply House — ${city}, ${state}`,
      "description": `Fire safety inspection, fire extinguisher service, fire alarm installation, fire sprinkler systems, and fire code compliance services in ${city}, ${stateFull}.`,
      "url": `https://firesafetysupplyhouse.com/fire-safety-services-${slug}/`,
      "areaServed": {
        "@type": "City",
        "name": city,
        "containedInPlace": { "@type": "State", "name": stateFull }
      },
      "serviceType": [
        "Fire Extinguisher Inspection",
        "Fire Alarm Installation",
        "Fire Sprinkler Installation",
        "Fire Suppression System Installation",
        "Fire Code Compliance Consulting"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "Sales",
        "email": "quotes@firesafetysupplyhouse.com"
      }
    },
    {
      "@type": "Service",
      "name": `Fire Safety Services in ${city}, ${state}`,
      "provider": { "@type": "Organization", "name": "Fire Safety Supply House" },
      "areaServed": { "@type": "City", "name": city },
      "serviceType": "Fire Protection Services",
      "description": `Complete fire safety services for commercial properties in ${city}, ${stateFull}: fire extinguisher inspection, fire alarm installation, fire sprinkler systems, fire suppression, and International Fire Code compliance consulting.`
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": `What fire safety services are required for commercial buildings in ${city}, ${state}?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `Commercial buildings in ${city} must comply with the International Fire Code (IFC) as adopted by the City of ${city}. Requirements include fire extinguisher inspection (NFPA 10), fire alarm system testing (NFPA 72), fire sprinkler system inspection (NFPA 25), and commercial kitchen suppression (NFPA 96). The ${fireDept} Fire Prevention Division enforces these requirements. Coastal and industrial properties along the Port of Corpus Christi have additional hazardous materials and marine fire protection considerations.`
          }
        },
        {
          "@type": "Question",
          "name": `How often are fire inspections required in ${city}, ${state}?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `The ${fireDept} conducts annual fire inspections of most commercial properties. Fire extinguishers require monthly visual checks and annual professional inspections per NFPA 10. Fire alarm systems require annual testing per NFPA 72. Sprinkler systems require quarterly, semi-annual, and annual inspections per NFPA 25. Commercial kitchen suppression systems require semi-annual inspection per NFPA 96.`
          }
        },
        {
          "@type": "Question",
          "name": `What are the penalties for fire code violations in ${city}, ${state}?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `Fire code violations in ${city} can result in fines starting at $500 per violation per day for uncorrected issues. The fire marshal can issue notices of violation with 30-day correction periods for first-time violations. Repeat violations or serious life-safety hazards face immediate enforcement including occupancy restrictions. The Texas State Fire Marshal's Office may also take action against licensed fire protection companies for code violations.`
          }
        },
        {
          "@type": "Question",
          "name": `Do restaurants in ${city} need special fire suppression systems?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `Yes. All commercial cooking operations in ${city} that produce grease-laden vapors must have an automatic wet chemical suppression system per NFPA 96. This applies to restaurants, hotel kitchens, food trucks, and institutional kitchens. Systems must be inspected semi-annually by a TDI-licensed technician. Class K fire extinguishers are also required within 30 feet of cooking equipment.`
          }
        },
        {
          "@type": "Question",
          "name": `Who enforces fire codes in ${city}, ${state}?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `The ${fireDept} Fire Prevention Division enforces fire codes within ${city} city limits. The Division handles plan reviews, commercial property inspections, and violation enforcement. The Texas State Fire Marshal's Office licenses fire protection service companies statewide and can investigate complaints at (512) 676-6000.`
          }
        }
      ]
    }
  ]
};

const services = [
  {
    title: 'Fire Extinguisher Inspection & Service',
    icon: '🧯',
    desc: `NFPA 10 compliant fire extinguisher inspections for ${city} commercial properties. Monthly visual checks, annual professional inspections, 6-year internal examinations, and 12-year hydrostatic testing. Service by TDI-licensed Texas fire protection technicians.`,
    nfpa: 'NFPA 10',
    cta: `Fire Extinguisher Service - ${city}, ${state}`
  },
  {
    title: 'Fire Alarm System Installation & Testing',
    icon: '🔔',
    desc: `Complete fire alarm system design, installation, and annual testing for ${city} commercial buildings. Addressable and conventional systems, smoke detectors, pull stations, horn/strobes, and monitoring. Full compliance with NFPA 72 and ${fireDept} requirements.`,
    nfpa: 'NFPA 72',
    cta: `Fire Alarm Installation - ${city}, ${state}`
  },
  {
    title: 'Fire Sprinkler System Installation & Inspection',
    icon: '💧',
    desc: `Fire sprinkler design, installation, and inspection for new construction and retrofit projects in ${city}. Wet, dry, pre-action, and deluge systems. Quarterly, semi-annual, and five-year inspections per NFPA 25. Experience with coastal humidity and corrosion challenges specific to ${city}.`,
    nfpa: 'NFPA 13 / NFPA 25',
    cta: `Fire Sprinkler Inspection - ${city}, ${state}`
  },
  {
    title: 'Commercial Kitchen Fire Suppression',
    icon: '🍳',
    desc: `Wet chemical fire suppression systems for ${city} restaurants, seafood kitchens, and food service operations. Design, installation, semi-annual inspection, and recharge. Ansul, Amerex, and Kidde certified. Required for all commercial cooking under NFPA 96.`,
    nfpa: 'NFPA 96',
    cta: `Kitchen Suppression - ${city}, ${state}`
  },
  {
    title: 'Fire Code Compliance Consulting',
    icon: '📋',
    desc: `Fire code compliance audits, violation remediation, and pre-inspection consulting for ${city} commercial properties. Specific expertise in port-adjacent industrial facilities, waterfront hospitality properties, and the compliance requirements of ${city}'s petrochemical and energy sector facilities.`,
    nfpa: 'IFC / NFPA 101',
    cta: `Fire Code Compliance - ${city}, ${state}`
  }
];
---

<Base
  title={`Fire Safety Services ${city}, ${state}`}
  description={`Fire safety services for ${city}, ${state} commercial properties. Fire extinguisher inspection, fire alarm installation, sprinkler systems,`}
  canonical={`https://firesafetysupplyhouse.com/fire-safety-services-${slug}/`}
  schema={schema}
>

  <section class="bg-gradient-to-b from-gray-50 to-white py-16">
    <div class="section">
      <nav class="flex items-center gap-2 text-xs text-gray-400 mb-8">
        <a href="/" class="hover:text-gray-700 no-underline">Home</a>
        <span>/</span>
        <span class="text-gray-700">Fire Safety Services in {city}, {state}</span>
      </nav>
      <div class="max-w-3xl">
        <div class="text-xs font-bold uppercase tracking-widest text-red-brand mb-3">Serving {city}, {stateFull} & {county}</div>
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-5 leading-tight">Fire Safety Services in {city}, {state}</h1>
        <p class="text-lg text-gray-500 leading-relaxed mb-6">Complete fire protection services for commercial properties in {city}, {stateFull}. Fire extinguisher inspection, fire alarm installation, sprinkler systems, kitchen suppression, and International Fire Code compliance consulting — performed by licensed professionals to keep your building in compliance with {fireDept} requirements and NFPA standards.</p>
        <div class="flex flex-wrap gap-3">
          <button onclick={`openRFQ('','','Fire Safety Services - ${city}, ${state}')`} class="btn-primary text-sm">Schedule a Fire Safety Inspection</button>
          <a href="mailto:quotes@firesafetysupplyhouse.com" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-gray-200 text-sm font-medium text-gray-700 hover:border-gray-400 transition-colors no-underline">Contact Us</a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-red-brand text-white py-4">
    <div class="section text-center">
      <p class="text-sm font-medium">⚠️ Don't wait for a violation. The {fireDept} conducts routine inspections of all commercial properties. Fire code violations carry fines starting at $500/day per uncorrected violation.</p>
    </div>
  </section>

  <section class="py-16">
    <div class="section">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold tracking-tight mb-3">Fire Protection Services for {city} Businesses</h2>
        <p class="text-base text-gray-500 max-w-2xl mx-auto">From the downtown waterfront to North Beach, Padre Island, and the Port of {city} industrial corridor — we serve every commercial property type in {city}.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(s => (
          <div class="card p-6 flex flex-col">
            <div class="text-3xl mb-3">{s.icon}</div>
            <h3 class="text-lg font-bold mb-2">{s.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed flex-1 mb-3">{s.desc}</p>
            <div class="flex items-center justify-between">
              <span class="text-xs font-bold text-red-brand bg-red-light px-2 py-1 rounded">{s.nfpa}</span>
              <button onclick={`openRFQ('','','${s.cta}')`} class="text-xs font-bold text-red-brand hover:underline bg-transparent border-0 cursor-pointer">Get Quote →</button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-16">
    <div class="section">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <h2 class="text-3xl font-bold tracking-tight mb-4">{city} Fire Code Requirements</h2>
          <p class="text-sm text-gray-600 leading-relaxed mb-4">The City of {city} adopts the International Fire Code (IFC) with local amendments, enforced by the {fireDept} Fire Prevention Division. As South Texas's largest city and home to one of the nation's largest ports, {city} has a diverse commercial landscape spanning downtown waterfront hotels and restaurants, Southside retail corridors, North Beach tourism and hospitality, and a significant concentration of petrochemical, refinery, and industrial operations in the harbor and industrial district.</p>
          <p class="text-sm text-gray-600 leading-relaxed mb-4">Coastal conditions in {city} — high humidity, salt air, and heat — create accelerated corrosion challenges for fire protection equipment. Sprinkler systems and fire alarm panels in coastal commercial buildings require more frequent inspection and maintenance than inland facilities to maintain reliable operability. The {fireDept} is aware of these conditions and actively enforces maintenance requirements.</p>
          <p class="text-sm text-gray-600 leading-relaxed mb-4">Key NFPA standards applicable to {city} commercial properties include <a href="/compliance/nfpa-10/" class="text-red-brand hover:underline">NFPA 10</a>, <a href="/compliance/nfpa-72/" class="text-red-brand hover:underline">NFPA 72</a>, and <a href="/compliance/nfpa-25/" class="text-red-brand hover:underline">NFPA 25</a>. Industrial facilities near the port may also be subject to NFPA 30 (flammable and combustible liquids) and NFPA 72 special hazard requirements.</p>
        </div>
        <div>
          <div class="bg-white rounded-xl p-6 border border-gray-200 mb-6">
            <h3 class="text-lg font-bold mb-4">{city} Fire Prevention Contacts</h3>
            <div class="flex flex-col gap-3">
              <div>
                <p class="text-sm font-bold text-gray-800">{fireDept} — Fire Prevention Division</p>
                <p class="text-xs text-gray-600">1301 N. Shoreline Blvd, {city}, {state} 78401</p>
                <p class="text-xs text-gray-600">Phone: (361) 826-3950</p>
              </div>
              <div class="border-t border-gray-100 pt-3">
                <p class="text-sm font-bold text-gray-800">Texas State Fire Marshal's Office</p>
                <p class="text-xs text-gray-600">Licensing & Complaints: (512) 676-6000</p>
                <p class="text-xs text-gray-600">tdi.texas.gov/fire</p>
              </div>
              <div class="border-t border-gray-100 pt-3">
                <p class="text-sm font-bold text-gray-800">{county} Fire Marshal</p>
                <p class="text-xs text-gray-600">Serves unincorporated {county} areas</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-xl p-6 border border-gray-200">
            <h3 class="text-lg font-bold mb-4">Inspection Frequency Requirements</h3>
            <div class="flex flex-col gap-2">
              <div class="flex justify-between items-center py-2 border-b border-gray-100">
                <span class="text-sm text-gray-700">Fire Extinguishers (visual)</span>
                <span class="text-xs font-bold text-red-brand">Monthly</span>
              </div>
              <div class="flex justify-between items-center py-2 border-b border-gray-100">
                <span class="text-sm text-gray-700">Fire Extinguishers (professional)</span>
                <span class="text-xs font-bold text-red-brand">Annual</span>
              </div>
              <div class="flex justify-between items-center py-2 border-b border-gray-100">
                <span class="text-sm text-gray-700">Fire Alarm Systems</span>
                <span class="text-xs font-bold text-red-brand">Annual</span>
              </div>
              <div class="flex justify-between items-center py-2 border-b border-gray-100">
                <span class="text-sm text-gray-700">Fire Sprinkler Systems</span>
                <span class="text-xs font-bold text-red-brand">Quarterly+</span>
              </div>
              <div class="flex justify-between items-center py-2">
                <span class="text-sm text-gray-700">Kitchen Suppression</span>
                <span class="text-xs font-bold text-red-brand">Semi-Annual</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="section">
      <h2 class="text-3xl font-bold tracking-tight mb-3 text-center">Commercial Properties We Serve in {city}</h2>
      <p class="text-base text-gray-500 max-w-2xl mx-auto text-center mb-10">From waterfront seafood restaurants to port-adjacent industrial facilities and Southside retail corridors, we serve every commercial property type in {city}.</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          'Restaurants & Seafood Dining',
          'Hotels & Beach Resorts',
          'Office Buildings',
          'Retail & Strip Centers',
          'Warehouses & Distribution',
          'Petrochemical & Industrial',
          'Multi-Family Residential',
          'Healthcare & Medical',
          'Schools & Education',
          'Marina & Marine Facilities',
          'Houses of Worship',
          'Port & Freight Operations'
        ].map(type => (
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <span class="text-sm font-medium text-gray-700">{type}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-16">
    <div class="section max-w-3xl">
      <h2 class="text-3xl font-bold tracking-tight mb-8 text-center">Frequently Asked Questions</h2>
      <div class="flex flex-col gap-4">
        <div class="bg-white rounded-xl p-5 border border-gray-200">
          <h3 class="text-sm font-bold mb-2">What fire safety services are required for commercial buildings in {city}, {state}?</h3>
          <p class="text-sm text-gray-600 leading-relaxed">{city} adopts the International Fire Code (IFC). Requirements include fire extinguishers (NFPA 10), fire alarms (NFPA 72), sprinklers (NFPA 13/25), and kitchen suppression (NFPA 96). Industrial and port-adjacent properties may have additional requirements under NFPA 30 and other hazardous materials standards.</p>
        </div>
        <div class="bg-white rounded-xl p-5 border border-gray-200">
          <h3 class="text-sm font-bold mb-2">Does coastal humidity affect fire protection systems in {city}?</h3>
          <p class="text-sm text-gray-600 leading-relaxed">Yes. {city}'s Gulf Coast climate — high humidity, salt air, and heat — accelerates corrosion in metal sprinkler components, fire alarm panel connections, and extinguisher hardware. Commercial properties near the waterfront should schedule fire protection inspections more frequently and use corrosion-resistant components where available. Document all inspections carefully for the {fireDept}.</p>
        </div>
        <div class="bg-white rounded-xl p-5 border border-gray-200">
          <h3 class="text-sm font-bold mb-2">What are the penalties for fire code violations in {city}?</h3>
          <p class="text-sm text-gray-600 leading-relaxed">Fire code violations in {city} carry fines starting at $500 per violation per day for uncorrected issues. First-time violators typically get 30 days to correct. Serious life-safety hazards can result in immediate occupancy restrictions. The Texas State Fire Marshal can also take action against licensed fire protection companies involved in non-compliant work.</p>
        </div>
        <div class="bg-white rounded-xl p-5 border border-gray-200">
          <h3 class="text-sm font-bold mb-2">Do restaurants in {city} need special fire suppression systems?</h3>
          <p class="text-sm text-gray-600 leading-relaxed">Yes. All commercial cooking producing grease-laden vapors requires a wet chemical suppression system per NFPA 96, plus a Class K extinguisher within 30 feet of cooking equipment. Semi-annual inspection by a TDI-licensed technician is required. This applies to all restaurant types including seafood operations, food trucks, and hotel kitchens.</p>
        </div>
        <div class="bg-white rounded-xl p-5 border border-gray-200">
          <h3 class="text-sm font-bold mb-2">Who enforces fire codes in {city}, {state}?</h3>
          <p class="text-sm text-gray-600 leading-relaxed">The {fireDept} Fire Prevention Division enforces fire codes within {city} city limits. The Texas State Fire Marshal's Office licenses fire protection service companies at (512) 676-6000. The {county} Fire Marshal serves unincorporated county areas outside {city} city limits.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="section text-center max-w-2xl">
      <h2 class="text-3xl font-bold tracking-tight mb-4">Schedule Your Fire Safety Inspection in {city}, {state}</h2>
      <p class="text-base text-gray-500 mb-6">Don't wait for the {fireDept} to find violations. Get ahead of International Fire Code requirements with a comprehensive fire safety assessment of your {city} property.</p>
      <button onclick={`openRFQ('','','Fire Safety Inspection - ${city}, ${state}')`} class="btn-primary text-sm">Get a Free Quote</button>
      <p class="text-xs text-gray-400 mt-3">Or email us directly: <a href="mailto:quotes@firesafetysupplyhouse.com" class="text-red-brand hover:underline">quotes@firesafetysupplyhouse.com</a></p>
    </div>
  </section>

  <section class="bg-gray-50 py-12">
    <div class="section">
      <h3 class="text-lg font-bold mb-4">Related Resources</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <a href="/compliance/nfpa-10/" class="card p-4 no-underline group">
          <span class="text-xs font-bold text-red-brand">Compliance</span>
          <p class="text-sm font-bold group-hover:text-red-brand transition-colors">NFPA 10 Fire Extinguisher Requirements</p>
        </a>
        <a href="/compliance/nfpa-72/" class="card p-4 no-underline group">
          <span class="text-xs font-bold text-red-brand">Compliance</span>
          <p class="text-sm font-bold group-hover:text-red-brand transition-colors">NFPA 72 Fire Alarm System Standards</p>
        </a>
        <a href="/resources/fire-safety-checklist-property-managers/" class="card p-4 no-underline group">
          <span class="text-xs font-bold text-red-brand">Resources</span>
          <p class="text-sm font-bold group-hover:text-red-brand transition-colors">Fire Safety Checklist for Property Managers</p>
        </a>
        <a href="/fire-safety-services-arlington-tx/" class="card p-4 no-underline group">
          <span class="text-xs font-bold text-red-brand">City</span>
          <p class="text-sm font-bold group-hover:text-red-brand transition-colors">Fire Safety Services in Arlington, TX</p>
        </a>
        <a href="/fire-safety-services-st-louis-mo/" class="card p-4 no-underline group">
          <span class="text-xs font-bold text-red-brand">City</span>
          <p class="text-sm font-bold group-hover:text-red-brand transition-colors">Fire Safety Services in St. Louis, MO</p>
        </a>
        <a href="/fire-safety-services-pittsburgh-pa/" class="card p-4 no-underline group">
          <span class="text-xs font-bold text-red-brand">City</span>
          <p class="text-sm font-bold group-hover:text-red-brand transition-colors">Fire Safety Services in Pittsburgh, PA</p>
        </a>
      </div>
    </div>
  </section>

</Base>

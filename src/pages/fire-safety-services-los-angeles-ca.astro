---
import Base from '../layouts/Base.astro';
const city = 'Los Angeles';
const state = 'CA';
const stateFull = 'California';
const slug = 'los-angeles-ca';
const county = 'Los Angeles County';
const fireDept = 'Los Angeles Fire Department (LAFD)';
---
<Base title={`Fire Safety Services ${city}, ${state}`} description={`Fire inspection, alarm, sprinkler, and kitchen suppression services for Los Angeles, CA — California Fire Code / LAFD Reg 4 compliance & Los Angeles Fire De`} canonical={`https://firesafetysupplyhouse.com/fire-safety-services-los-angeles-ca/`}>
  <section class="bg-gradient-to-b from-gray-50 to-white py-16"><div class="section">
    <nav class="flex items-center gap-2 text-xs text-gray-400 mb-8"><a href="/" class="hover:text-gray-700 no-underline">Home</a><span>/</span><span class="text-gray-700">Fire Safety Services in {city}, {state}</span></nav>
    <div class="max-w-3xl">
      <div class="text-xs font-bold uppercase tracking-widest text-red-brand mb-3">Serving Los Angeles, California — Los Angeles County</div>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-5 leading-tight">Fire Safety Services in Los Angeles, CA</h1>
      <p class="text-lg text-gray-500 leading-relaxed mb-6">Complete fire protection services for commercial properties in Los Angeles, California. Fire extinguisher inspection, fire alarm installation, sprinkler systems, kitchen suppression, and California Fire Code / LAFD Reg 4 compliance consulting — performed by licensed professionals to keep your building compliant with Los Angeles Fire Department (LAFD) requirements and NFPA standards.</p>
      <div class="flex flex-wrap gap-3"><button onclick={`openRFQ('','','Fire Safety Services - ${city}, ${state}')`} class="btn-primary text-sm">Schedule a Fire Safety Inspection</button><a href="mailto:quotes@firesafetysupplyhouse.com" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-gray-200 text-sm font-medium text-gray-700 hover:border-gray-400 transition-colors no-underline">Contact Us</a></div>
    </div>
  </div></section>
  <section class="bg-red-brand text-white py-4"><div class="section text-center"><p class="text-sm font-medium">⚠️ Don't wait for a violation. California Fire Code and LAFD Regulation 4 violations carry per-day fines. Results must be filed through thecomplianceengine.com within 7 days of inspection.</p></div></section>
  <section class="py-16"><div class="section">
    <div class="text-center mb-12"><h2 class="text-3xl font-bold tracking-tight mb-3">Fire Protection Services for Los Angeles Businesses</h2><p class="text-base text-gray-500 max-w-2xl mx-auto">We provide every fire safety service your Los Angeles commercial property needs to stay compliant with Los Angeles Fire Department (LAFD) requirements and NFPA standards.</p></div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="card p-6 flex flex-col"><div class="text-3xl mb-3">🧯</div><h3 class="text-lg font-bold mb-2">Fire Extinguisher Inspection &amp; Service</h3><p class="text-sm text-gray-600 leading-relaxed flex-1 mb-3">NFPA 10 compliant fire extinguisher inspections for Los Angeles commercial properties. Monthly visual checks, annual professional inspections, 6-year internal examinations, and 12-year hydrostatic testing. All service by licensed fire protection technicians.</p><div class="flex items-center justify-between"><span class="text-xs font-bold text-red-brand bg-red-light px-2 py-1 rounded">NFPA 10</span><button onclick={`openRFQ('','','Fire Extinguisher Service - ${city}, ${state}')`} class="text-xs font-bold text-red-brand hover:underline bg-transparent border-0 cursor-pointer">Get Quote →</button></div></div>
      <div class="card p-6 flex flex-col"><div class="text-3xl mb-3">🔔</div><h3 class="text-lg font-bold mb-2">Fire Alarm System Installation &amp; Testing</h3><p class="text-sm text-gray-600 leading-relaxed flex-1 mb-3">Complete fire alarm system design, installation, and annual testing for Los Angeles commercial buildings. Addressable and conventional systems, smoke detectors, pull stations, horn/strobes, and monitoring. Full compliance with NFPA 72 and Los Angeles Fire Department (LAFD) requirements.</p><div class="flex items-center justify-between"><span class="text-xs font-bold text-red-brand bg-red-light px-2 py-1 rounded">NFPA 72</span><button onclick={`openRFQ('','','Fire Alarm Installation - ${city}, ${state}')`} class="text-xs font-bold text-red-brand hover:underline bg-transparent border-0 cursor-pointer">Get Quote →</button></div></div>
      <div class="card p-6 flex flex-col"><div class="text-3xl mb-3">💧</div><h3 class="text-lg font-bold mb-2">Fire Sprinkler System Installation &amp; Inspection</h3><p class="text-sm text-gray-600 leading-relaxed flex-1 mb-3">Fire sprinkler design, installation, and inspection for Los Angeles commercial properties. Wet, dry, pre-action, and deluge systems. Quarterly, semi-annual, and five-year inspections per NFPA 25. Los Angeles has both California Fire Code obligations and LAFD Chief's Regulation 4 — a unique mandatory testing program requiring certified testers and Compliance Engine filing.</p><div class="flex items-center justify-between"><span class="text-xs font-bold text-red-brand bg-red-light px-2 py-1 rounded">NFPA 13 / NFPA 25</span><button onclick={`openRFQ('','','Fire Sprinkler Inspection - ${city}, ${state}')`} class="text-xs font-bold text-red-brand hover:underline bg-transparent border-0 cursor-pointer">Get Quote →</button></div></div>
      <div class="card p-6 flex flex-col"><div class="text-3xl mb-3">🍳</div><h3 class="text-lg font-bold mb-2">Commercial Kitchen Fire Suppression</h3><p class="text-sm text-gray-600 leading-relaxed flex-1 mb-3">Wet chemical fire suppression for Los Angeles restaurants and food service operations. Design, installation, semi-annual inspection, and recharge. Ansul, Amerex, and Kidde certified. Required for all commercial cooking per NFPA 96.</p><div class="flex items-center justify-between"><span class="text-xs font-bold text-red-brand bg-red-light px-2 py-1 rounded">NFPA 96</span><button onclick={`openRFQ('','','Kitchen Suppression - ${city}, ${state}')`} class="text-xs font-bold text-red-brand hover:underline bg-transparent border-0 cursor-pointer">Get Quote →</button></div></div>
      <div class="card p-6 flex flex-col"><div class="text-3xl mb-3">📋</div><h3 class="text-lg font-bold mb-2">Fire Code Compliance Consulting</h3><p class="text-sm text-gray-600 leading-relaxed flex-1 mb-3">Fire code compliance audits, violation remediation, and pre-inspection consulting for Los Angeles commercial properties. We help property managers resolve Los Angeles Fire Department (LAFD) violations and prepare for inspections under the California Fire Code / LAFD Reg 4.</p><div class="flex items-center justify-between"><span class="text-xs font-bold text-red-brand bg-red-light px-2 py-1 rounded">NFPA 101</span><button onclick={`openRFQ('','','Fire Code Compliance - ${city}, ${state}')`} class="text-xs font-bold text-red-brand hover:underline bg-transparent border-0 cursor-pointer">Get Quote →</button></div></div>
    </div>
  </div></section>
  <section class="bg-gray-50 py-16"><div class="section"><div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
    <div>
      <h2 class="text-3xl font-bold tracking-tight mb-4">Los Angeles Fire Code Requirements</h2>
      <p class="text-sm text-gray-600 leading-relaxed mb-4">The City of Los Angeles enforces the California Fire Code (Title 19 CCR) and LAFD Chief's Regulation 4 through the Los Angeles Fire Department. As the second-largest city in the United States and the entertainment, aerospace, and international trade capital of the West Coast, Los Angeles has a uniquely complex fire code compliance environment. In addition to standard California Fire Code obligations, commercial buildings in LA City limits must comply with LAFD Chief's Regulation 4 — a mandatory annual fire system testing program that requires results filed through thecomplianceengine.com within 7 days of inspection by LAFD-certified testers.</p>
      <p class="text-sm text-gray-600 leading-relaxed mb-4">LAFD Regulation 4 applies across all of Los Angeles City limits — from Downtown and Hollywood to the Westside, San Fernando Valley, and Harbor Gateway. Property managers in LA must track both their standard California Fire Code compliance calendar and their Reg 4 testing calendar, which involves 20+ distinct LAFD tester certification categories for different system types. Fire Safety Supply House operates dedicated LAFD Regulation 4 compliance resources for 10 Los Angeles neighborhoods — from Downtown to Playa Vista — with equipment fulfillment and LAFD-certified tester referrals for all Regulation 4 categories.</p>
      <p class="text-sm text-gray-600 leading-relaxed mb-4">Key standards include <a href="/compliance/nfpa-10/" class="text-red-brand hover:underline">NFPA 10</a>, <a href="/compliance/nfpa-72/" class="text-red-brand hover:underline">NFPA 72</a>, and <a href="/compliance/nfpa-25/" class="text-red-brand hover:underline">NFPA 25</a>.</p>
    </div>
    <div>
      <div class="bg-white rounded-xl p-6 border border-gray-200 mb-6">
        <h3 class="text-lg font-bold mb-4">Los Angeles Fire Prevention Contacts</h3>
        <div class="flex flex-col gap-3">
          <div><p class="text-sm font-bold text-gray-800">Los Angeles Fire Department (LAFD) — Fire Prevention</p><p class="text-xs text-gray-600">200 N. Main Street, Los Angeles, CA 90012</p><p class="text-xs text-gray-600">Phone: (213) 978-3473</p></div>
          <div class="border-t border-gray-100 pt-3"><p class="text-sm font-bold text-gray-800">California State Fire Marshal's Office</p><p class="text-xs text-gray-600">Licensing & Enforcement: (916) 445-8200</p></div>
        </div>
      </div>
      <div class="bg-white rounded-xl p-6 border border-gray-200">
        <h3 class="text-lg font-bold mb-4">Inspection Frequency Requirements</h3>
        <div class="flex flex-col gap-2">
          <div class="flex justify-between items-center py-2 border-b border-gray-100"><span class="text-sm text-gray-700">Fire Extinguishers (visual)</span><span class="text-xs font-bold text-red-brand">Monthly</span></div>
          <div class="flex justify-between items-center py-2 border-b border-gray-100"><span class="text-sm text-gray-700">Fire Extinguishers (professional)</span><span class="text-xs font-bold text-red-brand">Annual</span></div>
          <div class="flex justify-between items-center py-2 border-b border-gray-100"><span class="text-sm text-gray-700">Fire Alarm Systems</span><span class="text-xs font-bold text-red-brand">Annual</span></div>
          <div class="flex justify-between items-center py-2 border-b border-gray-100"><span class="text-sm text-gray-700">Fire Sprinkler Systems</span><span class="text-xs font-bold text-red-brand">Quarterly+</span></div>
          <div class="flex justify-between items-center py-2"><span class="text-sm text-gray-700">Kitchen Suppression</span><span class="text-xs font-bold text-red-brand">Semi-Annual</span></div>
        </div>
      </div>
    </div>
  </div></div></section>
  <section class="py-16"><div class="section">
    <h2 class="text-3xl font-bold tracking-tight mb-3 text-center">Commercial Properties We Serve in Los Angeles</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4"><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">High-Rise Office & Hotels</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Entertainment & Studios</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Restaurants & Hospitality</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Port & Marine Operations</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Warehouses & Logistics</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Multi-Family Residential</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Healthcare & Medical</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Schools & Universities</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Retail & Commercial</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Manufacturing & Industrial</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Houses of Worship</span></div><div class="bg-gray-50 rounded-lg p-4 text-center"><span class="text-sm font-medium text-gray-700">Mixed-Use Developments</span></div></div>
  </div></section>
  <section class="bg-gray-50 py-16"><div class="section max-w-3xl">
    <h2 class="text-3xl font-bold tracking-tight mb-8 text-center">Frequently Asked Questions</h2>
    <div class="flex flex-col gap-4">
      <div class="bg-white rounded-xl p-5 border border-gray-200"><h3 class="text-sm font-bold mb-2">What fire safety services are required for commercial buildings in Los Angeles, CA?</h3><p class="text-sm text-gray-600 leading-relaxed">Los Angeles enforces the California Fire Code (Title 19 CCR) + LAFD Chief's Regulation 4. Requirements include fire extinguishers (NFPA 10), fire alarms (NFPA 72), sprinklers (NFPA 13/25), and kitchen suppression for commercial cooking (NFPA 96). Los Angeles has both California Fire Code obligations and LAFD Chief's Regulation 4 — a unique mandatory testing program requiring certified testers and Compliance Engine filing.</p></div>
      <div class="bg-white rounded-xl p-5 border border-gray-200"><h3 class="text-sm font-bold mb-2">How often are fire inspections required in Los Angeles?</h3><p class="text-sm text-gray-600 leading-relaxed">The Los Angeles Fire Department (LAFD) conducts annual commercial property inspections. Fire extinguishers: monthly visual checks and annual professional inspection. Fire alarms: annual testing. Sprinklers: quarterly, semi-annual, and annual inspections. Kitchen suppression: semi-annual per NFPA 96.</p></div>
      <div class="bg-white rounded-xl p-5 border border-gray-200"><h3 class="text-sm font-bold mb-2">What is LAFD Regulation 4 and how does it differ from standard California Fire Code?</h3><p class="text-sm text-gray-600 leading-relaxed">LAFD Chief's Regulation 4 is a mandatory fire system testing program unique to Los Angeles City limits — it is separate from and additional to the standard California Fire Code. Regulation 4 requires annual testing of fire alarms, smoke management systems, and other systems by LAFD-certified testers (who must hold specific LAFD certification categories, not just state licenses), with results filed through thecomplianceengine.com within 7 days of inspection. Sprinklers and standpipes require five-year testing cycles. Kitchen suppression requires semi-annual inspection. Results filed late incur penalties separate from any underlying compliance violations. See our dedicated LAFD Regulation 4 neighborhood pages for detailed guidance.</p></div>
      <div class="bg-white rounded-xl p-5 border border-gray-200"><h3 class="text-sm font-bold mb-2">Do restaurants in Los Angeles need special fire suppression systems?</h3><p class="text-sm text-gray-600 leading-relaxed">Yes. All commercial cooking producing grease-laden vapors requires a wet chemical suppression system per NFPA 96, plus a Class K extinguisher within 30 feet of cooking equipment. Systems must be inspected semi-annually by a licensed technician.</p></div>
      <div class="bg-white rounded-xl p-5 border border-gray-200"><h3 class="text-sm font-bold mb-2">Who enforces fire codes in Los Angeles, CA?</h3><p class="text-sm text-gray-600 leading-relaxed">The Los Angeles Fire Department (LAFD) enforces fire codes within Los Angeles limits. The California State Fire Marshal's Office licenses fire protection contractors at (916) 445-8200.</p></div>
    </div>
  </div></section>
  <section class="py-16"><div class="section text-center max-w-2xl">
    <h2 class="text-3xl font-bold tracking-tight mb-4">Schedule Your Fire Safety Inspection in Los Angeles, CA</h2>
    <p class="text-base text-gray-500 mb-6">Don't wait for the Los Angeles Fire Department (LAFD) to find violations. Get ahead of California Fire Code / LAFD Reg 4 requirements with a comprehensive fire safety assessment of your Los Angeles property.</p>
    <button onclick={`openRFQ('','','Fire Safety Inspection - ${city}, ${state}')`} class="btn-primary text-sm">Get a Free Quote</button>
    <p class="text-xs text-gray-400 mt-3">Or email us: <a href="mailto:quotes@firesafetysupplyhouse.com" class="text-red-brand hover:underline">quotes@firesafetysupplyhouse.com</a></p>
  </div></section>
  <section class="bg-gray-50 py-12"><div class="section">
    <h3 class="text-lg font-bold mb-4">Related Resources</h3>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <a href="/compliance/nfpa-10/" class="card p-4 no-underline group"><span class="text-xs font-bold text-red-brand">Compliance</span><p class="text-sm font-bold group-hover:text-red-brand transition-colors">NFPA 10 Fire Extinguisher Requirements</p></a>
      <a href="/compliance/nfpa-72/" class="card p-4 no-underline group"><span class="text-xs font-bold text-red-brand">Compliance</span><p class="text-sm font-bold group-hover:text-red-brand transition-colors">NFPA 72 Fire Alarm System Standards</p></a>
      <a href="/fire-safety-services-long-beach-ca/" class="card p-4 no-underline group"><span class="text-xs font-bold text-red-brand">City</span><p class="text-sm font-bold group-hover:text-red-brand transition-colors">Fire Safety Services in Long Beach, CA</p></a>
      <a href="/fire-safety-services-santa-ana-ca/" class="card p-4 no-underline group"><span class="text-xs font-bold text-red-brand">City</span><p class="text-sm font-bold group-hover:text-red-brand transition-colors">Fire Safety Services in Santa Ana, CA</p></a>
      <a href="/fire-safety-services-irvine-ca/" class="card p-4 no-underline group"><span class="text-xs font-bold text-red-brand">City</span><p class="text-sm font-bold group-hover:text-red-brand transition-colors">Fire Safety Services in Irvine, CA</p></a>
      <a href="/resources/fire-safety-checklist-property-managers/" class="card p-4 no-underline group"><span class="text-xs font-bold text-red-brand">Resources</span><p class="text-sm font-bold group-hover:text-red-brand transition-colors">Fire Safety Checklist for Property Managers</p></a>
    </div>
  </div></section>
</Base>

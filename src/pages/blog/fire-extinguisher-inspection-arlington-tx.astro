            <tbody>
              <tr><td class="p-3 border border-gray-200">Annual Inspection & Tag</td><td class="p-3 border border-gray-200">$15–$35</td><td class="p-3 border border-gray-200 text-gray-600">Every 12 months</td></tr>
              <tr class="bg-gray-50"><td class="p-3 border border-gray-200">Recharge (ABC Dry Chemical)</td><td class="p-3 border border-gray-200">$20–$45</td><td class="p-3 border border-gray-200 text-gray-600">As needed / after use</td></tr>
              <tr><td class="p-3 border border-gray-200">6-Year Internal Examination</td><td class="p-3 border border-gray-200">$25–$55</td><td class="p-3 border border-gray-200 text-gray-600">Every 6 years</td></tr>
              <tr class="bg-gray-50"><td class="p-3 border border-gray-200">12-Year Hydrostatic Test</td><td class="p-3 border border-gray-200">$30–$75</td><td class="p-3 border border-gray-200 text-gray-600">Every 12 years</td></tr>

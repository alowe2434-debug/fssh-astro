---
import Base from '../layouts/Base.astro';
---

<Base title="Page Not Found" description="Page not found.">
  <div class="section py-24 text-center">
    <div class="text-8xl font-bold text-gray-100 mb-4">404</div>
    <h1 class="text-2xl font-bold mb-3">Page not found</h1>
    <p class="text-gray-500 mb-8">The page you're looking for doesn't exist or has been moved.</p>
    <div class="flex gap-3 justify-center">
      <a href="/" class="btn-primary">Back to Home</a>
      <a href="/products/" class="btn-secondary">Browse Products</a>
    </div>
  </div>
</Base>
